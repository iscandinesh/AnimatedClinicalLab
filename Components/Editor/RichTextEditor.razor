                                            <span style="font-size: 0.65rem; color: #9ca3af;">@img.Size</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <!-- Modal Footer -->
                        <div style="padding: 1rem 1.5rem; background: #fafafa; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end;">
                            <button type="button" @onclick="CloseGoogleDriveDialog" style="padding: 8px 16px; background: #ffffff; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 0.85rem; font-weight: 600; color: #475569; cursor: pointer;">Cancel</button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <textarea class="rte-code-textarea"
                      @bind="_rawText"
                      style="width: 100%; max-width: 850px; min-height: 800px; padding: 2rem; outline: none; border: 1px solid #cbd5e1; border-radius: 6px; background: #0f172a; color: #38bdf8; font-family: 'Fira Code', 'Courier New', monospace; font-size: 0.95rem; line-height: 1.6; resize: vertical; box-shadow: 0 4px 20px rgba(0,0,0,0.1);"
                      placeholder="Enter raw source content here..."></textarea>
        }
    </div>
</div>

