                                    <button type="button" onclick="document.getElementById('dialog-local-upload').click()" style="background: transparent; border: 1px dashed #cbd5e1; color: #2563eb; padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: background 0.15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='transparent'">
