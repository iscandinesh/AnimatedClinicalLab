    private string? ConvertGoogleDriveUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return null;
        string fileId = "";
        if (url.Contains("drive.google.com/file/d/"))
        {
            var parts = url.Split("drive.google.com/file/d/");
            if (parts.Length > 1)
            {
                fileId = parts[1].Split('/')[0].Split('?')[0];
            }
        }
        else if (url.Contains("drive.google.com/open?id="))
        {
            var parts = url.Split("drive.google.com/open?id=");
            if (parts.Length > 1)
            {
                fileId = parts[1].Split('&')[0];
            }
        }
        else if (url.Contains("docs.google.com/uc?id="))
        {
            return url;
        }
        else if (url.Contains("docs.google.com/uc?export=download&id="))
        {
            return url;
        }
        
        if (!string.IsNullOrEmpty(fileId))
        {
            return $"https://docs.google.com/uc?export=download&id={fileId}";
        }
        return url;
    }

