        line-height: 1.8;
    }

    /* Modern Table Layout & Styles inside Tiptap Editor Canvas */
    .ProseMirror table {
        border-collapse: collapse !important;
        table-layout: fixed;
        width: 100%;
        margin: var(--table-margin, 1.5rem auto) !important;
        overflow: hidden;
        border: var(--table-border-width, 2px) var(--table-border-style, solid) var(--table-border-color, #cbd5e1) !important;
    }

    .ProseMirror table.table-align-left {
        --table-margin: 1.5rem auto 1.5rem 0;
    }
    .ProseMirror table.table-align-center {
        --table-margin: 1.5rem auto;
    }
    .ProseMirror table.table-align-right {
        --table-margin: 1.5rem 0 1.5rem auto;
    }

    .ProseMirror td, .ProseMirror th {
        min-width: 1em;
        border-width: var(--table-border-width, 2px) !important;
        border-style: var(--table-border-style, solid) !important;
        border-color: var(--table-border-color, #cbd5e1) !important;
        padding: 12px 16px;
        vertical-align: top;
        box-sizing: border-box;
        position: relative;
    }

    .ProseMirror th {
        font-weight: 700;
        background-color: #f1f5f9;
        text-align: left;
    }

    /* Selected cell styling in Tiptap */
    .ProseMirror .selectedCell:after {
        background: rgba(37, 99, 235, 0.08);
        content: "";
        left: 0; right: 0; top: 0; bottom: 0;
        pointer-events: none;
        position: absolute;
        z-index: 2;
    }

    /* Column resizer styling */
    .ProseMirror .column-resize-handle {
        position: absolute;
        right: -2px;
        top: 0;
        bottom: -2px;
        width: 4px;
        background-color: #3b82f6;
        pointer-events: none;
        opacity: 0;
        z-index: 10;
        cursor: col-resize;
    }

    .ProseMirror table:hover .column-resize-handle {
        opacity: 0.3;
    }

    .ProseMirror .column-resize-handle:hover,
    .ProseMirror table:hover .column-resize-handle.selected {
        opacity: 1;
        width: 6px;
    }

    /* Alignments */
    .ProseMirror[data-align="left"] { text-align: left; }
    .ProseMirror[data-align="center"] { text-align: center; }
    .ProseMirror[data-align="right"] { text-align: right; }
    .ProseMirror[data-align="justify"] { text-align: justify; }

    /* Custom font classes styling */
    .ProseMirror span[style*="font-family"] {
        display: inline-block;
