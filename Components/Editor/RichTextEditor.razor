        await JSRuntime.InvokeVoidAsync("editorInterop.setZoom", factor);
    }

    private async Task ToggleReadOnly()
    {
        _readOnlyMode = !_readOnlyMode;
        await JSRuntime.InvokeVoidAsync("editorInterop.setEditable", !_readOnlyMode);
    }

    public async Task SetHtmlContentAsync(string html)
    {
        _currentHtml = html;
        if (_viewMode == "wysiwyg")
        {
            await JSRuntime.InvokeVoidAsync("editorInterop.setContent", html);
        }
        else
        {
            _rawText = html;
        }
        StateHasChanged();
    }

    public string GetHtmlContent()
    {
        if (_viewMode == "wysiwyg")
        {
            return _currentHtml;
        }
        else if (_viewMode == "html")
        {
            return _rawText;
        }
        else // markdown
        {
            return ConvertMarkdownToHtml(_rawText);
        }
    }

    private async Task HandleViewModeChanged(string newMode)
    {
        if (_viewMode == newMode) return;

        // Transition from WYSIWYG to other modes
        if (_viewMode == "wysiwyg")
        {
            if (newMode == "html")
            {
                _rawText = _currentHtml;
            }
            else if (newMode == "markdown")
            {
                _rawText = await ConvertHtmlToMarkdownAsync(_currentHtml);
            }
            await JSRuntime.InvokeVoidAsync("editorInterop.destroyCKEditor");
        }
        // Transition from HTML to other modes
        else if (_viewMode == "html")
        {
            if (newMode == "wysiwyg")
            {
                _currentHtml = _rawText;
                _shouldInitCKEditor = true;
            }
            else if (newMode == "markdown")
            {
                var astJson = await JSRuntime.InvokeAsync<string>("editorInterop.htmlToAst", _rawText);
                var doc = System.Text.Json.JsonSerializer.Deserialize<ElementNode>(astJson);
                _rawText = doc != null ? _markdownSerializer.Serialize(doc) : "";
            }
        }
        // Transition from Markdown to other modes
        else if (_viewMode == "markdown")
        {
            var html = ConvertMarkdownToHtml(_rawText);
            if (newMode == "wysiwyg")
            {
                _currentHtml = html;
                _shouldInitCKEditor = true;
            }
            else if (newMode == "html")
            {
                _rawText = html;
            }
        }

        _viewMode = newMode;
        StateHasChanged();
    }

    private async Task<string> ConvertHtmlToMarkdownAsync(string html)
    {
        try
        {
            var astJson = await JSRuntime.InvokeAsync<string>("editorInterop.htmlToAst", html);
            var doc = System.Text.Json.JsonSerializer.Deserialize<ElementNode>(astJson);
            if (doc != null)
            {
                return _markdownSerializer.Serialize(doc);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error converting HTML to Markdown: {ex.Message}");
        }
        return "";
    }

    private string ReplaceInlineMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return text;
        
        // Escape HTML first to prevent injection issues
        var escaped = System.Net.WebUtility.HtmlEncode(text);

        // Bold
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"\*\*([^*]+)\*\*", "<strong>$1</strong>");
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"__([^_]+)__", "<strong>$1</strong>");

        // Italic
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"\*([^*]+)\*", "<em>$1</em>");
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"_([^_]+)_", "<em>$1</em>");

        // Code
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"`([^`]+)`", "<code>$1</code>");

        // Strikethrough
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"~~([^~]+)~~", "<s>$1</s>");

        // Subscript and Superscript
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"~([^~]+)~", "<sub>$1</sub>");
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"\^([^^]+)\^", "<sup>$1</sup>");

        // Images: ![alt](url)
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"!\[([^\]]*)\]\(([^)]+)\)", "<img src=\"$2\" alt=\"$1\" />");

        // Links: [text](url)
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"\[([^\]]+)\]\(([^)]+)\)", "<a href=\"$2\" target=\"_blank\">$1</a>");
        
        // Unescape tags we just added
        escaped = escaped.Replace("&lt;strong&gt;", "<strong>").Replace("&lt;/strong&gt;", "</strong>")
                         .Replace("&lt;em&gt;", "<em>").Replace("&lt;/em&gt;", "</em>")
                         .Replace("&lt;code&gt;", "<code>").Replace("&lt;/code&gt;", "</code>")
                         .Replace("&lt;s&gt;", "<s>").Replace("&lt;/s&gt;", "</s>")
                         .Replace("&lt;sub&gt;", "<sub>").Replace("&lt;/sub&gt;", "</sub>")
                         .Replace("&lt;sup&gt;", "<sup>").Replace("&lt;/sup&gt;", "</sup>")
                         .Replace("&lt;img ", "<img ").Replace("/&gt;", "/>")
                         .Replace("&lt;a ", "<a ").Replace("&lt;/a&gt;", "</a>");

        return escaped;
    }

    private void CloseActiveBlock(System.Text.StringBuilder sb, ref string activeBlock, System.Collections.Generic.List<string> tableLines = null!)
    {
        if (string.IsNullOrEmpty(activeBlock)) return;

        if (activeBlock == "ul") sb.Append("</ul>");
        else if (activeBlock == "ol") sb.Append("</ol>");
        else if (activeBlock == "taskList") sb.Append("</ul>");
        else if (activeBlock == "blockquote") sb.Append("</blockquote>");
        else if (activeBlock == "table" && tableLines != null && tableLines.Count > 0)
        {
            sb.Append("<table style=\"border-collapse: collapse; width: 100%; margin: 1.5rem 0;\"><tbody>");
            for (int i = 0; i < tableLines.Count; i++)
            {
                var rowText = tableLines[i].Trim();
                if (i == 1 && rowText.Contains("---"))
                {
                    continue; // Skip separator row
                }
                sb.Append("<tr style=\"border-bottom: 1px solid #e2e8f0;\">");
                var cells = rowText.Split('|', StringSplitOptions.None);
                int startIdx = 1;
                int endIdx = cells.Length - 2;
                if (cells.Length <= 2)
                {
                    startIdx = 0;
                    endIdx = cells.Length - 1;
                }
                for (int c = startIdx; c <= endIdx; c++)
                {
                    var cellContent = cells[c].Trim();
                    string cellTag = (i == 0) ? "th" : "td";
                    string cellStyle = cellTag == "th" 
                        ? "border: 2px solid #cbd5e1; padding: 12px 16px; font-weight: 700; background-color: #f1f5f9; text-align: left;" 
                        : "border: 2px solid #cbd5e1; padding: 12px 16px; min-width: 60px; background: #ffffff;";
                    sb.Append($"<{cellTag} style=\"{cellStyle}\">");
                    sb.Append(ReplaceInlineMarkdown(cellContent));
                    sb.Append($"</{cellTag}>");
                }
                sb.Append("</tr>");
            }
            sb.Append("</tbody></table>");
        }
        
        activeBlock = "";
    }

    private string ConvertMarkdownToHtml(string md)
    {
        if (string.IsNullOrEmpty(md)) return "";
        var lines = md.Split('\n');
        var sb = new System.Text.StringBuilder();
        
        string activeBlock = ""; // "ul", "ol", "taskList", "blockquote", "code-block", "table"
        var codeBlockContent = new System.Text.StringBuilder();
        var tableLines = new System.Collections.Generic.List<string>();

        foreach (var rawLine in lines)
        {
            var line = rawLine;
            // Handle carriage return
            if (line.EndsWith("\r")) line = line.Substring(0, line.Length - 1);
            var trimmed = line.Trim();

            // Table Row Handling
            if (trimmed.StartsWith("|"))
            {
                if (activeBlock != "table")
                {
                    CloseActiveBlock(sb, ref activeBlock, tableLines);
                    activeBlock = "table";
                    tableLines.Clear();
                }
                tableLines.Add(trimmed);
                continue;
            }

            // Code block handling
            if (trimmed.StartsWith("```"))
            {
                if (activeBlock == "code-block")
                {
                    sb.Append($"<pre><code>{System.Net.WebUtility.HtmlEncode(codeBlockContent.ToString().TrimEnd())}</code></pre>");
                    codeBlockContent.Clear();
                    activeBlock = "";
                }
                else
                {
                    CloseActiveBlock(sb, ref activeBlock, tableLines);
                    activeBlock = "code-block";
                }
                continue;
            }

            if (activeBlock == "code-block")
            {
                codeBlockContent.AppendLine(line);
                continue;
            }

            if (string.IsNullOrEmpty(trimmed))
            {
                CloseActiveBlock(sb, ref activeBlock, tableLines);
                continue;
            }

            // Page Break
            if (trimmed == "<!-- page-break -->")
            {
                CloseActiveBlock(sb, ref activeBlock, tableLines);
                sb.Append("<hr class=\"page-break\" style=\"border-top: 2px dashed #3b82f6; margin: 2rem 0; position: relative; text-align: center; page-break-after: always; height: 0;\" />");
                continue;
            }

            // Video: @[video](url)
            var videoMatch = System.Text.RegularExpressions.Regex.Match(trimmed, @"^@\[video\]\(([^)]+)\)$");
            if (videoMatch.Success)
            {
                CloseActiveBlock(sb, ref activeBlock, tableLines);
                var url = videoMatch.Groups[1].Value;
                if (url.Contains("youtube.com") || url.Contains("youtu.be") || url.Contains("vimeo.com") || url.Contains("player.vimeo.com"))
                {
                    string embedUrl = url;
                    if (url.Contains("youtube.com/watch?v="))
                    {
                        var videoId = url.Split("v=")[1].Split('&')[0];
                        embedUrl = $"https://www.youtube.com/embed/{videoId}";
                    }
                    else if (url.Contains("youtu.be/"))
                    {
                        var videoId = url.Split("youtu.be/")[1].Split('?')[0];
                        embedUrl = $"https://www.youtube.com/embed/{videoId}";
                    }
                    sb.Append($"<div class=\"video-wrapper\" style=\"position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; margin: 1.5rem 0;\"><iframe src=\"{embedUrl}\" width=\"100%\" style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;\" allowfullscreen=\"true\" frameborder=\"0\"></iframe></div>");
                }
                else
                {
                    sb.Append($"<video src=\"{url}\" controls=\"true\" style=\"max-width: 100%; margin: 1.5rem 0; display: block; border-radius: 8px;\" width=\"100%\"></video>");
                }
                continue;
            }

            // Horizontal Rule
            if (trimmed == "---" || trimmed == "***" || trimmed == "___")
            {
                CloseActiveBlock(sb, ref activeBlock, tableLines);
                sb.Append("<hr />");
                continue;
            }

            // Headings
            if (trimmed.StartsWith("#"))
            {
                CloseActiveBlock(sb, ref activeBlock, tableLines);
                int level = 0;
                while (level < trimmed.Length && trimmed[level] == '#') level++;
                if (level >= 1 && level <= 6 && level < trimmed.Length && trimmed[level] == ' ')
                {
                    var content = trimmed.Substring(level + 1).Trim();
                    sb.Append($"<h{level}>{ReplaceInlineMarkdown(content)}</h{level}>");
                    continue;
                }
            }

            // Blockquote
            if (trimmed.StartsWith(">"))
            {
                if (activeBlock != "blockquote")
                {
                    CloseActiveBlock(sb, ref activeBlock, tableLines);
                    sb.Append("<blockquote>");
                    activeBlock = "blockquote";
                }
                var content = trimmed.Substring(1).Trim();
                sb.Append($"<p>{ReplaceInlineMarkdown(content)}</p>");
                continue;
            }

            // Task List Item: starts with "- [ ] " or "- [x] " or "* [ ] " or "* [x] "
            var isTaskItem = (trimmed.StartsWith("- [ ] ") || trimmed.StartsWith("- [x] ") ||
                              trimmed.StartsWith("* [ ] ") || trimmed.StartsWith("* [x] "));
            if (isTaskItem)
            {
                if (activeBlock != "taskList")
                {
                    CloseActiveBlock(sb, ref activeBlock, tableLines);
                    sb.Append("<ul data-type=\"taskList\">");
                    activeBlock = "taskList";
                }
                bool isChecked = trimmed.Contains("[x]");
                var content = trimmed.Substring(6).Trim();
                sb.Append($"<li data-type=\"taskItem\" data-checked=\"{(isChecked ? "true" : "false")}\">");
                sb.Append($"<label><input type=\"checkbox\" {(isChecked ? "checked" : "")} /><span></span></label>");
                sb.Append($"<div>{ReplaceInlineMarkdown(content)}</div>");
                sb.Append("</li>");
                continue;
            }

            // Bullet List Item: starts with "- " or "* "
            if (trimmed.StartsWith("- ") || trimmed.StartsWith("* "))
            {
                if (activeBlock != "ul")
                {
                    CloseActiveBlock(sb, ref activeBlock, tableLines);
                    sb.Append("<ul>");
                    activeBlock = "ul";
                }
                var content = trimmed.Substring(2).Trim();
                sb.Append($"<li>{ReplaceInlineMarkdown(content)}</li>");
                continue;
            }

            // Numbered List Item: starts with "1. " or "1) " (or any digits)
            var numberedMatch = System.Text.RegularExpressions.Regex.Match(trimmed, @"^(\d+)[.)]\s+(.*)$");
            if (numberedMatch.Success)
            {
                if (activeBlock != "ol")
                {
                    CloseActiveBlock(sb, ref activeBlock, tableLines);
                    sb.Append("<ol>");
                    activeBlock = "ol";
                }
                var content = numberedMatch.Groups[2].Value.Trim();
                sb.Append($"<li>{ReplaceInlineMarkdown(content)}</li>");
                continue;
            }

            // Plain Paragraph
            CloseActiveBlock(sb, ref activeBlock, tableLines);
            sb.Append($"<p>{ReplaceInlineMarkdown(trimmed)}</p>");
        }

        CloseActiveBlock(sb, ref activeBlock, tableLines);
        return sb.ToString();
    }

    private string StripHtmlTags(string html)
    {
        if (string.IsNullOrEmpty(html)) return "";
        var charArray = new char[html.Length];
        int index = 0;
        bool inTag = false;
        for (int i = 0; i < html.Length; i++)
        {
            char c = html[i];
            if (c == '<')
            {
                inTag = true;
                continue;
            }
            if (c == '>')
            {
                inTag = false;
                continue;
            }
            if (!inTag)
            {
                charArray[index++] = c;
            }
        }
        return new string(charArray, 0, index);
    }

    private int GetCharacterCount()
    {
        return StripHtmlTags(_currentHtml).Length;
    }

    private int GetWordCount()
    {
        var text = StripHtmlTags(_currentHtml);
        if (string.IsNullOrWhiteSpace(text)) return 0;
        return text.Split(new[] { ' ', '\r', '\n', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;
    }



    public void Dispose()
    {
        _objRef?.Dispose();
    }
