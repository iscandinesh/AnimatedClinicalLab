                                    <button type="button" @onclick="ImportGoogleDriveLink" style="padding: 8px 16px; background: #2563eb; color: white; border: none; border-radius: 6px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: background 0.15s;" onmouseover="this.style.background='#1d4ed8'" onmouseout="this.style.background='#2563eb'">Import</button>
                                </div>
                                @if (!string.IsNullOrEmpty(_googleDriveError))
                                {
                                    <span style="color: #ef4444; font-size: 0.75rem; margin-top: 4px; display: block;">@_googleDriveError</span>
                                }
                            </div>
                            
                            <!-- File Browser -->
                            <div style="border-top: 1px solid #f1f5f9; padding-top: 1rem;">
