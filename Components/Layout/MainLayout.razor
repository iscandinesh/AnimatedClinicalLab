@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeService ThemeState
@inject IJSRuntime JS

<div class="app-shell">
    <!-- Global Animated Background (Floating blobs, grid overlay, and particles) -->
    <div class="dna-bg" aria-hidden="true" style="position: fixed; inset: 0; z-index: -1; pointer-events: none; overflow: hidden;">
        <div class="floating-blob b1" style="opacity: 0.08;"></div>
        <div class="floating-blob b2" style="opacity: 0.08;"></div>
        <div class="floating-blob b3" style="opacity: 0.06;"></div>
        <div class="hero-grid-bg" style="opacity: 0.015; height: 100vh;"></div>
    </div>

    <!-- Global Background Bubbles -->
    <div class="bubble-container" aria-hidden="true">
        <div class="bubble" style="left: 10%; width: 40px; height: 40px; animation-delay: 0s; animation-duration: 12s;"></div>
        <div class="bubble" style="left: 25%; width: 60px; height: 60px; animation-delay: 2s; animation-duration: 15s;"></div>
        <div class="bubble" style="left: 40%; width: 30px; height: 30px; animation-delay: 4s; animation-duration: 10s;"></div>
        <div class="bubble" style="left: 55%; width: 50px; height: 50px; animation-delay: 1s; animation-duration: 14s;"></div>
        <div class="bubble" style="left: 70%; width: 70px; height: 70px; animation-delay: 3s; animation-duration: 18s;"></div>
        <div class="bubble" style="left: 85%; width: 45px; height: 45px; animation-delay: 5s; animation-duration: 13s;"></div>
        <div class="bubble" style="left: 95%; width: 35px; height: 35px; animation-delay: 7s; animation-duration: 11s;"></div>
    </div>

    <!-- Particle Simulation -->
    <div class="position-fixed inset-0 pointer-events-none" style="z-index: 0; overflow: hidden;">
        @for (int i = 0; i < 20; i++)
        {
            var left = System.Random.Shared.Next(0, 100);
            var delay = System.Random.Shared.NextDouble() * 8;
            var duration = 10 + System.Random.Shared.NextDouble() * 12;
            var size = 3 + System.Random.Shared.NextDouble() * 5;
            <span class="particle" style="left: @(left)%; animation-delay: @(delay)s; animation-duration: @(duration)s; width: @(size)px; height: @(size)px;"></span>
        }
    </div>

    <div class="app-layout">
        <header>
            <NavMenu />
        </header>

        <main class="main-content">
            @Body
        </main>

    </div>

    <footer class="app-footer">
