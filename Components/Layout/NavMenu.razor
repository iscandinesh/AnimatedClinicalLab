@inject IJSRuntime JS

<div class="navbar-inner container d-flex justify-content-between align-items-center py-2">
    <!-- Brand -->
    <a class="navbar-brand d-flex align-items-center text-decoration-none" href="">
        <img src="images/logo-full.png" alt="Alpha Diagnostics Centre" class="nav-logo" />
    </a>

    <!-- Mobile Toggle -->
    <button class="nav-toggler d-lg-none border-0 bg-transparent p-2" @onclick="ToggleNavMenu" aria-label="Toggle navigation">
        <i class="bi @(collapseNavMenu ? "bi-list" : "bi-x-lg") fs-3 text-primary"></i>
    </button>

    <!-- Desktop Nav -->
    <nav class="d-none d-lg-flex align-items-center gap-1">
        <NavLink class="nav-link fw-medium px-3 py-2" href="" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink class="nav-link fw-medium px-3 py-2" href="about">About Us</NavLink>
        <NavLink class="nav-link fw-medium px-3 py-2" href="services">Services</NavLink>
        <NavLink class="nav-link fw-medium px-3 py-2" href="locations">Locations</NavLink>
        <NavLink class="nav-link fw-medium px-3 py-2" href="contact">Contact</NavLink>
        <div class="ms-3">
            <a href="contact" class="btn btn-primary-custom nav-btn">
                <i class="bi bi-calendar-check"></i> Book a Test
            </a>
        </div>
    </nav>
</div>

<!-- Mobile Nav Overlay -->
@if (!collapseNavMenu)
{
    <div class="mobile-nav-overlay animate-fade-in-down" @onclick="ToggleNavMenu"></div>
    <nav class="mobile-nav animate-fade-in-down">
        <div class="d-flex flex-column gap-1 p-4">
            <NavLink class="mobile-nav-link" href="" Match="NavLinkMatch.All" @onclick="ToggleNavMenu">
                <i class="bi bi-house me-3"></i> Home
            </NavLink>
            <NavLink class="mobile-nav-link" href="about" @onclick="ToggleNavMenu">
                <i class="bi bi-info-circle me-3"></i> About Us
            </NavLink>
            <NavLink class="mobile-nav-link" href="services" @onclick="ToggleNavMenu">
                <i class="bi bi-clipboard-pulse me-3"></i> Services
            </NavLink>
            <NavLink class="mobile-nav-link" href="locations" @onclick="ToggleNavMenu">
                <i class="bi bi-geo-alt me-3"></i> Locations
            </NavLink>
            <NavLink class="mobile-nav-link" href="contact" @onclick="ToggleNavMenu">
                <i class="bi bi-envelope me-3"></i> Contact
            </NavLink>
            <div class="mt-4">
                <a href="contact" class="btn btn-primary-custom w-100" @onclick="ToggleNavMenu">
                    <i class="bi bi-calendar-check"></i> Book a Test
                </a>
            </div>
        </div>
    </nav>
}

@code {
    private bool collapseNavMenu = true;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initScrollHeader");
        }
    }
}
