@page "/about"

<PageTitle>About Us - Alpha Diagnostics Centre</PageTitle>

<section class="page-header py-5 text-center text-white position-relative" style="background: var(--gradient-primary); padding-top: 120px !important; padding-bottom: 80px !important;">
    <div class="container position-relative z-2 animate-fade-in-up">
        <div class="badge-pill mb-3 glass-panel-dark d-inline-block px-4 py-2 text-white border-white border-opacity-25" style="border-radius: 30px;">
            <i class="bi bi-info-circle me-2"></i> Discover Our Story
        </div>
        <h1 class="display-4 fw-bold mb-3 mt-2">About Alpha Diagnostics</h1>
        <p class="lead mb-0 text-white opacity-75">Bringing international-level lab standards to Erode and beyond.</p>
    </div>
</section>

<!-- Who We Are Section -->
<section class="py-5 bg-white">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 animate-fade-in-left">
                <div class="position-relative">
                    <div class="position-absolute top-0 start-0 w-100 h-100 bg-primary-subtle rounded-5" style="transform: translate(-20px, -20px); z-index: 0;"></div>
                    <div class="modern-card position-relative z-1 border-0 shadow-lg p-5">
                        <i class="bi bi-quote text-primary opacity-25" style="font-size: 5rem; position: absolute; top: 10px; right: 20px;"></i>
                        <h3 class="fw-bold mb-4">Who We Are</h3>
                        <p class="text-secondary fs-5 mb-4 line-height-lg">
                            Alpha Diagnostics Centre is a modern diagnostic laboratory built and led by experienced doctors who are deeply focused on quality.
                        </p>
                        <p class="text-secondary mb-4">
                            Our goal is to bring international-level lab standards, automation, and accuracy to the people of Erode and the surrounding regions.
                        </p>
                        <p class="text-secondary mb-0">
                            We are a barcoded, interfaced, and fully automated lab with NABL accreditation and ICMR approval, designed to deliver reliable reports as quickly as possible.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 animate-fade-in-right delay-200">
                <div class="mb-5">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="icon-box bg-primary-subtle text-primary p-3 rounded-circle">
                            <i class="bi bi-eye fs-4"></i>
                        </div>
                        <h2 class="fw-bold mb-0">Our Vision</h2>
                    </div>
                    <div class="glass-panel p-4 border-start border-4 border-primary rounded-end-4">
                        <p class="text-secondary mb-0 fs-5 font-italic">
                            "To be a quality laboratory that provides flawless reporting with the latest technology, helping people and the medical community move towards a healthier world, and to become the most trusted network referral lab in the region."
                        </p>
                    </div>
                </div>

                <div>
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="icon-box bg-secondary-subtle text-secondary-dark p-3 rounded-circle">
                            <i class="bi bi-bullseye fs-4"></i>
                        </div>
                        <h2 class="fw-bold mb-0">Our Mission</h2>
                    </div>
                    <div class="glass-panel p-4 border-start border-4 border-info rounded-end-4">
                        <p class="text-secondary mb-3 fw-bold">To be the best and most trusted network referral lab in the region by:</p>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2 d-flex align-items-start gap-2 text-secondary">
                                <i class="bi bi-check-circle-fill text-primary mt-1"></i>
                                <span>Maintaining the highest standard of quality, value, and dignity.</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start gap-2 text-secondary">
                                <i class="bi bi-check-circle-fill text-primary mt-1"></i>
                                <span>Building a strong and skilled team.</span>
                            </li>
                            <li class="mb-2 d-flex align-items-start gap-2 text-secondary">
                                <i class="bi bi-check-circle-fill text-primary mt-1"></i>
                                <span>Providing excellent service and support to patients and doctors.</span>
                            </li>
                            <li class="d-flex align-items-start gap-2 text-secondary">
                                <i class="bi bi-check-circle-fill text-primary mt-1"></i>
                                <span>Using high-end technology in every community and region we serve.</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- What Makes Us Different -->
<section class="py-5 bg-main">
    <div class="container py-5">
        <div class="text-center mb-5 animate-fade-in-up">
            <h2 class="section-title">What Makes Us Different</h2>
            <p class="section-subtitle">Excellence driven by technology, speed, and strict quality control.</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-100">
                <div class="modern-card">
                    <div class="card-icon bg-success-subtle text-success"><i class="bi bi-cpu"></i></div>
                    <h5 class="fw-bold mb-3">Automated Setup</h5>
                    <p class="text-secondary small mb-0">Computerized, barcoded, interfaced, and fully automated laboratory setup ensuring zero human error.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-200">
                <div class="modern-card">
                    <div class="card-icon bg-primary-subtle text-primary"><i class="bi bi-hospital"></i></div>
                    <h5 class="fw-bold mb-3">Biggest Referral Lab</h5>
                    <p class="text-secondary small mb-0">One of the best and biggest referral labs in Erode, serving multiple hospitals, nursing homes, and clinics.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-300">
                <div class="modern-card">
                    <div class="card-icon bg-warning-subtle text-warning"><i class="bi bi-lightning-charge"></i></div>
                    <h5 class="fw-bold mb-3">4-Hour Delivery</h5>
                    <p class="text-secondary small mb-0">Ability to deliver reports within 4 hours anywhere in Erode district for many investigations.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-400">
                <div class="modern-card">
                    <div class="card-icon bg-danger-subtle text-danger"><i class="bi bi-bug"></i></div>
                    <h5 class="fw-bold mb-3">Advanced Microbiology</h5>
                    <p class="text-secondary small mb-0">Fully automated microbiology department with advanced culture and sensitivity systems.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-500">
                <div class="modern-card">
                    <div class="card-icon bg-info-subtle text-info"><i class="bi bi-shield-check"></i></div>
                    <h5 class="fw-bold mb-3">Strict Quality Control</h5>
                    <p class="text-secondary small mb-0">Recognized external quality assurance programs including Bio-Rad, CMC, and AIIMS panels.</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-600">
                <div class="modern-card bg-primary text-white border-0">
                    <div class="card-icon bg-white text-primary"><i class="bi bi-people"></i></div>
                    <h5 class="fw-bold mb-3 text-white">Expert Leadership</h5>
                    <p class="text-light small mb-0 opacity-75">Guided by a strong panel of experienced doctors ensuring clear clinical focus in every test.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Advanced Diagnostic Systems -->
<section class="py-5 bg-white">
    <div class="container py-5">
        <div class="row mb-5 align-items-center">
            <div class="col-lg-6">
                <h2 class="section-title text-start">Advanced Diagnostic Systems</h2>
                <p class="lead text-secondary">Our lab uses high-end analyzers and platforms from global leaders to ensure accurate and fast reporting.</p>
            </div>
            <div class="col-lg-6 text-lg-end">
                <div class="glass-panel d-inline-block p-3 px-4 rounded-pill">
                    <p class="mb-0 fw-bold text-primary"><i class="bi bi-info-circle me-2"></i> Faster clinical decisions with interfaced workflows</p>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="d-flex gap-3 mb-4">
                    <div class="bg-main p-3 rounded-3 text-primary h-100">
                        <i class="bi bi-hdd-network fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark">VITROS 5600 & ECIQ</h5>
                        <p class="text-secondary small mb-0">Integrated chemistry and immunoassay systems using advanced microslide, microtip, and enhanced chemiluminescence technology for improved turnaround and precision.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-flex gap-3 mb-4">
                    <div class="bg-main p-3 rounded-3 text-danger h-100">
                        <i class="bi bi-droplet fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark">Sysmex XN-350</h5>
                        <p class="text-secondary small mb-0">Fully automated 6-part differential hematology analyser and FDA-approved body fluid analyser for precise blood counts.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-flex gap-3 mb-4">
                    <div class="bg-main p-3 rounded-3 text-success h-100">
                        <i class="bi bi-virus fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark">Bio-Rad CFX96</h5>
                        <p class="text-secondary small mb-0">Advanced PCR platform for precise and reliable molecular test detection.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-flex gap-3 mb-4">
                    <div class="bg-main p-3 rounded-3 text-info h-100">
                        <i class="bi bi-robot fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-dark">Abbott Architect CI 4100 & Beckman Access 2</h5>
                        <p class="text-secondary small mb-0">Modular immunochemistry analysers with robotic sample handling and high capacity testing.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                <div class="glass-panel p-4 border-start border-4 border-warning bg-warning-subtle">
                    <div class="d-flex gap-3">
                        <i class="bi bi-stopwatch text-warning fs-3"></i>
                        <div>
                            <h5 class="fw-bold text-dark">Fast Microbiology Setup</h5>
                            <p class="text-secondary small mb-0">Using BD BACTEC Fx40 and VITEK Compact 2 for automated blood culture and bacterial identification, delivering positive culture reports in as little as 4 hours and sensitivity in 6 hours.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
