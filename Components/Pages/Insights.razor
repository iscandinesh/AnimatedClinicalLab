@page "/insights"
@using AlphaRazor.Services
@inject BlogDbService DbService
@inject IJSRuntime JS

<PageTitle>Health Insights & Blog - Alpha Diagnostics Centre</PageTitle>

<HeadContent>
    <meta name="description" content="Explore health insights, medical guides, and diagnostic wellness articles written by diagnostic specialists at Alpha Diagnostics Centre." />
    <meta name="keywords" content="health insights, diagnostics blog, medical lab blog, medical testing guides, Tamil Nadu wellness" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.alphadiagnosticscentre.com/insights" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Health Insights & Blog - Alpha Diagnostics Centre" />
    <meta property="og:description" content="Explore health insights, medical guides, and diagnostic wellness articles written by diagnostic specialists at Alpha Diagnostics Centre." />
    <meta property="og:url" content="https://www.alphadiagnosticscentre.com/insights" />
</HeadContent>

<!-- Hero Banner -->
<section class="page-header insights-hero py-5 text-center position-relative" style="padding-top: 180px !important; padding-bottom: 120px !important; overflow: visible; min-height: 600px; display: flex; align-items: center;">
    <!-- Aesthetic Background Layers -->
    <div class="mesh-bg"></div>
    <div class="hero-grid-bg"></div>

    <!-- Ambient Glow Orbs -->
    <div class="glow-orb" style="top: 15%; left: 15%; opacity: 0.4;"></div>
    <div class="glow-orb" style="bottom: 15%; right: 15%; background: var(--primary-purple); opacity: 0.4;"></div>

    <div class="container position-relative z-2 reveal-up">
        <div class="glass-card-premium p-5 mx-auto" style="max-width: 900px;">
            <div class="badge-pill-premium mb-4 d-inline-block">
                <i class="bi bi-journal-richtext me-2"></i> Health Knowledge Hub
            </div>
            <h1 class="hero-title mb-4">
                Insights &amp; <span class="text-primary">Health Tips</span>
            </h1>
            <p class="lead mb-0" style="max-width: 700px; margin: 0 auto; color: var(--text-secondary);">
                Expert-backed articles, health tips, and diagnostic guidance to help you stay informed and take control of your wellness journey.
            </p>
        </div>
    </div>
</section>

<!-- Featured Post -->
@if (_featuredBlog != null)
{
    <section class="py-5" style="background: rgba(255,255,255,0.01);">
        <div class="container py-4">
            <div class="text-center mb-5 reveal-up">
                <span class="badge-pill-premium mb-3 d-inline-block">
                    <i class="bi bi-star-fill me-2" style="color: #f59e0b;"></i> Featured Article
                </span>
                <h2 class="section-title fw-800 mb-3">Today's Top Read</h2>
            </div>
            
            <a href="blog-details/@_featuredBlog.Id" class="text-decoration-none text-reset">
                <div class="glass-card-premium p-0 overflow-hidden reveal-up" style="border-radius: 24px; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;" onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 30px 60px rgba(0,0,0,0.25)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
                    <div class="row g-0">
                        <div class="col-lg-6" style="background: linear-gradient(135deg, @(_featuredBlog.GradientStart ?? "#1e3a5f") 0%, @(_featuredBlog.GradientEnd ?? "#0f2240") 100%); min-height: 380px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(_featuredBlog.ImagePath))
                            {
                                <img src="@_featuredBlog.ImagePath" alt="@_featuredBlog.Title" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div style="position: absolute; inset: 0; background: radial-gradient(circle at 30% 50%, rgba(96,165,250,0.2) 0%, transparent 60%);"></div>
                                <div style="text-align: center; z-index: 1; padding: 2rem;">
                                    <i class="@(_featuredBlog.IconClass ?? "bi bi-heart-pulse")" style="font-size: 5rem; color: @(_featuredBlog.IconColor ?? "#60a5fa"); opacity: 0.9;"></i>
                                    <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 1rem; letter-spacing: 2px; text-transform: uppercase;">@_featuredBlog.CategoryBadge</div>
                                </div>
                            }
                        </div>
                        <div class="col-lg-6 p-5 d-flex flex-column justify-content-center">
                            <div class="d-flex gap-2 mb-3 flex-wrap">
                                @if (!string.IsNullOrEmpty(_featuredBlog.Tags))
                                {
                                    @foreach (var tag in _featuredBlog.Tags.Split(','))
                                    {
                                        <span class="insight-tag">@tag.Trim()</span>
                                    }
                                }
                            </div>
                            <h2 class="fw-800 mb-3" style="font-size: clamp(1.4rem, 2.5vw, 1.9rem); line-height: 1.3;">@_featuredBlog.Title</h2>
                            <p class="text-secondary mb-4" style="line-height: 1.8;">
                                @(string.IsNullOrEmpty(_featuredBlog.SubTitle) ? GetExcerpt(_featuredBlog.Title, 150) : _featuredBlog.SubTitle)
                            </p>
                            <div class="d-flex align-items-center gap-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: white; font-weight: 700;">@_featuredBlog.AuthorAvatar</div>
                                    <div>
                                        <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">@_featuredBlog.AuthorName</div>
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">@_featuredBlog.AuthorTitle</div>
                                    </div>
                                </div>
                                <div style="color: var(--text-muted); font-size: 0.8rem;"><i class="bi bi-calendar3 me-1"></i> @_featuredBlog.Date</div>
                                <div style="color: var(--text-muted); font-size: 0.8rem;"><i class="bi bi-clock me-1"></i> @_featuredBlog.ReadTime</div>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </section>
}

<!-- Blog Category Filter -->
<section class="py-2">
    <div class="container">
        <div class="d-flex justify-content-center gap-2 flex-wrap mb-2 reveal-up">
            <button class="btn-helium btn-helium-primary px-4 insight-filter-btn @(SelectedCategory == "all" ? "active" : "")" @onclick='() => SetCategory("all")'>All Topics</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn @(SelectedCategory == "diabetes" ? "active" : "")" @onclick='() => SetCategory("diabetes")'>Diabetes</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn @(SelectedCategory == "heart" ? "active" : "")" @onclick='() => SetCategory("heart")'>Heart Health</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn @(SelectedCategory == "thyroid" ? "active" : "")" @onclick='() => SetCategory("thyroid")'>Thyroid</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn @(SelectedCategory == "women" ? "active" : "")" @onclick='() => SetCategory("women")'>Women's Health</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn @(SelectedCategory == "nutrition" ? "active" : "")" @onclick='() => SetCategory("nutrition")'>Nutrition</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn @(SelectedCategory == "preventive" ? "active" : "")" @onclick='() => SetCategory("preventive")'>Preventive Care</button>
        </div>
    </div>
</section>

<!-- Blog Grid -->
<section class="py-5" style="background: rgba(255,255,255,0.01);">
    <div class="container py-4">
        <div class="row g-4" id="blog-grid">
            @foreach (var blog in FilteredBlogs)
            {
                <div class="col-md-6 col-lg-4 reveal-up insight-card-wrapper" data-category="@blog.Category">
                    <div class="insight-blog-card">
                        <div class="insight-card-img" style="background: linear-gradient(135deg, @(blog.GradientStart ?? "#1a1a3a") 0%, @(blog.GradientEnd ?? "#0f0f2a") 100%);">
                            @if (!string.IsNullOrEmpty(blog.ImagePath))
                            {
                                <img src="@blog.ImagePath" alt="@blog.Title" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="@(blog.IconClass ?? "bi bi-file-earmark-text")" style="font-size: 3rem; color: @(blog.IconColor ?? "#a78bfa"); z-index: 1;"></i>
                            }
                            <div class="insight-card-category-badge" style="z-index: 2;">@blog.CategoryBadge</div>
                        </div>
                        <div class="insight-card-body">
                            <div class="d-flex gap-2 mb-2">
                                @if (!string.IsNullOrEmpty(blog.Tags))
                                {
                                    @foreach (var tag in blog.Tags.Split(','))
                                    {
                                        <span class="insight-tag">@tag.Trim()</span>
                                    }
                                }
                            </div>
                            <h3 class="insight-card-title">@blog.Title</h3>
                            <p class="insight-card-desc">@(string.IsNullOrEmpty(blog.SubTitle) ? GetExcerpt(blog.Title, 100) : blog.SubTitle)</p>
                            <div class="insight-card-footer">
                                <div class="insight-author">
                                    <div class="insight-author-avatar" style="background: linear-gradient(135deg, #10b981, #059669);">@blog.AuthorAvatar</div>
                                    <div>
                                        <div class="insight-author-name">@blog.AuthorName</div>
                                        <div class="insight-author-date">@blog.Date · @blog.ReadTime</div>
                                    </div>
                                </div>
                                <a href="blog-details/@blog.Id" class="insight-read-btn">Read <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!FilteredBlogs.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-journal-x" style="font-size: 4rem; color: var(--text-muted);"></i>
                    <h3 class="mt-3">No articles found</h3>
                    <p class="text-secondary">Try selecting a different health topic.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Newsletter / CTA Section -->
<section class="py-5">
    <div class="container py-3">
        <div class="glass-card-premium p-5 text-center reveal-up" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(139, 92, 246, 0.12)); border: 1px solid rgba(96, 165, 250, 0.25);">
            <i class="bi bi-envelope-paper" style="font-size: 3rem; color: var(--primary-blue); margin-bottom: 1rem; display: block;"></i>
            <h2 class="fw-800 mb-3" style="font-size: clamp(1.6rem, 3vw, 2.2rem);">Stay Informed, Stay Healthy</h2>
            <p class="text-secondary mb-4" style="max-width: 550px; margin: 0 auto 1.5rem;">Get our latest health articles and wellness tips delivered straight to your inbox. No spam — just useful, expert-backed content.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="contact" class="btn-helium btn-helium-primary px-5 py-3">
                    <i class="bi bi-calendar-check me-2"></i> Book a Health Test
                </a>
                <a href="services#health-packages" class="btn-helium btn-helium-secondary px-5 py-3">
                    <i class="bi bi-box2-heart me-2"></i> Explore Packages
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    private List<BlogPost> _blogs = new();
    private BlogPost? _featuredBlog = null;
    private bool _blogsLoaded = false;
    private bool _animationsInitialized = false;
    public string SelectedCategory { get; set; } = "all";

    private IEnumerable<BlogPost> FilteredBlogs =>
        SelectedCategory == "all"
            ? _blogs.Where(b => b.Id != _featuredBlog?.Id)
            : _blogs.Where(b => b.Category == SelectedCategory && b.Id != _featuredBlog?.Id);

    protected override async Task OnInitializedAsync()
    {
        _blogs = await DbService.GetBlogsAsync();
        _featuredBlog = _blogs.FirstOrDefault(b => b.IsFeatured) ?? _blogs.FirstOrDefault();
        _blogsLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_blogsLoaded && !_animationsInitialized)
        {
            _animationsInitialized = true;
            await JS.InvokeVoidAsync("initHeliumAnimations");
        }
    }

    private void SetCategory(string category)
    {
        SelectedCategory = category;
        StateHasChanged();
    }

    private string GetExcerpt(string text, int length)
    {
        if (string.IsNullOrEmpty(text)) return "";
        if (text.Length <= length) return text;
        return text.Substring(0, length) + "...";
    }
}
