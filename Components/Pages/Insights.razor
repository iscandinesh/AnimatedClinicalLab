<!-- Newsletter / CTA Section -->
<section class="py-5">
    <div class="container py-3">
        <div class="glass-card-premium p-5 text-center reveal-up" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(139, 92, 246, 0.12)); border: 1px solid rgba(96, 165, 250, 0.25);">
            <i class="bi bi-envelope-paper" style="font-size: 3rem; color: var(--primary-blue); margin-bottom: 1rem; display: block;"></i>
