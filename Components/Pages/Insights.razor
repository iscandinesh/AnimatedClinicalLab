@page "/insights"
@inject IJSRuntime JS

<PageTitle>Insights - Alpha Diagnostics Centre</PageTitle>

<!-- Hero Banner -->
<section class="page-header insights-hero py-5 text-center position-relative" style="padding-top: 180px !important; padding-bottom: 120px !important; overflow: hidden; min-height: 600px; display: flex; align-items: center;">
    <!-- Aesthetic Background Layers -->
    <div class="mesh-bg"></div>
    <div class="hero-grid-bg"></div>

    <!-- Ambient Glow Orbs -->
    <div class="glow-orb" style="top: 15%; left: 15%; opacity: 0.4;"></div>
    <div class="glow-orb" style="bottom: 15%; right: 15%; background: var(--primary-purple); opacity: 0.4;"></div>

    <div class="container position-relative z-2 reveal-up">
        <div class="glass-card-premium p-5 mx-auto" style="max-width: 900px;">
            <div class="badge-pill-premium mb-4 d-inline-block">
                <i class="bi bi-journal-richtext me-2"></i> Health Knowledge Hub
            </div>
            <h1 class="hero-title mb-4">
                Insights &amp; <span class="text-primary">Health Tips</span>
            </h1>
            <p class="lead mb-0" style="max-width: 700px; margin: 0 auto; color: var(--text-secondary);">
                Expert-backed articles, health tips, and diagnostic guidance to help you stay informed and take control of your wellness journey.
            </p>
        </div>
    </div>
</section>

<!-- Featured Post -->
<section class="py-5" style="background: rgba(255,255,255,0.01);">
    <div class="container py-4">
        <div class="text-center mb-5 reveal-up">
            <span class="badge-pill-premium mb-3 d-inline-block"><i class="bi bi-star-fill me-2" style="color: #f59e0b;"></i> Featured Article</span>
            <h2 class="section-title fw-800 mb-3">This Month's Top Read</h2>
        </div>
        <div class="glass-card-premium p-0 overflow-hidden reveal-up" style="border-radius: 24px; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;" onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 30px 60px rgba(0,0,0,0.25)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
            <div class="row g-0">
                <div class="col-lg-6" style="background: linear-gradient(135deg, #1e3a5f 0%, #0f2240 100%); min-height: 380px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
                    <div style="position: absolute; inset: 0; background: radial-gradient(circle at 30% 50%, rgba(96,165,250,0.2) 0%, transparent 60%);"></div>
                    <div style="text-align: center; z-index: 1; padding: 2rem;">
                        <i class="bi bi-heart-pulse" style="font-size: 5rem; color: #60a5fa; opacity: 0.9;"></i>
                        <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 1rem; letter-spacing: 2px; text-transform: uppercase;">Cardiology</div>
                    </div>
                </div>
                <div class="col-lg-6 p-5 d-flex flex-column justify-content-center">
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        <span class="insight-tag">Heart Health</span>
                        <span class="insight-tag">Prevention</span>
                    </div>
                    <h2 class="fw-800 mb-3" style="font-size: clamp(1.4rem, 2.5vw, 1.9rem); line-height: 1.3;">Understanding Your Cardiac Risk: Why Early Testing Matters</h2>
                    <p class="text-secondary mb-4" style="line-height: 1.8;">Heart disease remains one of the leading causes of premature death, yet most risk factors are identifiable years in advance through simple blood tests. Learn what markers you should be testing and how often.</p>
                    <div class="d-flex align-items-center gap-4">
                        <div class="d-flex align-items-center gap-2">
                            <div style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: white; font-weight: 700;">DR</div>
                            <div>
                                <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Dr. Rajan Kumar</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">Cardiologist</div>
                            </div>
                        </div>
                        <div style="color: var(--text-muted); font-size: 0.8rem;"><i class="bi bi-calendar3 me-1"></i> June 1, 2026</div>
                        <div style="color: var(--text-muted); font-size: 0.8rem;"><i class="bi bi-clock me-1"></i> 7 min read</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Blog Category Filter -->
<section class="py-2">
    <div class="container">
        <div class="d-flex justify-content-center gap-2 flex-wrap mb-2 reveal-up">
            <button class="btn-helium btn-helium-primary px-4 insight-filter-btn active" onclick="filterInsights(this, 'all')">All Topics</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn" onclick="filterInsights(this, 'diabetes')">Diabetes</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn" onclick="filterInsights(this, 'heart')">Heart Health</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn" onclick="filterInsights(this, 'thyroid')">Thyroid</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn" onclick="filterInsights(this, 'women')">Women's Health</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn" onclick="filterInsights(this, 'nutrition')">Nutrition</button>
            <button class="btn-helium btn-helium-secondary px-4 insight-filter-btn" onclick="filterInsights(this, 'preventive')">Preventive Care</button>
        </div>
    </div>
</section>

<!-- Blog Grid -->
<section class="py-5" style="background: rgba(255,255,255,0.01);">
    <div class="container py-4">
        <div class="row g-4" id="blog-grid">

            <!-- Blog Card 1 -->
            <div class="col-md-6 col-lg-4 reveal-up insight-card-wrapper" data-category="diabetes">
                <div class="insight-blog-card">
                    <div class="insight-card-img" style="background: linear-gradient(135deg, #1a3a2a 0%, #0f2a1a 100%);">
                        <i class="bi bi-droplet-half" style="font-size: 3rem; color: #34d399;"></i>
                        <div class="insight-card-category-badge">Diabetes</div>
                    </div>
                    <div class="insight-card-body">
                        <div class="d-flex gap-2 mb-2">
                            <span class="insight-tag">Blood Sugar</span>
                            <span class="insight-tag">HbA1c</span>
                        </div>
                        <h3 class="insight-card-title">What Your HbA1c Score Really Means for Your Long-Term Health</h3>
                        <p class="insight-card-desc">HbA1c isn't just a number — it's a three-month window into your blood sugar patterns. Here's how to interpret it and what action to take.</p>
                        <div class="insight-card-footer">
                            <div class="insight-author">
                                <div class="insight-author-avatar" style="background: linear-gradient(135deg, #10b981, #059669);">SP</div>
                                <div>
                                    <div class="insight-author-name">Dr. Sunita Priya</div>
                                    <div class="insight-author-date">May 25, 2026 · 5 min read</div>
                                </div>
                            </div>
                            <a href="insights" class="insight-read-btn">Read <i class="bi bi-arrow-right"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Blog Card 2 -->
            <div class="col-md-6 col-lg-4 reveal-up insight-card-wrapper" data-category="thyroid">
