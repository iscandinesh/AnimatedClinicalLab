                            <div class="insight-author">
                                <div class="insight-author-avatar" style="background: linear-gradient(135deg, #ec4899, #be185d);">RV</div>
                                <div>
                                    <div class="insight-author-name">Dr. Revathi Velu</div>
                                    <div class="insight-author-date">May 10, 2026 · 8 min read</div>
                                </div>
                            </div>
                            <a href="insights" class="insight-read-btn">Read <i class="bi bi-arrow-right"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Blog Card 4 -->
            <div class="col-md-6 col-lg-4 reveal-up insight-card-wrapper" data-category="nutrition">
                <div class="insight-blog-card">
                    <div class="insight-card-img" style="background: linear-gradient(135deg, #1a2a1a 0%, #0f1f0f 100%);">
