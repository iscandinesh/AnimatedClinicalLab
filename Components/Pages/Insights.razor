                    <div class="insight-card-img" style="background: linear-gradient(135deg, #2a1a3a 0%, #1a0f2a 100%);">
                        <i class="bi bi-activity" style="font-size: 3rem; color: #a78bfa;"></i>
                        <div class="insight-card-category-badge">Thyroid</div>
                    </div>
                    <div class="insight-card-body">
                        <div class="d-flex gap-2 mb-2">
                            <span class="insight-tag">TSH</span>
