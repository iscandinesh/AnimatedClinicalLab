                        <div class="insight-card-footer">
                            <div class="insight-author">
                                <div class="insight-author-avatar" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9);">AM</div>
                                <div>
                                    <div class="insight-author-name">Dr. Anitha Meena</div>
                                    <div class="insight-author-date">May 18, 2026 · 6 min read</div>
                                </div>
                            </div>
                            <a href="insights" class="insight-read-btn">Read <i class="bi bi-arrow-right"></i></a>
                        </div>
