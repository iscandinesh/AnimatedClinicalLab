    private void StartMachinesAutoplay()
    {
        _progressBarKey++;
        _machinesCts?.Cancel();
        _machinesCts = new System.Threading.CancellationTokenSource();
        var token = _machinesCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested && !disposed)
            {
                await Task.Delay(6000, token);
                if (token.IsCancellationRequested || disposed) break;
                
                await InvokeAsync(() =>
                {
                    activeMachineIndex = (activeMachineIndex + 1) % machines.Count;
                    _progressBarKey++;
                    StateHasChanged();
                });
            }
        }, token);
    }

    private void PrevMachine()
    {
        activeMachineIndex = (activeMachineIndex - 1 + machines.Count) % machines.Count;
        StartMachinesAutoplay();
    }

    private void NextMachine()
    {
        activeMachineIndex = (activeMachineIndex + 1) % machines.Count;
        StartMachinesAutoplay();
    }

    private void SetMachine(int index)
    {
        activeMachineIndex = index;
        StartMachinesAutoplay();
    }

    private void OnMachinesMouseEnter()
    {
        _machinesCts?.Cancel();
    }

    private void OnMachinesMouseLeave()
    {
        StartMachinesAutoplay();
    }

