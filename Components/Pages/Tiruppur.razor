    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initHeliumAnimations");
            _ = StartAutoPlay();
            StartMachinesAutoplay();
        }
    }

    private async Task StartAutoPlay()
    {
        while (!disposed)
        {
            await Task.Delay(5000);
            if (disposed) break;
            currentSlideIndex = (currentSlideIndex + 1) % eventSlides.Count;
            StateHasChanged();
        }
    }

    private void NextSlide()
    {
        currentSlideIndex = (currentSlideIndex + 1) % eventSlides.Count;
    }

    private void PrevSlide()
    {
        currentSlideIndex = (currentSlideIndex - 1 + eventSlides.Count) % eventSlides.Count;
    }

    private void SetSlide(int index)
    {
        currentSlideIndex = index;
    }

    public void Dispose()
    {
        disposed = true;
        _machinesCts?.Cancel();
        _machinesCts?.Dispose();
    }
