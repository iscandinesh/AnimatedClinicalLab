                        <button class="carousel-control-btn prev" @onclick="PrevSlide" style="position: absolute; top: 50%; left: 15px; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.2); background: rgba(0,0,0,0.5); color: #fff; z-index: 10; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;">
