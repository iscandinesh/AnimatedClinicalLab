            <p class="lead mb-5 text-white text-center mx-auto" style="max-width: 750px; font-size: 1.35rem; font-weight: 500; text-shadow: 0 4px 15px rgba(0,0,0,0.95), 0 2px 6px rgba(0,0,0,0.9);">
