                            <h4 class="fw-bold mb-3" style="font-size: 1.5rem; letter-spacing: -0.5px;">@eventSlides[currentSlideIndex].Title</h4>
                            <p class="text-secondary mb-0" style="line-height: 1.6; font-size: 0.95rem;">@eventSlides[currentSlideIndex].Description</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



