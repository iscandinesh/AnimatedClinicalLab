                        <div class="h-100 w-100 position-relative overflow-hidden">
                            @for (int i = 0; i < eventSlides.Count; i++)
                            {
                                var index = i;
                                <div class="slide-item" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: @(index == currentSlideIndex ? "1" : "0"); visibility: @(index == currentSlideIndex ? "visible" : "hidden"); transition: opacity 0.8s ease, visibility 0.8s ease;">
