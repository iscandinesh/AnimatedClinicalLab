                                    <!-- Ambient Dark Gradient Overlay -->
                                    <div class="position-absolute bottom-0 start-0 w-100 h-50" style="background: linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0));"></div>
                                </div>
                            }
                        </div>
                        
