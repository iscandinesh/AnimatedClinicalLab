                        <div>
                            <h5 class="fw-bold mb-0">Coimbatore Branch</h5>
                            <small class="text-primary opacity-75">Branch Lab</small>
                        </div>
                    </div>
                    <p class="text-secondary mb-4 small">Krishnasamy Nagar, Ramanathapuram, Coimbatore – 641 045.</p>
                    <a href="tel:+918110866366" class="btn-helium btn-helium-secondary w-100 text-center py-2">
                        <i class="bi bi-telephone me-2"></i> 81108 66366
                    </a>
                </div>
            </div>

            <!-- Anthiyur -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.4s;">
