@page "/locations"
@inject IJSRuntime JS

<PageTitle>Our Locations - Alpha Diagnostics Centre</PageTitle>

<section class="page-header py-5 text-center position-relative" style="padding-top: 180px !important; padding-bottom: 120px !important; overflow: hidden; min-height: 600px; display: flex; align-items: center;">
    <!-- Aesthetic Background Layers -->
    <div class="mesh-bg"></div>
    <div class="hero-grid-bg"></div>

    <!-- Ambient Glow Orbs -->
    <div class="glow-orb" style="top: 15%; left: 15%; opacity: 0.4;"></div>
    <div class="glow-orb" style="bottom: 15%; right: 15%; background: var(--primary-purple); opacity: 0.4;"></div>
    
    <div class="container position-relative z-2 reveal-up">
        <div class="glass-card-premium p-5 mx-auto" style="max-width: 900px;">
            <div class="badge-pill-premium mb-4 d-inline-block">
                <i class="bi bi-geo-alt me-2"></i> Serving Erode & Surrounding Districts
            </div>
            <h1 class="hero-title mb-4">
                Our <span class="text-primary">Locations</span>
            </h1>
            <p class="lead mb-0" style="max-width: 700px; margin: 0 auto; color: var(--text-secondary);">
                Accessible across the district so you never have to travel far for quality diagnostics.
            </p>
        </div>
    </div>
</section>

 <!-- Horizontal Marquee Banner -->
 <div class="marquee-banner my-4">
    <div class="marquee-wrapper">
        <div class="marquee-content-running">
            <i class="bi bi-megaphone-fill me-2"></i> Now Expanding to Tiruppur & More Locations! &nbsp;&nbsp;&nbsp;&nbsp; 
            <i class="bi bi-megaphone-fill me-2"></i> Now Expanding to Tiruppur & More Locations! &nbsp;&nbsp;&nbsp;&nbsp;
            <i class="bi bi-megaphone-fill me-2"></i> Now Expanding to Tiruppur & More Locations! &nbsp;&nbsp;&nbsp;&nbsp;
            <i class="bi bi-megaphone-fill me-2"></i> Now Expanding to Tiruppur & More Locations! &nbsp;&nbsp;&nbsp;&nbsp;
        </div>
    </div>
 </div>

<!-- Main Lab - Vertical Split Layout -->
<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <h2 class="section-title">Main Laboratory</h2>
            <p class="text-secondary mx-auto" style="max-width: 600px;">Our central hub for processing samples from all branches and collection centres.</p>
        </div>

        <div class="location-split-container reveal-up">
            <div class="row g-0">
                <!-- Map View Side -->
                <div class="col-lg-7 d-none d-lg-block">
                    <div class="map-container-split h-100">
                        <iframe 
                            class="google-map-iframe"
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3912.0215!2d77.7166!3d11.3362!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ba96f3e4a00df11%3A0x6b777c420833834!2sAlpha%20Diagnostics%20Centre%20(Main%20Lab%20Branch%20-%20Erode)!5e0!3m2!1sen!2sin!4v1715070000000!5m2!1sen!2sin" 
                            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                    </div>
                </div>

                <!-- Details Side -->
                <div class="col-lg-5">
                    <div class="location-details-card">
                        <!-- Card Header -->
                        <div class="location-details-header">
                            <div class="d-flex align-items-center gap-4">
                                <div class="bg-white bg-opacity-20 p-4 rounded-4 shadow-sm">
                                    <i class="bi bi-hospital fs-1"></i>
                                </div>
                                <div>
                                    <h3 class="fw-bold mb-2" style="letter-spacing: -1px;">Alpha Diagnostics Centre</h3>
                                    <span class="badge bg-white bg-opacity-20 border border-white border-opacity-30 px-3 py-2 rounded-pill small fw-bold">Main Laboratory</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Card Body -->
                        <div class="location-details-body">
                            <div class="row g-4">
                                <div class="col-12">
                                    <div class="location-grid-item">
                                        <div class="location-grid-icon"><i class="bi bi-geo-alt-fill"></i></div>
                                        <div>
                                            <div class="fw-bold mb-1">Address</div>
                                            <div class="text-secondary small">31, Patel Street, Erode – 638 001.</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="location-grid-item">
                                        <div class="location-grid-icon"><i class="bi bi-telephone-fill"></i></div>
                                        <div>
                                            <div class="fw-bold mb-1">Phone</div>
                                            <div class="text-secondary small">81108 99999 • 70944 90917</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="location-grid-item">
                                        <div class="location-grid-icon"><i class="bi bi-envelope-fill"></i></div>
                                        <div>
                                            <div class="fw-bold mb-1">Email</div>
                                            <div class="text-secondary small">info@alphalab.co.in</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="location-grid-item mb-0">
                                        <div class="location-grid-icon"><i class="bi bi-globe"></i></div>
                                        <div>
                                            <div class="fw-bold mb-1">Website</div>
                                            <div class="text-secondary small">www.alphalab.com</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Branch Network -->
