        </div>
    </div>
</section>

<!-- Authorised Collection Centres -->
<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <h2 class="section-title">Authorised Collection Centres</h2>
            <p class="text-secondary mx-auto" style="max-width: 600px;">Partner hospitals and clinics where you can submit samples for Alpha processing.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3 reveal-up">
                <div class="glass-card p-4 text-center h-100 hover-glow">
                    <i class="bi bi-hospital text-primary fs-2 mb-3 d-block"></i>
