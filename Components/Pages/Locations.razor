                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle"><i class="bi bi-geo-alt fs-4"></i></div>
                        <div>
                            <h5 class="fw-bold mb-0">Anthiyur Branch</h5>
                            <small class="text-primary opacity-75">Branch Lab</small>
                        </div>
                    </div>
                    <p class="text-secondary mb-4 small">Thavettapalayam, near Sivasakthi Hospital, Anthiyur – 638 501.</p>
                    <a href="tel:+917094490916" class="btn-helium btn-helium-secondary w-100 text-center py-2">
