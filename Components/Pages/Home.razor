    private void StartAutoplay()
    {
        _cts?.Cancel();
        _cts = new System.Threading.CancellationTokenSource();
        var token = _cts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(10000, token);
                if (token.IsCancellationRequested) break;
                
                await InvokeAsync(() =>
                {
                    NextSlide();
                    StateHasChanged();
                });
            }
        }, token);
    }

    private void NextSlide()
    {
        currentSlideIndex = (currentSlideIndex + 1) % slides.Count;
    }

    private void PrevSlide()
    {
        currentSlideIndex = (currentSlideIndex - 1 + slides.Count) % slides.Count;
    }

    private void SetSlide(int index)
    {
        currentSlideIndex = index;
        StartAutoplay();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initHeliumAnimations");
            await JS.InvokeVoidAsync("testimonialScroller.init");
            StartAutoplay();
            StartMachinesAutoplay();
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _machinesCts?.Cancel();
        _machinesCts?.Dispose();
    }
