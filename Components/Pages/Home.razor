</HeadContent>



<!-- 1. HERO SECTION (EXACT ALIGNMENT WITH REACT REFERENCE) -->
<section class="position-relative d-flex align-items-center overflow-visible homepage-hero" style="min-height: 65vh;">
    <!-- Reference Animations Background -->
    <div class="dna-bg" aria-hidden="true">
        <div class="floating-blob b1"></div>
        <div class="floating-blob b2"></div>
        <div class="floating-blob b3"></div>
        <div class="hero-grid-bg"></div>
    </div>



    <div class="container-fluid position-relative mx-auto px-4" style="max-width: 1280px; z-index: 10; overflow: visible;">
        <!-- Hero Carousel Container -->
        <div class="hero-carousel-container">
            @for (int i = 0; i < slides.Count; i++)
            {
                var slide = slides[i];
                var index = i;
                <div class="hero-slide @(currentSlideIndex == index ? "active" : "")">
                    <!-- Full-bleed right image or trust logos layout -->
                    <div class="hero-slide-bg-image reveal-image" aria-hidden="true">
                        @if (index == 0)
                        {
                            <div class="hero-trust-logos-layout">
                                <div class="trust-logo-card">
                                    <img src="images/anniversary-logo-trans.png?v=3" alt="10 Years Excellence Wreath" class="anniversary-logo-img" width="160" height="160" />
                                </div>
                                <div class="trust-logo-card">
                                    <img src="images/nabl-accredited-logo-trans.png" alt="NABL Accredited Lab" class="nabl-logo-img" width="160" height="160" />
                                </div>
                                <div class="trust-logo-card">
                                    <img src="images/cmc-vellore-logo-trans.png" alt="CMC Vellore EQAS Approved" class="cmc-logo-img" width="160" height="160" />
                                </div>
                            </div>
                        }
                        else
                        {
                            <img src="@slide.ImagePath" alt="@slide.Title" class="hero-slide-img" width="1200" height="1200" />
                        }
                    </div>

                    <!-- Left Column: Content -->
                    <div class="hero-slide-content">
                        <div class="reveal-badge">
                            @if (slide.Tagline.Contains("NABL"))
                            {
                                <span class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill badge-nabl-premium fw-bold tracking-wide mb-4" style="font-size: 0.72rem;">
                                    <i class="bi bi-patch-check-fill text-emerald-icon"></i> @slide.Tagline
                                </span>
                            }
                            else if (slide.Tagline.Contains("Offer"))
                            {
                                <span class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill badge-offer-premium fw-bold tracking-wide mb-4" style="font-size: 0.72rem;">
                                    <i class="bi bi-gift-fill text-gold-icon"></i> @slide.Tagline
                                </span>
                            }
                            else if (slide.Tagline.Contains("Convenient"))
                            {
                                <span class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill badge-convenient-premium fw-bold tracking-wide mb-4" style="font-size: 0.72rem;">
                                    <i class="bi bi-shield-fill-check text-cyan-icon"></i> @slide.Tagline
                                </span>
                            }
                            else if (slide.Tagline.Contains("Screening"))
                            {
                                <span class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill badge-screening-premium fw-bold tracking-wide mb-4" style="font-size: 0.72rem;">
                                    <i class="bi bi-heart-pulse-fill text-purple-icon"></i> @slide.Tagline
                                </span>
                            }
                            else
                            {
                                <span class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill theme-badge-hero fw-bold tracking-wide mb-4" style="font-size: 0.72rem;">
                                    <i class="bi bi-stars"></i> @slide.Tagline
                                </span>
                            }
                        </div>
                        <h1 class="hero-title mt-4 reveal-title">
                            @slide.Title
                        </h1>
                        <p class="hero-body-custom reveal-body">
                            @slide.Body
                        </p>

                        <div class="mt-8 d-flex flex-wrap gap-4 reveal-buttons">
                            @if (!string.IsNullOrEmpty(slide.Cta1Text))
                            {
                                <a href="@slide.Cta1Link" class="btn-helium btn-helium-primary btn-carousel-cta rounded-pill shadow-lg shadow-blue-200 d-flex align-items-center gap-2" style="background: #2563eb; color: #fff;">
                                    @slide.Cta1Text
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(slide.Cta2Text))
                            {
                                <a href="@slide.Cta2Link" class="btn btn-hero-outline btn-carousel-cta rounded-pill d-flex align-items-center justify-content-center fw-700">
                                    @slide.Cta2Text
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>

    <!-- Navigation Arrows -->
    <button class="carousel-nav-btn prev" @onclick="PrevSlide" aria-label="Previous slide">
        <i class="bi bi-chevron-left fs-5"></i>
    </button>
    <button class="carousel-nav-btn next" @onclick="NextSlide" aria-label="Next slide">
        <i class="bi bi-chevron-right fs-5"></i>
    </button>
</section>

