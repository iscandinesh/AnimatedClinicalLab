          {
            "@@type": "Offer",
            "itemOffered": {
              "@@type": "MedicalTest",
              "name": "Basic Health Checkup"
            }
          },
          {
            "@@type": "Offer",
            "itemOffered": {
              "@@type": "MedicalTest",
              "name": "Master Health Checkup"
            }
          },
          {
            "@@type": "Offer",
            "itemOffered": {
              "@@type": "MedicalTest",
              "name": "Executive Health Checkup"
            }
          },
          {
            "@@type": "Offer",
            "itemOffered": {
              "@@type": "MedicalTest",
              "name": "Well Women Health Checkup"
            }
          },
          {
            "@@type": "Offer",
            "itemOffered": {
              "@@type": "MedicalTest",
              "name": "Cardiac Package"
            }
          },
          {
            "@@type": "Offer",
            "itemOffered": {
              "@@type": "MedicalTest",
              "name": "Diabetic Package"
            }
          }
        ]
