@page "/"

<PageTitle>Home - Alpha Diagnostics Centre</PageTitle>

<!-- ═══════════════════════════════════════════
     HERO SECTION — animated background + real image
     ═══════════════════════════════════════════ -->
<section class="hero-wrapper">

    <!-- Animated gradient orbs -->
    <div class="hero-orb orb-1" aria-hidden="true"></div>
    <div class="hero-orb orb-2" aria-hidden="true"></div>
    <div class="hero-orb orb-3" aria-hidden="true"></div>

    <!-- Floating animated lab particles (dots/circles) -->
    <div class="hero-particles" aria-hidden="true">
        <span class="hparticle hp1"></span>
        <span class="hparticle hp2"></span>
        <span class="hparticle hp3"></span>
        <span class="hparticle hp4"></span>
        <span class="hparticle hp5"></span>
        <span class="hparticle hp6"></span>
        <span class="hparticle hp7"></span>
        <span class="hparticle hp8"></span>
    </div>

    <div class="container position-relative" style="z-index:2;">
        <div class="row align-items-center min-vh-100 py-5">

            <!-- ── Left: Text Content ─────────────────── -->
            <div class="col-lg-6 pb-5 pb-lg-0 animate-fade-in-up">

                <!-- Badge pill -->
                <div class="hero-badge mb-4">
                    <i class="bi bi-shield-check me-2"></i>
                    Rooted in care, growing in health.
                </div>

                <!-- Elegant headline -->
                <h1 class="hero-headline mb-3">
                    Advanced Diagnostics<br />
                    <span class="hero-accent">You Can Trust.</span>
                </h1>

                <p class="hero-tagline mb-3">
                    Barcoded, automated testing with <strong>NABL-accredited</strong> quality and caring service.
                </p>

                <p class="hero-body mb-5">
                    Alpha Diagnostics Centre is a fully automated, barcoded, and interfaced diagnostic laboratory started by quality-focused doctors — delivering fast, accurate reports across Erode and nearby areas.
                </p>

                <!-- CTA Buttons -->
                <div class="d-flex flex-wrap gap-3 mb-5">
                    <a href="contact" class="btn btn-primary-custom hover-lift">
                        <i class="bi bi-calendar-check"></i> Book a Test
                    </a>
                    <a href="services" class="btn btn-secondary-custom hover-lift">
                        <i class="bi bi-clipboard-pulse"></i> View Packages
                    </a>
                </div>

                <!-- Stats strip -->
                <div class="hero-stats-strip">
                    <div class="hstat">
                        <div class="hstat-num">10+</div>
                        <div class="hstat-label">Years of Service</div>
                    </div>
                    <div class="hstat-sep"></div>
                    <div class="hstat">
                        <div class="hstat-num">4 Hrs</div>
                        <div class="hstat-label">Report Delivery</div>
                    </div>
                    <div class="hstat-sep"></div>
                    <div class="hstat">
                        <div class="hstat-num">15+</div>
                        <div class="hstat-label">Collection Centres</div>
                    </div>
                    <div class="hstat-sep"></div>
                    <div class="hstat">
                        <div class="hstat-num">500+</div>
                        <div class="hstat-label">Tests Available</div>
                    </div>
                </div>
            </div>

            <!-- ── Right: Real Clinical Lab Image ────── -->
            <div class="col-lg-6 position-relative mt-5 mt-lg-0 animate-fade-in-left delay-300">

                <div class="hero-img-frame">
                    <img src="images/hero-lab.png"
                         alt="Alpha Diagnostics Centre – Clinical Laboratory"
                         class="hero-img" />
                    <!-- Soft inner gradient overlay at bottom -->
                    <div class="hero-img-overlay"></div>
                </div>

                <!-- Floating badge: NABL -->
                <div class="hero-float-card card-nabl">
                    <div class="hfc-icon bg-success-subtle text-success">
                        <i class="bi bi-patch-check-fill"></i>
                    </div>
                    <div>
                        <div class="hfc-title">NABL Accredited</div>
                        <div class="hfc-sub">International Standards</div>
                    </div>
                </div>

                <!-- Floating badge: Speed -->
                <div class="hero-float-card card-speed">
                    <div class="hfc-icon bg-primary-subtle text-primary">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <div class="hfc-title">Fast Turnaround</div>
                        <div class="hfc-sub">Reports in 4 hours</div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

