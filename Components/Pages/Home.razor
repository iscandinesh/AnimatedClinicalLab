<section id="faq" class="py-5 position-relative overflow-hidden">
    <div class="container py-5 position-relative" style="z-index: 2;">
        <div class="row gy-5 gx-lg-5">
            <!-- Left Column: Contact info and help cards -->
            <div class="col-lg-5 reveal-up">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span style="width: 28px; height: 2px; background-color: #9ac6a5; display: inline-block;"></span>
                    <span class="text-logo-green fw-800 text-uppercase tracking-wider" style="letter-spacing: 2px; font-size: 0.85rem;">FAQ</span>
                </div>
                
                <h2 class="fw-800 mb-4 text-primary-theme" style="font-size: clamp(2.2rem, 3.5vw, 2.8rem); line-height: 1.15;">
                    Common <span style="color: #9ac6a5; font-style: italic; font-family: 'Playfair Display', Georgia, serif;">questions</span> answered
                </h2>
                
                <p class="text-secondary-theme mb-5" style="max-width: 440px; font-size: 1.05rem; line-height: 1.7;">
                    Can't find what you're looking for? Our customer support and diagnostics help team is available 24/7.
                </p>
                
                <!-- Contact Cards -->
                <div class="d-flex flex-column gap-4">
                    <!-- WhatsApp Card -->
                    <a href="https://wa.me/918110899999" target="_blank" class="faq-contact-card p-3 rounded-4 d-flex align-items-center gap-4 text-decoration-none">
                        <div class="faq-contact-icon-wrapper d-flex align-items-center justify-content-center rounded-circle" style="width: 54px; height: 54px; background: rgba(37, 211, 102, 0.1); color: #25D366; font-size: 1.5rem;">
                            <i class="bi bi-whatsapp"></i>
                        </div>
                        <div>
                            <h5 class="fw-700 text-primary-theme mb-1" style="font-size: 1.1rem; letter-spacing: -0.2px;">WhatsApp Us</h5>
                            <span class="text-secondary-theme small">+91 81108 99999</span>
                        </div>
                    </a>
                    
                    <!-- Helpline Card -->
                    <a href="tel:8110899999" class="faq-contact-card call-card p-3 rounded-4 d-flex align-items-center gap-4 text-decoration-none">
                        <div class="faq-contact-icon-wrapper d-flex align-items-center justify-content-center rounded-circle" style="width: 54px; height: 54px; background: rgba(124, 58, 237, 0.1); color: #9b95c3; font-size: 1.5rem;">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <div>
                            <h5 class="fw-700 text-primary-theme mb-1" style="font-size: 1.1rem; letter-spacing: -0.2px;">Toll-Free Helpline</h5>
                            <span class="text-secondary-theme small">81108 99999 / 70944 90917 · 24/7</span>
                        </div>
                    </a>
                </div>
            </div>
            
            <!-- Right Column: Accordion -->
            <div class="col-lg-7 reveal-up">
                <div class="faq-accordion">
                    @foreach (var faq in faqs)
                    {
                        var index = faqs.IndexOf(faq);
                        <div class="faq-item @(activeIndex == index ? "active" : "")">
                            <button class="faq-trigger" @onclick="() => ToggleFaq(index)">
                                <span>@faq.Question</span>
                                <i class="bi bi-chevron-down faq-icon"></i>
                            </button>
                            <div class="faq-content">
                                <p style="margin-bottom: 0;">@faq.Answer</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

