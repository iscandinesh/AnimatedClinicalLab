        "addressLocality": "Erode",
        "addressRegion": "Tamil Nadu",
        "postalCode": "638011",
        "addressCountry": "IN"
      },
      "geo": {
        "@@type": "GeoCoordinates",
        "latitude": 11.3410,
        "longitude": 77.7172
