@page "/editor"
@using AlphaRazor.Components
@rendermode InteractiveServer
@inject BlogDbService BlogService
@inject EmailService EmailService
@inject NavigationManager NavManager
@inject IWebHostEnvironment Env
@inject IJSRuntime JSRuntime

<PageTitle>Content Management System</PageTitle>

<div class="portal-root">
    @if (!_isLoggedIn)
    {
        <!-- GLASSMORPHISM LOGIN PAGE -->
        <div class="login-container">
            <div class="mesh-bg">
                <div class="orb orb-1"></div>
                <div class="orb orb-2"></div>
                <div class="orb orb-3"></div>
            </div>

            <div class="login-card">
                <div class="login-header">
                    <div class="logo-icon">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h2>Marketing Portal</h2>
                    <p>Enter your credentials to manage clinic insights</p>
                </div>

                <div class="login-body">
                    @if (!string.IsNullOrEmpty(_loginError))
                    {
                        <div class="error-alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>@_loginError</span>
                        </div>
                    }

                    <div class="form-group">
                        <label for="username">Username</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person-fill"></i>
                            <input id="username" type="text" placeholder="Enter username" @bind="_username" @bind:event="oninput" @onkeydown="HandleKeyDown" autocomplete="off" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <div class="input-wrapper">
                            <i class="bi bi-lock-fill"></i>
                            <input id="password" type="password" placeholder="Enter password" @bind="_password" @bind:event="oninput" @onkeydown="HandleKeyDown" />
                        </div>
                    </div>

                    <button class="btn-login" @onclick="AttemptLogin" disabled="@_isSubmitting">
                        @if (_isSubmitting)
                        {
                            <span class="spinner"></span>
                            <span>Authenticating...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                            <i class="bi bi-arrow-right-short"></i>
                        }
                    </button>
                </div>
                
                <div class="login-footer">
                    <span>Alpha Diagnostics Admin System v2.0</span>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- CMS ADMIN DASHBOARD -->
        <div class="dashboard-layout">
            <!-- SIDEBAR -->
            <aside class="sidebar">
                <div class="sidebar-header">
                    <div class="brand">
                        <i class="bi bi-journal-richtext text-primary"></i>
                        <div>
                            <h3>Insights CMS</h3>
                            <span>Alpha Diagnostics</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn-mail-tx" title="Mail Transactions" @onclick="OpenMailModal">
                            <i class="bi bi-envelope-paper"></i>
                        </button>
                        <button class="btn-logout" title="Sign Out" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </div>
                </div>

                <div class="sidebar-actions">
                    <button class="btn-new-post" @onclick="CreateNewPost">
                        <i class="bi bi-plus-lg"></i>
                        <span>New Blog Post</span>
                    </button>
                </div>

                <div class="sidebar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search blogs..." @bind="_searchText" @bind:event="oninput" />
                </div>

                <div class="sidebar-menu" id="blog-list-container">
                    @{
                        var blogsToShow = FilteredBlogs.ToList();
                        int priority = 1;
                    }
                    @foreach (var blog in blogsToShow)
                    {
                        var blogId = blog.Id;
                        var priorityNum = priority++;
                        <div class="menu-item @(blog.Id == _activePost?.Id ? "active" : "") @(_dragOverBlogId == blog.Id ? "drag-over" : "")"
                             draggable="true"
                             @onclick="() => SelectBlog(blog)"
                             @ondragstart="() => OnDragStart(blog)"
                             @ondragover:preventDefault="true"
                             @ondragover="() => OnDragOver(blog)"
                             @ondrop="() => OnDrop(blog)"
                             @ondragend="OnDragEnd">
                            <div class="drag-handle" title="Drag to reorder">
                                <i class="bi bi-grip-vertical"></i>
                            </div>
                            <div class="priority-badge" title="Priority #@priorityNum">#@priorityNum</div>
                            <div class="menu-icon" style="background: linear-gradient(135deg, @(blog.GradientStart ?? "#4f46e5"), @(blog.GradientEnd ?? "#06b6d4"))">
                                <i class="@(string.IsNullOrEmpty(blog.IconClass) ? "bi bi-file-earmark-text" : blog.IconClass)" style="color: @(blog.IconColor ?? "#ffffff")"></i>
                            </div>
                            <div class="menu-details">
                                <span class="menu-title">@blog.Title</span>
                                <div class="menu-meta">
                                    <span class="menu-badge" style="background: @(GetCategoryColor(blog.Category))">@blog.CategoryBadge</span>
                                    <span class="menu-date">@blog.Date</span>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!FilteredBlogs.Any())
                    {
                        <div class="no-blogs">
                            <i class="bi bi-folder-x"></i>
                            <p>No blog posts found</p>
                        </div>
                    }
                </div>
            </aside>

            <!-- MAIN CONTENT AREA -->
            <main class="main-content">
                @if (_activePost == null)
                {
                    <!-- WELCOME/ANALYTICS SCREEN -->
                    <div class="welcome-screen">
                        <div class="welcome-card">
                            <div class="animated-icon">
                                <i class="bi bi-speedometer2"></i>
                            </div>
                            <h1>Insights Management Portal</h1>
                            <p>Select a blog post from the sidebar to begin editing, or create a brand new post to publish on the clinic website.</p>
                            
                            <div class="analytics-grid">
                                <div class="stat-card">
                                    <h3>@_blogs.Count</h3>
                                    <span>Total Posts</span>
                                </div>
                                <div class="stat-card">
                                    <h3>@_blogs.Count(b => b.IsFeatured)</h3>
                                    <span>Featured Posts</span>
                                </div>
                                <div class="stat-card text-success">
                                    <h3>Database Connected</h3>
                                    <span>PostgreSQL Server</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- EDITOR DASHBOARD -->
                    <div class="editor-header">
                        <div class="title-section">
                            <h2>@(_activePost.Id == 0 ? "Create New Blog Post" : "Edit Blog Post")</h2>
                            <p><span class="post-status @(_activePost.IsPublished ? "published" : "draft")">@(_activePost.IsPublished ? "Published" : "Draft")</span> @(_activePost.IsPublished ? "Visible on the public website" : "Private until published")</p>
                        </div>
                        <div class="actions-section">
                            <button class="btn-delete" @onclick="ConfirmDelete" disabled="@(_activePost.Id == 0)">
                                <i class="bi bi-trash3"></i>
                                <span>Delete</span>
                            </button>
                            <button class="btn-save" @onclick="SaveChanges" disabled="@_isSaving">
                                @if (_isSaving)
                                {
                                    <span class="spinner-sm"></span>
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <i class="bi bi-cloud-arrow-up"></i>
                                    <span>Save Changes</span>
                                }
                            </button>
                            <button class="btn-publish" @onclick="PublishChanges" disabled="@_isSaving">
                                <i class="bi bi-send-check"></i>
                                <span>@(_activePost.IsPublished ? "Update Published" : "Publish")</span>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger mx-4 mt-3" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-2"></i>
                            @_errorMessage
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_successMessage))
                    {
                        <div class="alert alert-success mx-4 mt-3" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @_successMessage
                        </div>
                    }

                    <div class="editor-scroll-container">
                        <!-- METADATA FORM -->
                        <div class="metadata-section">
                            <div class="metadata-grid">
                                <!-- LEFT COLUMN -->
                                <div class="meta-card">
                                    <h4><i class="bi bi-file-earmark-richtext"></i> General Info</h4>
                                    
                                    <div class="form-group-db">
                                        <label>Blog Title</label>
                                        <input type="text" @bind="_activePost.Title" placeholder="e.g. Understanding Cardiac Risk" />
                                    </div>
                                    
                                    <div class="form-group-db">
                                        <label>Blog Subtitle</label>
                                        <input type="text" @bind="_activePost.SubTitle" placeholder="e.g. Learn what markers you should be testing and how often." />
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Category (Path Key)</label>
                                                <input type="text" @bind="_activePost.Category" placeholder="e.g. heart, diabetes" />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Category Badge Label</label>
                                                <input type="text" @bind="_activePost.CategoryBadge" placeholder="e.g. Cardiology" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group-db">
                                        <label>Tags (Comma-separated)</label>
                                        <input type="text" @bind="_activePost.Tags" placeholder="e.g. Heart Health, Prevention" />
                                    </div>

                                    <div class="row align-items-center mt-3">
                                        <div class="col-6">
                                            <div class="form-check form-switch custom-switch">
                                                <input class="form-check-input" type="checkbox" id="featuredSwitch" @bind="_activePost.IsFeatured" />
                                                <label class="form-check-label" for="featuredSwitch">Featured Article</label>
                                            </div>
                                        </div>
                                        <div class="col-6 text-end">
                                            <span class="badge text-bg-secondary">ID: @(_activePost.Id == 0 ? "New" : _activePost.Id)</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- CENTER COLUMN: AUTHOR -->
                                <div class="meta-card">
                                    <h4><i class="bi bi-person-circle"></i> Author & Meta</h4>
                                    
                                    <div class="form-group-db">
                                        <label>Author Name</label>
                                        <input type="text" @bind="_activePost.AuthorName" placeholder="e.g. Dr. Rajan Kumar" />
                                    </div>

                                    <div class="form-group-db">
                                        <label>Author Title / Specialty</label>
                                        <input type="text" @bind="_activePost.AuthorTitle" placeholder="e.g. Cardiologist" />
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Author Profile Photo</label>
                                                <div class="image-upload-wrapper" style="flex-direction: column; align-items: flex-start; gap: 8px;">
                                                    <div style="display: flex; gap: 8px; width: 100%; align-items: center;">
                                                        <input type="text" @bind="_activePost.AuthorAvatar" placeholder="/avatars/dr.jpg, URL, or upload" style="flex: 1;" />
                                                        <label class="btn-upload" title="Upload Author Photo" style="flex-shrink: 0;">
                                                            <i class="bi bi-person-circle"></i>
                                                            <InputFile OnChange="UploadAvatarImage" accept="image/*" style="display:none;" />
                                                        </label>
                                                        @if (!string.IsNullOrEmpty(_activePost.AuthorAvatar))
                                                        {
                                                            <button type="button" title="Clear Avatar" @onclick="() => _activePost.AuthorAvatar = string.Empty" style="border: none; background: #fef2f2; color: #ef4444; border-radius: 6px; width: 28px; height: 28px; cursor: pointer; flex-shrink: 0; font-size: 0.9rem;">
                                                                <i class="bi bi-x"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(_activePost.AuthorAvatar) && (_activePost.AuthorAvatar.StartsWith("data:") || _activePost.AuthorAvatar.StartsWith("http") || _activePost.AuthorAvatar.StartsWith("/")))
                                                    {
                                                        <img src="@_activePost.AuthorAvatar" alt="Author Avatar Preview" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(59,130,246,0.5);" />
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Read Time</label>
                                                <input type="text" @bind="_activePost.ReadTime" placeholder="e.g. 7 min read" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group-db">
                                        <label>Publish Date Label</label>
                                        <input type="text" @bind="_activePost.Date" placeholder="e.g. June 1, 2026" />
                                    </div>
                                </div>

                                <!-- RIGHT COLUMN: CARD AESTHETICS -->
                                <div class="meta-card">
                                    <h4><i class="bi bi-palette"></i> Card Design & Visuals</h4>

                                    <div class="form-group-db">
                                        <label>Banner Image / Graphic</label>
                                        <div class="image-upload-wrapper">
                                            <input type="text" @bind="_activePost.ImagePath" placeholder="/BlogImages/1.jpg or URL" />
                                            <label class="btn-upload" title="Upload Local Image File">
                                                <i class="bi bi-upload"></i>
                                                <InputFile OnChange="UploadBannerImage" accept="image/*" style="display:none;" />
                                            </label>
                                        </div>
                                        @if (!string.IsNullOrEmpty(_activePost.ImagePath))
                                        {
                                            <div class="banner-preview">
                                                <img src="@_activePost.ImagePath" alt="Banner Preview" />
                                            </div>
                                        }
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Icon Class (Bootstrap)</label>
                                                <input type="text" @bind="_activePost.IconClass" placeholder="bi bi-heart-pulse" />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Icon Color</label>
                                                <div class="color-picker-group">
                                                    <input type="color" @bind="_activePost.IconColor" />
                                                    <input type="text" @bind="_activePost.IconColor" style="font-size: 0.8rem;" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Gradient Start</label>
                                                <div class="color-picker-group">
                                                    <input type="color" @bind="_activePost.GradientStart" />
                                                    <input type="text" @bind="_activePost.GradientStart" style="font-size: 0.8rem;" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group-db">
                                                <label>Gradient End</label>
                                                <div class="color-picker-group">
                                                    <input type="color" @bind="_activePost.GradientEnd" />
                                                    <input type="text" @bind="_activePost.GradientEnd" style="font-size: 0.8rem;" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- FALLBACK TEXT FIELDS (FOR SITES USING STRUCTURAL RENDERING) -->
                            <div class="meta-card mt-3">
                                <h4><i class="bi bi-card-text"></i> Dynamic Structured Sections (SEO / Fallback)</h4>
                                <div class="form-group-db">
                                    <label>Introductory Paragraph (Summary)</label>
                                    <textarea @bind="_activeDetails.Introduction" placeholder="A short, catchy intro that sets the stage..." rows="3"></textarea>
                                </div>
                                <div class="form-group-db">
                                    <label>Concluding Paragraph</label>
                                    <textarea @bind="_activeDetails.Conclusion" placeholder="Summarize findings and call to action..." rows="3"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- RICH TEXT EDITOR CANVAS -->
                        <div class="editor-canvas-container">
                            <h4 class="canvas-header"><i class="bi bi-pen-fill"></i> Rich Content Editor</h4>
                            <RichTextEditor @ref="_editorRef" InitialHtml="@_activeDetails.ContentHtml" />
                        </div>
                    </div>
                }
            </main>
        </div>
    }

    @if (_showMailModal)
    {
        <!-- MAIL TRANSACTIONS MODAL -->
        <div class="modal-overlay">
            <div class="modal-card">
                <div class="modal-header">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-envelope-paper-fill text-primary fs-4"></i>
                        <h3 class="mb-0">Client Mail Transactions</h3>
                    </div>
                    <button class="btn-close-modal" @onclick="CloseMailModal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                
                <!-- Date Filter and Report Action Bar -->
                <div class="modal-filter-bar">
                    <div class="filter-inputs">
                        <div class="filter-group">
                            <label>From Date</label>
                            <input type="date" @bind="_filterFromDate" class="date-input" />
                        </div>
                        <div class="filter-group">
                            <label>To Date</label>
                            <input type="date" @bind="_filterToDate" class="date-input" />
                        </div>
                        @if (_filterFromDate.HasValue || _filterToDate.HasValue)
                        {
                            <button class="btn-clear-filter" @onclick="ClearDateFilters" title="Clear Filters">
                                <i class="bi bi-x-circle-fill"></i>
                            </button>
                        }
                    </div>
                    <button class="btn-report-pdf" @onclick="GeneratePdfReport" title="Download Immersive PDF Report">
                        <i class="bi bi-file-earmark-pdf-fill me-1"></i> Export PDF Report
                    </button>
                </div>

                <div class="modal-body-split">
                    <!-- LEFT COLUMN: MAIL LIST -->
                    <div class="mail-list-sidebar">
                        @if (FilteredMails == null || !FilteredMails.Any())
                        {
                            <div class="no-mails">
                                <i class="bi bi-envelope-open"></i>
                                <p>No mail transactions logged.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var mail in FilteredMails ?? Array.Empty<MailTransaction>())
                            {
                                var currentMail = mail;
                                if (currentMail == null) continue;
                                <div class="mail-item @(currentMail.MtCode == _selectedMail?.MtCode ? "active" : "")" @onclick="() => SelectMail(currentMail)">
                                    <div class="mail-item-header">
                                        <span class="mail-name">@(string.IsNullOrEmpty(currentMail.ClientName) ? currentMail.ToEmail : currentMail.ClientName)</span>
                                        <div class="d-flex align-items-center gap-1">
                                            <button class="btn-download-mail" @onclick:stopPropagation="true" @onclick="() => DownloadMailTxt(currentMail)" title="Download Info">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <button class="btn-delete-mail" @onclick:stopPropagation="true" @onclick="() => DeleteMail(currentMail)" title="Delete Transaction">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="mail-subject">@currentMail.Subject</div>
                                    <div class="mail-meta mt-1">
                                        <span class="status-badge @currentMail.Status.ToLower()">@currentMail.Status</span>
                                        <span class="mail-time">@currentMail.CreatedDate.ToString("yyyy-MM-dd HH:mm")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- RIGHT COLUMN: MAIL DETAIL -->
                    <div class="mail-detail-pane">
                        @if (_selectedMail == null)
                        {
                            <div class="select-prompt">
                                <i class="bi bi-envelope-arrow-up text-muted"></i>
                                <p>Select an inquiry to view full client-typed data and delivery status</p>
                            </div>
                        }
                        else
                        {
                            <div class="detail-scrollable">
                                <div class="detail-header-card">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h4 class="mb-1 text-white">@_selectedMail.ClientName</h4>
                                            <span class="text-secondary text-sm">Client Inquirer</span>
                                        </div>
                                        <span class="status-badge-lg @_selectedMail.Status.ToLower()">@_selectedMail.Status</span>
                                    </div>
                                </div>

                                <div class="detail-section-card mt-3">
                                    <h5 class="mb-3"><i class="bi bi-person-lines-fill me-2"></i>Contact Information</h5>
                                    <div class="info-row">
                                        <span class="info-label">Name:</span>
                                        <span class="info-value">@_selectedMail.ClientName</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Contact Number:</span>
                                        <span class="info-value">@_selectedMail.ClientContact</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">To Email:</span>
                                        <span class="info-value"><a href="mailto:@_selectedMail.ToEmail" class="email-link">@_selectedMail.ToEmail</a></span>
                                    </div>
                                </div>

                                <div class="detail-section-card mt-3">
                                    <h5 class="mb-3"><i class="bi bi-envelope-fill me-2"></i>Mail Details</h5>
                                    <div class="info-row">
                                        <span class="info-label">Subject:</span>
                                        <span class="info-value">@_selectedMail.Subject</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Sent Date/Time:</span>
                                        <span class="info-value">@(_selectedMail.SentDatetime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Not Sent / Pending")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_selectedMail.ErrorMessage))
                                    {
                                        <div class="info-row error-row mt-2">
                                            <span class="info-label text-danger">Error:</span>
                                            <span class="info-value text-danger">@_selectedMail.ErrorMessage</span>
                                        </div>
                                    }
                                </div>

                                <div class="detail-section-card mt-3">
                                    <h5 class="mb-3"><i class="bi bi-chat-left-text-fill me-2"></i>Client Message / Body</h5>
                                    <div class="message-body">
                                        @if (string.IsNullOrEmpty(_selectedMail.ClientMessage))
                                        {
                                            <span class="text-muted">No text message body parsed.</span>
                                        }
                                        else
                                        {
                                            @_selectedMail.ClientMessage
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- HIDDEN PDF REPORT TEMPLATE FOR HTML2PDF -->
    <div style="position: absolute; left: -9999px; top: -9999px;">
        <div id="pdf-report-content" style="width: 1000px; padding: 40px; background: #ffffff; color: #1e293b; font-family: 'Inter', -apple-system, sans-serif; box-sizing: border-box;">
            <!-- Document Header -->
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #3b82f6; padding-bottom: 20px; margin-bottom: 25px;">
                <div>
                    <h1 style="margin: 0; font-size: 28px; color: #1e3a8a; font-weight: 800; letter-spacing: -0.02em;">ALPHA DIAGNOSTICS</h1>
                    <p style="margin: 4px 0 0 0; font-size: 13px; color: #64748b; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em;">Clinical Laboratory Information System</p>
                </div>
                <div style="text-align: right;">
                    <h2 style="margin: 0; font-size: 18px; color: #2563eb; font-weight: 700;">Client Inquiries Summary</h2>
                    <p style="margin: 4px 0 0 0; font-size: 12px; color: #64748b; font-weight: 500;">
                        Period: @(_filterFromDate?.ToString("yyyy-MM-dd") ?? "All Time") to @(_filterToDate?.ToString("yyyy-MM-dd") ?? "All Time")
                    </p>
                </div>
            </div>

            <!-- Report Details Summary Block -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; font-size: 12px; color: #334155; background: #f8fafc; padding: 15px 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);">
                <div>
                    <span style="color: #64748b; font-weight: 500;">Report Type:</span> 
                    <strong style="color: #0f172a; margin-left: 5px;">Client Inquiry History</strong>
                </div>
                <div>
                    <span style="color: #64748b; font-weight: 500;">Generated On:</span> 
                    <strong style="color: #0f172a; margin-left: 5px;">@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</strong>
                </div>
                <div>
                    <span style="color: #64748b; font-weight: 500;">Total Records:</span> 
                    <span style="background: #dbeafe; color: #1e40af; padding: 3px 8px; border-radius: 12px; font-weight: 700; font-size: 11px; margin-left: 5px;">@(FilteredMails?.Count() ?? 0)</span>
                </div>
            </div>

            <!-- Table of Client Records -->
            <table style="width: 100%; border-collapse: collapse; font-size: 12px; text-align: left; margin-bottom: 30px; border: 1px solid #e2e8f0;">
                <thead>
                    <tr style="background: #1e3a8a; color: #ffffff;">
                        <th style="padding: 12px 15px; border-right: 1px solid rgba(255,255,255,0.15); font-weight: 700; width: 22%;">Client Name</th>
                        <th style="padding: 12px 15px; border-right: 1px solid rgba(255,255,255,0.15); font-weight: 700; width: 20%;">Phone Number</th>
                        <th style="padding: 12px 15px; border-right: 1px solid rgba(255,255,255,0.15); font-weight: 700; width: 25%;">Email Address</th>
                        <th style="padding: 12px 15px; border-right: 1px solid rgba(255,255,255,0.15); font-weight: 700; width: 18%;">Date & Time</th>
                        <th style="padding: 12px 15px; font-weight: 700; width: 15%;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!FilteredMails.Any())
                    {
                        <tr>
                            <td colspan="5" style="padding: 25px; text-align: center; color: #64748b; font-style: italic; font-size: 13px; background: #ffffff;">No client inquiry records found matching the selected range.</td>
                        </tr>
                    }
                    else
                    {
                        int idx = 0;
                        @foreach (var mail in FilteredMails)
                        {
                            var rowBg = idx % 2 == 0 ? "#ffffff" : "#f8fafc";
                            var borderBottom = idx == FilteredMails.Count() - 1 ? "none" : "1px solid #e2e8f0";
                            var statusColor = mail.Status.ToLower() == "sent" ? "#10b981" : (mail.Status.ToLower() == "failed" ? "#ef4444" : "#fbbf24");
                            <tr style="background: @rowBg; border-bottom: @borderBottom;">
                                <td style="padding: 12px 15px; font-weight: 600; color: #0f172a; border-right: 1px solid #e2e8f0;">@mail.ClientName</td>
                                <td style="padding: 12px 15px; color: #334155; border-right: 1px solid #e2e8f0; font-family: monospace; font-size: 13px;">@mail.ClientContact</td>
                                <td style="padding: 12px 15px; color: #334155; border-right: 1px solid #e2e8f0;">@mail.ToEmail</td>
                                <td style="padding: 12px 15px; color: #475569; border-right: 1px solid #e2e8f0;">@mail.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td style="padding: 12px 15px; font-weight: 700; color: @statusColor; text-transform: uppercase; font-size: 11px;">@mail.Status</td>
                            </tr>
                            idx++;
                        }
                    }
                </tbody>
            </table>

            <!-- Professional Report Sign-off / Footer -->
            <div style="margin-top: 50px; border-top: 2px solid #e2e8f0; padding-top: 15px; display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: #94a3b8; font-weight: 500;">
                <span>Alpha Diagnostics Marketing CMS Reporting Portal</span>
                <span style="font-family: monospace;">SYSTEM GENERATED DOCUMENT - CONFIDENTIAL</span>
            </div>
        </div>
    </div>
</div>

<!-- STYLES -->
<style>
    :root {
        --glass-bg: rgba(15, 23, 42, 0.45);
        --glass-border: rgba(255, 255, 255, 0.08);
        --glass-hover: rgba(255, 255, 255, 0.12);
        --accent-primary: #3b82f6;
        --accent-glow: rgba(59, 130, 246, 0.35);
        --text-muted: #94a3b8;
    }

    body {
        margin: 0;
        padding: 0;
        background-color: #0b0f19;
        color: #f1f5f9;
        font-family: 'Inter', sans-serif;
        overflow: hidden;
    }

    .portal-root {
        width: 100vw;
        height: 100vh;
        position: relative;
        background: radial-gradient(circle at 50% 120%, #1e1b4b 0%, #09070f 80%);
        overflow: hidden;
    }

    /* LOGIN PAGE */
    .login-container {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .mesh-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        overflow: hidden;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(140px);
        opacity: 0.4;
        mix-blend-mode: screen;
        animation: float 25s infinite alternate ease-in-out;
    }

    .orb-1 {
        width: 500px;
        height: 500px;
        background: #3b82f6;
        top: 10%;
        left: 15%;
    }

    .orb-2 {
        width: 600px;
        height: 600px;
        background: #818cf8;
        bottom: 10%;
        right: 15%;
        animation-delay: -5s;
    }

    .orb-3 {
        width: 400px;
        height: 400px;
        background: #ec4899;
        top: 40%;
        left: 50%;
        animation-delay: -10s;
    }

    .login-card {
        width: 440px;
        padding: 2.5rem;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(25px);
        border-radius: 20px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        z-index: 10;
        animation: cardEnter 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .logo-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: white;
        margin: 0 auto 1.2rem auto;
        box-shadow: 0 8px 24px rgba(59, 130, 246, 0.4);
    }

    .login-header h2 {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        margin: 0;
        font-size: 1.75rem;
        letter-spacing: -0.025em;
    }

    .login-header p {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-top: 0.5rem;
    }

    .error-alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
        padding: 0.8rem 1.2rem;
        border-radius: 12px;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        animation: shake 0.4s ease-in-out;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #cbd5e1;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-wrapper i {
        position: absolute;
        left: 1.2rem;
        color: var(--text-muted);
        font-size: 1.1rem;
    }

    .input-wrapper input {
        width: 100%;
        padding: 0.9rem 1.2rem 0.9rem 3.2rem;
        background: rgba(15, 23, 42, 0.45);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        color: white;
        font-size: 0.95rem;
        outline: none;
        transition: all 0.3s ease;
    }

    .input-wrapper input:focus {
        border-color: var(--accent-primary);
        box-shadow: 0 0 15px var(--accent-glow);
        background: rgba(15, 23, 42, 0.75);
    }

    .btn-login {
        width: 100%;
        padding: 0.95rem;
        background: linear-gradient(135deg, #3b82f6, #4f46e5);
        border: none;
        border-radius: 12px;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
    }

    .btn-login:hover {
        background: linear-gradient(135deg, #2563eb, #4338ca);
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(59, 130, 246, 0.4);
    }

    .btn-login:active {
        transform: translateY(0);
    }

    .btn-login:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    .login-footer {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* CMS DASHBOARD LAYOUT */
    .dashboard-layout {
        width: 100%;
        height: 100%;
        display: flex;
        overflow: hidden;
    }

    /* SIDEBAR */
    .sidebar {
        width: 320px;
        background: rgba(11, 15, 25, 0.85);
        border-right: 1px solid var(--glass-border);
        display: flex;
        flex-direction: column;
        height: 100%;
        z-index: 20;
    }

    .sidebar-header {
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--glass-border);
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .brand i {
        font-size: 1.8rem;
    }

    .brand h3 {
        margin: 0;
        font-family: 'Outfit', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: white;
    }

    .brand span {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .btn-logout {
        background: transparent;
        border: 1px solid var(--glass-border);
        color: var(--text-muted);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-logout:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #f87171;
        border-color: rgba(239, 68, 68, 0.2);
    }

    .sidebar-actions {
        padding: 1rem 1.5rem;
    }

    .btn-new-post {
        width: 100%;
        padding: 0.8rem;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border: none;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
    }

    .btn-new-post:hover {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        box-shadow: 0 6px 16px rgba(59, 130, 246, 0.35);
    }

    .sidebar-search {
        padding: 0 1.5rem 1rem 1.5rem;
        position: relative;
        display: flex;
        align-items: center;
    }

    .sidebar-search i {
        position: absolute;
        left: 2.2rem;
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .sidebar-search input {
        width: 100%;
        padding: 0.65rem 1rem 0.65rem 2.4rem;
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        color: white;
        font-size: 0.85rem;
        outline: none;
        transition: all 0.3s ease;
    }

    .sidebar-search input:focus {
        border-color: var(--accent-primary);
        background: rgba(15, 23, 42, 0.8);
    }

    .sidebar-menu {
        flex: 1;
        overflow-y: auto;
        padding: 0 1rem 1rem 1rem;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.75rem 0.8rem;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.25s ease;
        margin-bottom: 0.5rem;
        border: 1px solid transparent;
        position: relative;
    }

    .menu-item:hover {
        background: var(--glass-hover);
        border-color: var(--glass-border);
    }

    .menu-item.active {
        background: rgba(59, 130, 246, 0.12);
        border-color: rgba(59, 130, 246, 0.25);
    }

    .menu-item.drag-over {
        background: rgba(99, 102, 241, 0.22);
        border-color: rgba(99, 102, 241, 0.6);
        border-style: dashed;
        transform: scale(1.015);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

    .drag-handle {
        display: flex;
        align-items: center;
        color: rgba(255, 255, 255, 0.18);
        cursor: grab;
        flex-shrink: 0;
        font-size: 0.9rem;
        transition: color 0.2s;
        padding: 0 1px;
    }

    .menu-item:hover .drag-handle {
        color: rgba(255, 255, 255, 0.55);
    }

    .drag-handle:active { cursor: grabbing; }

    .priority-badge {
        font-size: 0.6rem;
        font-weight: 700;
        color: rgba(148, 163, 184, 0.65);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        padding: 0.1rem 0.28rem;
        flex-shrink: 0;
        min-width: 20px;
        text-align: center;
        letter-spacing: 0.02em;
        font-family: 'Inter', monospace;
    }

    .menu-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .menu-details {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .menu-title {
        font-size: 0.85rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #f8fafc;
    }

    .menu-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .menu-badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        text-transform: uppercase;
        color: white;
    }

    .menu-date {
        font-size: 0.7rem;
        color: var(--text-muted);
    }

    .no-blogs {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--text-muted);
    }

    .no-blogs i {
        font-size: 2rem;
        margin-bottom: 0.5rem;
        display: block;
    }

    /* MAIN CONTENT */
    .main-content {
        flex: 1;
        height: 100%;
        display: flex;
        flex-direction: column;
        background: #0f172a;
        overflow: hidden;
    }

    /* WELCOME SCREEN */
    .welcome-screen {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .welcome-card {
        text-align: center;
        max-width: 600px;
        padding: 3rem;
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .animated-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(59, 130, 246, 0.1);
        color: var(--accent-primary);
        font-size: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem auto;
        animation: pulseGlow 3s infinite alternate;
    }

    .welcome-card h1 {
        font-family: 'Outfit', sans-serif;
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .welcome-card p {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .analytics-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .stat-card {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--glass-border);
        padding: 1rem;
        border-radius: 12px;
    }

    .stat-card h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
    }

    .stat-card span {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* EDITOR INTERFACE */
    .editor-header {
        padding: 1.25rem 2rem;
        background: rgba(15, 23, 42, 0.8);
        border-bottom: 1px solid var(--glass-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .title-section h2 {
        margin: 0;
        font-family: 'Outfit', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .title-section p {
        margin: 0.25rem 0 0 0;
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .actions-section {
        display: flex;
        gap: 0.75rem;
    }

    .btn-delete {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.25);
        color: #f87171;
        padding: 0.55rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-delete:hover:not(:disabled) {
        background: #ef4444;
        color: white;
        border-color: #ef4444;
    }

    .btn-delete:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-save {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border: none;
        color: white;
        padding: 0.55rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
    }

    .btn-save:hover:not(:disabled) {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        box-shadow: 0 6px 16px rgba(59, 130, 246, 0.35);
    }

    .btn-save:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .btn-publish {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        color: #fff;
        padding: 0.55rem 1.25rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }
    .btn-publish:hover:not(:disabled) { background: linear-gradient(135deg, #059669, #047857); }
    .btn-publish:disabled { opacity: .7; cursor: not-allowed; }
    .post-status { display: inline-block; padding: .15rem .5rem; margin-right: .35rem; border-radius: 999px; font-size: .7rem; font-weight: 700; letter-spacing: .03em; }
    .post-status.draft { color: #fbbf24; background: rgba(245, 158, 11, .14); }
    .post-status.published { color: #6ee7b7; background: rgba(16, 185, 129, .14); }

    .editor-scroll-container {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* METADATA FORM STYLING */
    .metadata-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.25rem;
    }

    .meta-card {
        background: rgba(30, 41, 59, 0.4);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .meta-card h4 {
        margin: 0 0 0.5rem 0;
        font-size: 0.95rem;
        font-weight: 700;
        color: #60a5fa;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 0.5rem;
    }

    .form-group-db {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .form-group-db label {
        font-size: 0.75rem;
        font-weight: 600;
        color: #94a3b8;
    }

    .form-group-db input[type="text"],
    .form-group-db textarea {
        width: 100%;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 0.55rem 0.75rem;
        color: white;
        font-size: 0.85rem;
        outline: none;
        transition: all 0.3s ease;
    }

    .form-group-db input:focus,
    .form-group-db textarea:focus {
        border-color: var(--accent-primary);
        background: rgba(15, 23, 42, 0.85);
    }

    /* IMAGE UPLOAD & PREVIEW */
    .image-upload-wrapper {
        display: flex;
        gap: 0.5rem;
    }

    .btn-upload {
        width: 38px;
        height: 38px;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #60a5fa;
        cursor: pointer;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .btn-upload:hover {
        background: rgba(59, 130, 246, 0.15);
        border-color: var(--accent-primary);
    }

    .banner-preview {
        width: 100%;
        height: 80px;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--glass-border);
