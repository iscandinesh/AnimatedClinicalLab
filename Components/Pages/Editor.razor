@code {
    private bool _isLoggedIn = false;
    private string _username = "";
    private string _password = "";
    private string _loginError = "";
    private bool _isSubmitting = false;

    private List<BlogPost> _blogs = new();
    private string _searchText = "";

    private BlogPost? _activePost = null;
    private BlogPostDetails _activeDetails = new();
    private RichTextEditor? _editorRef;

    private string _errorMessage = "";
    private string _successMessage = "";
    private bool _isSaving = false;

    // Mail Transactions state
    private bool _showMailModal = false;
    private List<MailTransaction> _mailTransactions = new();
    private MailTransaction? _selectedMail = null;
    private DateTime? _filterFromDate = DateTime.Today.AddDays(-10);
    private DateTime? _filterToDate = DateTime.Today;

    private IEnumerable<MailTransaction> FilteredMails =>
        _mailTransactions == null 
            ? Array.Empty<MailTransaction>()
            : _mailTransactions.Where(m => 
                (!_filterFromDate.HasValue || m.CreatedDate.Date >= _filterFromDate.Value.Date) &&
                (!_filterToDate.HasValue || m.CreatedDate.Date <= _filterToDate.Value.Date)
            );

    // Drag-and-drop reordering state
    private BlogPost? _draggedBlog = null;
    private int _dragOverBlogId = -1;

    private IEnumerable<BlogPost> FilteredBlogs => 
        string.IsNullOrWhiteSpace(_searchText) 
            ? _blogs 
            : _blogs.Where(b => b.Title.Contains(_searchText, StringComparison.OrdinalIgnoreCase) || 
                                 b.CategoryBadge.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    private void OnDragStart(BlogPost blog)
    {
        _draggedBlog = blog;
    }

    private void OnDragOver(BlogPost target)
    {
        if (_draggedBlog == null || _draggedBlog.Id == target.Id) return;
        _dragOverBlogId = target.Id;
    }

    private async Task OnDrop(BlogPost target)
    {
        if (_draggedBlog == null || _draggedBlog.Id == target.Id)
        {
            _dragOverBlogId = -1;
            _draggedBlog = null;
            return;
        }

        // Re-order the in-memory list
        var fromIndex = _blogs.IndexOf(_draggedBlog);
        var toIndex = _blogs.IndexOf(target);
        if (fromIndex < 0 || toIndex < 0) return;

        _blogs.RemoveAt(fromIndex);
        _blogs.Insert(toIndex, _draggedBlog);

        // Update SortOrder on each item
        for (int i = 0; i < _blogs.Count; i++)
            _blogs[i].SortOrder = i + 1;

        _draggedBlog = null;
        _dragOverBlogId = -1;
        StateHasChanged();

        // Persist the new order to the DB
        await BlogService.ReorderBlogsAsync(_blogs.Select(b => b.Id).ToList());
    }

    private void OnDragEnd()
    {
        _draggedBlog = null;
        _dragOverBlogId = -1;
    }

    protected override async Task OnInitializedAsync()
    {
        // Try to load auth state from local variable (or could use ProtectedSessionStorage)
        // For simplicity of this marketing dashboard, we maintain session in-memory or cookie.
        // We will seed or check from DB.
        await LoadBlogsListAsync();
    }

    private async Task LoadBlogsListAsync()
    {
        try
        {
            _blogs = await BlogService.GetBlogsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading blogs: {ex.Message}");
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = AttemptLogin();
        }
    }

    private async Task AttemptLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _loginError = "Please fill in all fields.";
            return;
        }

        _isSubmitting = true;
        _loginError = "";
        StateHasChanged();

        try
        {
            bool isValid = await BlogService.ValidateLoginAsync(_username, _password);
            if (isValid)
            {
                _isLoggedIn = true;
                await LoadBlogsListAsync();
            }
            else
            {
                _loginError = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            _loginError = $"Login error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private void Logout()
    {
        _isLoggedIn = false;
        _username = "";
        _password = "";
        _activePost = null;
        StateHasChanged();
    }

    private async Task SelectBlog(BlogPost blog)
    {
        _errorMessage = "";
        _successMessage = "";
        
        // Deep clone post (preserve ImageData so it isn't zeroed on re-save)
        _activePost = new BlogPost
        {
            Id = blog.Id,
            Title = blog.Title,
            SubTitle = blog.SubTitle,
            Category = blog.Category,
            CategoryBadge = blog.CategoryBadge,
            Tags = blog.Tags,
            AuthorName = blog.AuthorName,
            AuthorTitle = blog.AuthorTitle,
            AuthorAvatar = blog.AuthorAvatar,
            Date = blog.Date,
            ReadTime = blog.ReadTime,
            ImagePath = blog.ImagePath,
            ImageData = blog.ImageData,
            IconClass = blog.IconClass,
            IconColor = blog.IconColor,
            GradientStart = blog.GradientStart,
            GradientEnd = blog.GradientEnd,
            IsFeatured = blog.IsFeatured,
            IsPublished = blog.IsPublished
        };

        var details = await BlogService.GetBlogDetailsAsync(blog.Id);
        _activeDetails = details ?? new BlogPostDetails { BlogId = blog.Id };

        StateHasChanged();

        // Pass HTML content to editor interop
        if (_editorRef != null)
        {
            await _editorRef.SetHtmlContentAsync(_activeDetails.ContentHtml);
        }
    }

    private void CreateNewPost()
    {
        _errorMessage = "";
        _successMessage = "";
        
        _activePost = new BlogPost
        {
            Id = 0,
            Date = DateTime.Now.ToString("MMMM d, yyyy"),
            ReadTime = "5 min read",
            IconClass = "bi bi-activity",
            IconColor = "#a78bfa",
            GradientStart = "#2a1a3a",
            GradientEnd = "#1a0f2a",
            ImagePath = "/BlogImages/1.jpg"
        };
        _activeDetails = new BlogPostDetails { BlogId = 0 };

        StateHasChanged();

        // Clear editor content
        if (_editorRef != null)
        {
            _ = _editorRef.SetHtmlContentAsync("<p>Start typing your blog post content here...</p>");
        }
    }

    private async Task UploadBannerImage(InputFileChangeEventArgs e)
    {
        _errorMessage = "";
        _successMessage = "";
        try
        {
            var file = e.File;
            if (file != null)
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);

                if (_activePost != null)
                {
                    _activePost.ImageData = memoryStream.ToArray();
                    _activePost.ImagePath = $"data:{file.ContentType};base64,{Convert.ToBase64String(_activePost.ImageData)}";
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Banner image upload failed: {ex.Message}";
        }
    }

    private async Task UploadAvatarImage(InputFileChangeEventArgs e)
    {
        _errorMessage = "";
        try
        {
            var file = e.File;
            if (file != null && _activePost != null)
            {
                // Limit avatar to 2MB
                using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                var base64 = Convert.ToBase64String(memoryStream.ToArray());
                _activePost.AuthorAvatar = $"data:{file.ContentType};base64,{base64}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Avatar upload failed: {ex.Message}";
        }
    }

    private async Task SaveChanges()
    {
        await SavePostAsync(publish: false);
    }

    private async Task PublishChanges()
    {
        await SavePostAsync(publish: true);
    }

    private async Task SavePostAsync(bool publish)
    {
        if (_activePost == null) return;
        
        if (string.IsNullOrWhiteSpace(_activePost.Title))
        {
            _errorMessage = "Title is required.";
            return;
        }

        if (publish)
        {
            _activePost.IsPublished = true;
        }
        _isSaving = true;
        _errorMessage = "";
        _successMessage = "";
        StateHasChanged();

        try
        {
            // Read rich HTML content from editor
            if (_editorRef != null)
            {
                _activeDetails.ContentHtml = await _editorRef.GetHtmlContentAsync();
            }

            bool success;
            if (_activePost.Id == 0)
            {
                int newId = await BlogService.CreateBlogAsync(_activePost, _activeDetails);
                success = newId > 0;
                if (success)
                {
                    _activePost.Id = newId;
                    _activeDetails.BlogId = newId;
                }
            }
            else
            {
                success = await BlogService.SaveBlogAsync(_activePost, _activeDetails);
            }

            if (success)
            {
                _successMessage = publish ? "Blog post published and is now visible on the website." : (_activePost.IsPublished ? "Published post changes saved." : "Draft saved. It remains private until you publish it.");
                await LoadBlogsListAsync();
            }
            else
            {
                _errorMessage = "Failed to save blog post to PostgreSQL database.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Save error: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmDelete()
    {
        if (_activePost == null || _activePost.Id == 0) return;

        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{_activePost.Title}'?");
        if (!confirm) return;

        try
        {
            bool success = await BlogService.DeleteBlogAsync(_activePost.Id);
            if (success)
            {
                _activePost = null;
                _successMessage = "Blog post deleted successfully.";
                await LoadBlogsListAsync();
            }
            else
            {
                _errorMessage = "Failed to delete blog post.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Delete error: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task OpenMailModal()
    {
        _mailTransactions = await EmailService.GetMailTransactionsAsync();
        _selectedMail = null;
        _showMailModal = true;
        StateHasChanged();
    }

    private void CloseMailModal()
    {
        _showMailModal = false;
        StateHasChanged();
    }

    private void SelectMail(MailTransaction mail)
    {
        _selectedMail = mail;
        StateHasChanged();
    }

    private async Task DeleteMail(MailTransaction mail)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this mail transaction (To: {mail.ToEmail}, Subject: {mail.Subject})?");
        if (!confirm) return;

        bool success = await EmailService.DeleteMailTransactionAsync(mail.MtCode);
        if (success)
        {
            _mailTransactions.Remove(mail);
            if (_selectedMail?.MtCode == mail.MtCode)
            {
                _selectedMail = null;
            }
            StateHasChanged();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Failed to delete the mail transaction.");
        }
    }

    private void ClearDateFilters()
    {
        _filterFromDate = null;
        _filterToDate = null;
        StateHasChanged();
    }

    private async Task DownloadMailTxt(MailTransaction mail)
    {
        try
        {
            string filename = $"client_{mail.ClientName.Replace(" ", "_")}.txt";
            string content = $"Client Name: {mail.ClientName}\r\n" +
                             $"Contact Number: {mail.ClientContact}\r\n" +
                             $"Client Email: {mail.ToEmail}\r\n";
            await JSRuntime.InvokeVoidAsync("downloadTextFile", filename, content);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting text file: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to download client info: {ex.Message}");
        }
    }

    private async Task GeneratePdfReport()
    {
        try
        {
            string filename = $"Inquiry_Report_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            await JSRuntime.InvokeVoidAsync("generatePdfFromHtml", "pdf-report-content", filename);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting PDF: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to export PDF: {ex.Message}");
        }
    }

    private string GetCategoryColor(string? category)
    {
        return (category?.ToLower()) switch
        {
            "heart" => "#ef4444",
            "diabetes" => "#10b981",
            "thyroid" => "#8b5cf6",
            "women" => "#ec4899",
            "nutrition" => "#f59e0b",
            _ => "#64748b"
        };
    }
}
