<!-- About Erode Main Lab Section -->
<section class="py-5">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
            <!-- Left: Intro Content Card -->
            <div class="col-lg-6 reveal-up">
                <div class="glass-card h-100 p-4 p-md-5 position-relative" style="border-radius: 30px; border: 1px solid rgba(255,255,255,0.05);">
                    <div class="position-absolute top-0 end-0 p-4 opacity-10">
                        <i class="bi bi-hospital display-3 text-primary"></i>
                    </div>
                    <h2 class="h3 fw-bold mb-4">NABL Laboratory in Erode</h2>
                    <p class="text-secondary mb-3" style="line-height: 1.7; font-size: 0.95rem;">
                        With <strong>over 10+ years of trusted experience in the diagnostic industry</strong>, Alpha Diagnostics Centre's Main Laboratory at 16, Patel Street is Erode's premier facility for 24/7 medical testing. We provide high-precision diagnostics to clinics, hospitals, and individuals across the city.
                    </p>
                    <p class="text-secondary mb-3" style="line-height: 1.7; font-size: 0.95rem;">
                        Our 24/7 home sample collection network covers all major residential areas of Erode.
                    </p>
                    <p class="text-secondary mb-0" style="line-height: 1.7; font-size: 0.95rem;">
                        By processing biochemistry, molecular biology, and microbiology tests locally at our centralized hub on Patel Street, we guarantee doctor-verified results for blood sugar, cholesterol, thyroid, and full health checkup packages—with reports delivered within 4 hours to their WhatsApp and email.
                    </p>
                </div>
            </div>

            <!-- Right: Stats & trust signals -->
            <div class="col-lg-6 reveal-up" style="transition-delay: 0.15s;">
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-start gap-3">
                        <div class="orb-blue flex-shrink-0" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; background: rgba(59,130,246,0.1); color: var(--primary-blue);">
                            <i class="bi bi-gear-wide-connected fs-5"></i>
                        </div>
