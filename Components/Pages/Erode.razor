    <meta name="keywords" content="24/7 diagnostic centre in Erode, blood test in Erode, health checkup packages in Erode, best lab in Erode, home sample collection Erode, NABL lab Erode, laboratory in Erode, pathology lab Erode, Patel Street" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.alphadiagnosticscentre.com/erode" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Best NABL Diagnostic Lab & Blood Test Centre in Erode | Alpha Diagnostics" />
    <meta property="og:description" content="NABL accredited diagnostic lab in Erode offering blood tests, health checkup packages, and home sample collection." />
    <meta property="og:url" content="https://www.alphadiagnosticscentre.com/erode" />
</HeadContent>

<style>
    .erode-hero {
        position: relative;
        background: #090c15 !important;
        min-height: 520px;
        padding-top: 165px !important;
        padding-bottom: 115px !important;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
    }
    .erode-hero::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: url('images/erode-famous-banner-desktop.jpg?v=32');
        background-position: 46% 48%;
        background-repeat: no-repeat;
        background-size: cover;
        opacity: 0.92;
        z-index: 1;
        pointer-events: none;
        animation: heroBackgroundZoom 12s ease-in-out infinite alternate;
        will-change: transform;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        filter: saturate(0.95) contrast(1.0) brightness(1.05);
    }
    @@media (max-width: 992px) {
        .erode-hero {
            min-height: 440px;
            padding-top: 130px !important;
            padding-bottom: 90px !important;
        }
    }
    @@media (max-width: 768px) {
        .erode-hero {
            min-height: 360px;
            padding-top: 110px !important;
            padding-bottom: 70px !important;
        }
        .erode-hero::before {
            background-image: url('images/erode-famous-banner-mobile.jpg?v=32') !important;
            background-position: center 48% !important;
            opacity: 0.92;
        }
    }
    
    @@keyframes heroBackgroundZoom {
        0% {
            transform: scale(1.02);
        }
        100% {
            transform: scale(1.08);
        }
    }

    /* Event Slider Styles */
    .carousel-control-btn:hover {
        background: rgba(59, 130, 246, 0.3) !important;
        border-color: rgba(59, 130, 246, 0.5) !important;
        transform: translateY(-50%) scale(1.05);
    }
    .dot-indicator:hover {
        background: var(--primary-blue) !important;
        opacity: 0.8;
    }
    .animate-fade-in {
        animation: slideFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @@keyframes slideFadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* --- Machines Showcase Styles --- */
    .machines-section {
        padding: 80px 0;
        background: transparent;
        position: relative;
        overflow: hidden;
        border-top: 1px solid var(--border-subtle);
    }

    .machines-section .section-title {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 800;
        color: var(--text-primary);
    }

    .machines-section .section-subtitle {
        font-size: clamp(1rem, 2vw, 1.15rem);
        color: var(--text-secondary);
        max-width: 650px;
        margin: 0 auto;
        font-weight: 500;
        line-height: 1.6;
    }

    .machine-showcase-card {
        border-radius: 28px;
        background: var(--bg-card);
        border: 1px solid var(--border-subtle);
        height: 640px;
        position: relative;
        overflow: hidden;
        transition: all 0.5s ease;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .machine-image-zone {
        height: 100%;
        background: var(--machine-bg-bottom, #faf9f6);
        transition: background 0.6s ease;
        overflow: hidden;
        position: relative;
    }

    .machine-image-zone::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 42%;
        background: var(--machine-theme-gradient, var(--machine-theme-color));
        transition: background 0.6s ease;
        z-index: 1;
    }

    .machine-details-zone {
        height: 100%;
    }

    .details-top-split {
        height: 42%;
        background: var(--machine-theme-gradient, var(--machine-theme-color));
        transition: background 0.6s ease;
        color: #ffffff;
        padding: 32px 40px !important;
        position: relative;
        z-index: 2;
    }

    .details-top-split > div > * {
        animation: machineDetailsFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    .details-top-split > div > *:nth-child(1) { animation-delay: 0.05s; }
    .details-top-split > div > *:nth-child(2) { animation-delay: 0.12s; }
    .details-top-split > div > *:nth-child(3) { animation-delay: 0.18s; }

    .machine-logo-wrapper {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        border-radius: 18px;
        background: #091527;
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2), inset 0 2px 4px rgba(255, 255, 255, 0.05);
        animation: machineDetailsFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 0.22s;
        opacity: 0;
    }

    .machine-logo-wrapper svg {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        display: block;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15));
    }

    .details-bottom-split {
        height: 58%;
        background: var(--machine-bg-bottom, #faf9f6);
        color: var(--text-primary);
        transition: background 0.6s ease;
        padding: 32px 40px !important;
    }

    .details-bottom-split > div > * {
        animation: machineDetailsFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    .details-bottom-split > div > *:nth-child(1) { animation-delay: 0.2s; }
    .details-bottom-split > div > *:nth-child(2) { animation-delay: 0.3s; }

    .details-footer {
        animation: machineDetailsFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 0.38s;
        opacity: 0;
    }

    @@keyframes machineDetailsFadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .machine-image-zone .machine-image-wrapper {
        position: absolute;
        top: 42%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        max-width: 550px;
        height: 480px;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: machineImageEntry 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .main-machine-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        scale: 1.25;
        filter: drop-shadow(0 20px 30px rgba(0, 0, 0, 0.35));
        animation: floatMachine 6s ease-in-out infinite;
    }

    @@keyframes floatMachine {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-12px) rotate(1deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }

    @@keyframes machineImageEntry {
        from {
            opacity: 0;
            transform: translate(-50%, -35%) scale(0.9);
        }
        to {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
    }

    .machine-thumbnails-container {
        position: absolute;
        bottom: 24px;
        left: 24px;
        right: 24px;
        display: flex;
        gap: 8px;
        z-index: 20;
        overflow-x: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding-bottom: 5px;
    }

    .machine-thumbnails-container::-webkit-scrollbar {
        display: none;
    }

    .machine-thumb-btn {
        flex-shrink: 0;
        width: 50px;
        height: 50px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid transparent;
        padding: 3px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
    }

    .machine-thumb-btn img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 6px;
    }

    .machine-thumb-btn:hover {
        transform: translateY(-4px) scale(1.05);
        box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
    }

    .machine-thumb-btn.active {
        border-color: var(--primary-blue);
        transform: translateY(-4px) scale(1.1);
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
    }

    .machine-top-tag {
        font-size: 0.75rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.6);
        letter-spacing: 2px;
    }

    .machine-name-title {
        font-size: clamp(1.5rem, 3vw, 2.3rem);
        font-weight: 800;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.1;
        text-transform: uppercase;
    }

    .machine-subtitle {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.85);
        font-weight: 500;
        letter-spacing: 0.5px;
    }

    .machine-desc-text {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--text-secondary);
        margin: 0;
    }

    .specs-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .spec-item-badge {
        display: inline-flex;
        align-items: center;
        padding: 5px 12px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .text-success-icon {
        color: #10b981;
    }

    .border-top-subtle {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #10b981;
        position: relative;
    }

    .pulse-dot::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        border: 2px solid #10b981;
        animation: statusPulse 1.8s infinite ease-out;
    }

    @@keyframes statusPulse {
        0% { transform: scale(0.8); opacity: 0.8; }
        100% { transform: scale(2.2); opacity: 0; }
    }

    .status-text {
        font-size: 0.8rem;
        color: var(--text-secondary);
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .btn-machine-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .btn-machine-action:hover {
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25) !important;
        filter: brightness(1.15);
    }

    .btn-machine-action:active {
        transform: translateY(-1px) scale(1.02);
    }

    .showcase-nav-arrows {
        display: flex;
        gap: 8px;
    }

    .showcase-arrow-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: transparent;
        border: 1px solid var(--border-subtle);
        color: var(--text-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .showcase-arrow-btn:hover {
        background: var(--primary-blue);
        color: #ffffff;
        border-color: var(--primary-blue);
        transform: scale(1.08);
    }

    @@media (max-width: 991px) {
        .machine-showcase-card {
            height: auto;
        }
        .machine-image-zone {
            height: 320px;
            background: linear-gradient(to bottom, var(--machine-theme-color) 60%, var(--machine-bg-bottom) 60%);
        }
        .machine-image-zone .machine-image-wrapper {
            top: 60%;
            height: 200px;
        }
        .machine-thumbnails-container {
            bottom: 12px;
            left: 50%;
            transform: translateX(-50%);
        }
        .details-top-split {
            height: auto;
            padding: 40px 24px !important;
        }
        .details-bottom-split {
            height: auto;
            padding: 40px 24px !important;
        }
    }

    /* Fleet of Machines Autoplay Progress Bar */
    .machine-progress-bar-wrapper {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: rgba(255, 255, 255, 0.1);
        z-index: 30;
    }

    .machine-progress-bar {
        height: 100%;
        background: var(--machine-theme-color);
        width: 0%;
        animation: machineProgress 6s linear forwards;
    }

    .machine-showcase-card:hover .machine-progress-bar {
        animation-play-state: paused;
    }

    @@keyframes machineProgress {
        from {
            width: 0%;
        }
        to {
            width: 100%;
        }
    }
</style>

<!-- Hero Section -->
