                        <img src="@machines[activeMachineIndex].ImagePath" alt="@machines[activeMachineIndex].Name" class="main-machine-img" />
                    </div>

                    <!-- Thumbnails overlayed at the bottom left -->
                    <div class="machine-thumbnails-container">
                        @for (int i = 0; i < machines.Count; i++)
                        {
                            var index = i;
                            <button class="machine-thumb-btn @(activeMachineIndex == index ? "active" : "")" @onclick="() => SetMachine(index)" aria-label="Select @machines[index].Name">
                                <img src="@machines[index].ImagePath" alt="@machines[index].Name" />
                            </button>
                        }
                    </div>
                </div>

                <!-- Right: Details Zone -->
                <div class="col-lg-6 machine-details-zone d-flex flex-column justify-content-between" @key="activeMachineIndex">
                    <!-- Top Details (in colored split) -->
                    <div class="details-top-split p-5 d-flex align-items-center justify-content-between gap-4">
                        <div class="d-flex flex-column justify-content-center">
                            <span class="machine-top-tag mb-2">ADVANCED DIAGNOSTICS</span>
                            <h4 class="machine-name-title mb-1">
                                @machines[activeMachineIndex].Name
                            </h4>
                            <span class="machine-subtitle">@machines[activeMachineIndex].Subtitle</span>
                        </div>
                        <div class="machine-logo-wrapper d-flex align-items-center justify-content-center">
                            @((MarkupString)machines[activeMachineIndex].LogoSvg)
                        </div>
                    </div>

                    <!-- Bottom Details (in white/dark split) -->
                    <div class="details-bottom-split p-5 d-flex flex-column justify-content-between flex-grow-1">
                        <div>
                            <p class="machine-desc-text">@machines[activeMachineIndex].Description</p>
                            
                            <!-- Specs list -->
                            <div class="specs-grid mt-4">
                                @foreach (var spec in machines[activeMachineIndex].Specs)
                                {
                                    <div class="spec-item-badge">
                                        <i class="bi bi-patch-check-fill text-success-icon me-2"></i>
                                        <span>@spec</span>
                                    </div>
