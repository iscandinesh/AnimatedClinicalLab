                                </button>
                                <button class="showcase-arrow-btn" @onclick="NextMachine" aria-label="Next Machine">
                                    <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
