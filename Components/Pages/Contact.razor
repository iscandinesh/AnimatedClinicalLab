@page "/contact"
@inject IJSRuntime JS

<PageTitle>Contact Us - Alpha Diagnostics Centre</PageTitle>

<section class="page-header text-center position-relative">
    <!-- Blended banner image -->
    <img src="images/indian-pathologist-new.png" alt="Diagnostics Lab" class="header-banner-image" />

    <div class="container position-relative z-2 py-0">
        <h1 class="header-title fw-bold mb-2 reveal-up" style="font-size: 2.5rem;">Contact us</h1>
        <p class="header-subtitle lead mb-0 small reveal-up" style="max-width: 600px; margin: 0 auto; font-size: 0.95rem; line-height: 1.5;">
            Book a test, request a home visit, or reach out with any questions. We are here to help.
        </p>
    </div>

    <!-- Wavy Bottom Boundary -->
    <div class="header-wave">
        <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M0,60 C300,120 900,0 1200,60 L1200,120 L0,120 Z" class="wave-path"></path>
        </svg>
    </div>
</section>

<section class="pt-0 pb-4">
    <div class="container pb-3">
        <div class="contact-card-container reveal-up">
            <!-- Contact Info Panel (Left Column) -->
            <div class="contact-info-panel">
                <div>
                    <h3 class="contact-item-title fs-4 mb-2">Get in touch</h3>
                    <p class="text-secondary small mb-5">Reach us through any of the channels below. We will respond promptly.</p>

                    <div class="contact-items-list">
                        <!-- Main Lab Address -->
                        <div class="contact-item">
                            <div class="contact-icon-wrapper">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                            <div class="contact-text-wrapper">
                                <span class="contact-item-title">Main Laboratory</span>
                                <span class="contact-item-desc">31, Patel Street, Erode – 638 001.</span>
                                <a href="https://maps.google.com" target="_blank" class="contact-item-link">View on Map →</a>
                            </div>
                        </div>

                        <!-- Sample Collection & Support -->
                        <div class="contact-item">
                            <div class="contact-icon-wrapper">
                                <i class="bi bi-telephone"></i>
                            </div>
                            <div class="contact-text-wrapper">
                                <span class="contact-item-title">Sample Collection &amp; Call Support</span>
                                <span class="contact-item-desc">70944 90917 | 81108 99999</span>
                            </div>
                        </div>

                        <!-- WhatsApp Support -->
                        <div class="contact-item">
                            <div class="contact-icon-wrapper">
                                <i class="bi bi-whatsapp"></i>
                            </div>
                            <div class="contact-text-wrapper">
                                <span class="contact-item-title">WhatsApp Support</span>
                                <a href="https://wa.me/918110899999" target="_blank" class="contact-item-link">81108 99999 →</a>
                            </div>
                        </div>

                        <!-- Email Support -->
                        <div class="contact-item">
                            <div class="contact-icon-wrapper">
                                <i class="bi bi-envelope"></i>
                            </div>
                            <div class="contact-text-wrapper">
                                <span class="contact-item-title">Email Support</span>
                                <span class="contact-item-desc">info@alphadiagnosticscentre.com</span>
                            </div>
                        </div>

                        <!-- Complaints & Feedback -->
                        <div class="contact-item">
                            <div class="contact-icon-wrapper">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                            <div class="contact-text-wrapper">
                                <span class="contact-item-title">Complaints &amp; Feedback</span>
                                <span class="contact-item-desc">70944 90913 | 70944 90907</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Follow Our Social Media Links -->
                <div class="social-media-wrapper">
                    <div class="social-title">Follow our social media</div>
                    <div class="social-icons-list">
                        <a href="https://facebook.com" target="_blank" class="social-link-btn" aria-label="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="https://instagram.com" target="_blank" class="social-link-btn" aria-label="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="https://twitter.com" target="_blank" class="social-link-btn" aria-label="Twitter">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                        <a href="https://youtube.com" target="_blank" class="social-link-btn" aria-label="YouTube">
                            <i class="bi bi-youtube"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Message Form Panel (Right Column) -->
            <div class="contact-form-panel">
                <!-- Premium Quick Highlights Banner to fill empty space -->
                <div class="form-quick-info-banner mb-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="banner-icon-box">
                            <i class="bi bi-patch-check-fill text-primary"></i>
                        </div>
                        <div>
                            <span class="banner-title">NABL Accredited &amp; ICMR Approved</span>
                            <span class="banner-subtitle">Get certified reports on your WhatsApp in 4 hours</span>
                        </div>
                    </div>
                </div>

                <h3 class="form-title">Send us a message</h3>
                <p class="form-subtitle">Fill out the form below to book a home sample collection or inquire about a test.</p>

                @if (isSubmitted)
                {
                    <div class="text-center py-5 animate-fade-in">
                        <div class="bg-success bg-opacity-10 text-success p-4 rounded-circle d-inline-block mb-4" style="width: 80px; height: 80px; display: inline-flex !important; align-items: center; justify-content: center;">
                            <i class="bi bi-check-lg fs-1"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Message Sent!</h4>
                        <p class="text-secondary">Thank you for reaching out. Our team will contact you shortly.</p>
                        <button class="contact-submit-btn w-auto px-5 mx-auto" @onclick="() => isSubmitted = false">Send Another Message</button>
                    </div>
                }
                else
                {
                    <form @onsubmit="HandleSubmit" class="d-flex flex-column gap-2">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-top">Full Name</label>
                                <input type="text" class="contact-form-input" placeholder="Name" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-top">Phone Number</label>
                                <input type="tel" class="contact-form-input" placeholder="Phone" required>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-top">Email Address</label>
                                <input type="email" class="contact-form-input" placeholder="Email" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-top">Subject / Test Type</label>
                                <select class="form-select contact-form-input" style="height: auto;">
                                    <option selected>Home Sample Collection</option>
                                    <option>Health Package Inquiry</option>
                                    <option>General Question</option>
                                    <option>Feedback</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="form-label-top">Your Message</label>
                            <textarea class="contact-form-input" rows="2" placeholder="Message"></textarea>
                        </div>
                        <button type="submit" class="contact-submit-btn">
                            <i class="bi bi-send-fill"></i> Send
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private bool isSubmitted = false;

    private async Task HandleSubmit()
    {
        await Task.Delay(600);
        isSubmitted = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initHeliumAnimations");
        }
    }
}
