@page "/contact"

<PageTitle>Contact Us - Alpha Diagnostics Centre</PageTitle>

<section class="page-header py-5 text-center text-white position-relative"
         style="background: var(--gradient-primary); padding-top: 120px !important; padding-bottom: 80px !important;">
    <div class="container position-relative z-2 animate-fade-in-up">
        <div class="badge-pill mb-3 glass-panel-dark d-inline-block px-4 py-2 text-white border-white border-opacity-25"
             style="border-radius: 30px;">
            <i class="bi bi-headset me-2"></i> We're Here to Help
        </div>
        <h1 class="display-4 fw-bold mb-3 mt-2">Get in Touch</h1>
        <p class="lead mb-0 text-white opacity-75">Book a test, request a home visit, or reach out with any questions.</p>
    </div>
</section>

<!-- Quick Contact Strips -->
<section class="py-4 bg-white border-bottom">
    <div class="container">
        <div class="row g-3 justify-content-center">
            <div class="col-md-4">
                <a href="tel:+918110899999" class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none hover-lift" style="background: var(--bg-main);">
                    <div style="width:48px;height:48px;border-radius:50%;background:var(--bg-main);border:2px solid var(--primary-color);display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-telephone-fill text-primary fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-medium">Sample Collection Booking</div>
                        <div class="fw-bold text-dark">70944 90917 / 81108 99999</div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="https://wa.me/918110899999" target="_blank" class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none hover-lift" style="background: var(--bg-main);">
                    <div style="width:48px;height:48px;border-radius:50%;background:#d1fae5;border:2px solid #16a34a;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-whatsapp text-success fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-medium">WhatsApp Report / Support</div>
                        <div class="fw-bold text-dark">81108 99999</div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="mailto:info@alphalab.co.in" class="d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none hover-lift" style="background: var(--bg-main);">
                    <div style="width:48px;height:48px;border-radius:50%;background:#e0f2fe;border:2px solid #0284c7;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-envelope-fill text-info fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-medium">Email Support</div>
                        <div class="fw-bold text-dark">info@alphalab.co.in</div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-main">
    <div class="container py-4">
        <div class="row g-5">
            <!-- Contact Info Panel -->
            <div class="col-lg-5 animate-fade-in-left">
                <div class="modern-card p-5 h-100">
                    <h3 class="fw-bold mb-1">Contact Information</h3>
                    <p class="text-secondary mb-4">Reach us through any of the channels below. We will respond promptly.</p>

                    <div class="d-flex align-items-start gap-3 mb-4 p-3 rounded-3" style="background:var(--bg-main);">
                        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg-white);border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-geo-alt-fill text-primary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Main Laboratory</h6>
                            <p class="text-secondary small mb-0">31, Patel Street, Erode – 638 001.<br />
                                <a href="https://maps.google.com" target="_blank" class="text-primary small">View on Map &rarr;</a>
                            </p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start gap-3 mb-4 p-3 rounded-3" style="background:var(--bg-main);">
                        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg-white);border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-telephone-fill text-primary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Sample Collection</h6>
                            <p class="text-secondary small mb-1">70944 90917 &nbsp;|&nbsp; 81108 99999</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start gap-3 mb-4 p-3 rounded-3" style="background:var(--bg-main);">
                        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg-white);border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-chat-dots-fill text-success"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Complaints & Feedback</h6>
                            <p class="text-secondary small mb-0">70944 90913 &nbsp;|&nbsp; 70944 90907<br />
                                <span class="text-muted fst-italic">We take every complaint seriously and use your feedback to improve our services.</span>
                            </p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start gap-3 mb-5 p-3 rounded-3" style="background:var(--bg-main);">
                        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg-white);border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-globe text-info"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Website</h6>
                            <p class="text-secondary small mb-0">www.alphalab.com</p>
                        </div>
                    </div>

                    <hr class="mb-4" />
                    <h6 class="fw-bold mb-3 text-secondary text-uppercase small letter-spacing-1">Follow Us</h6>
                    <div class="d-flex gap-3">
                        <a href="#" class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white hover-lift"
                           style="width:42px;height:42px;transition:all 0.3s;"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="d-flex align-items-center justify-content-center rounded-circle text-white hover-lift"
                           style="width:42px;height:42px;background:#e1306c;transition:all 0.3s;"><i class="bi bi-instagram"></i></a>
                        <a href="https://wa.me/918110899999" target="_blank" class="d-flex align-items-center justify-content-center rounded-circle text-white hover-lift"
                           style="width:42px;height:42px;background:#16a34a;transition:all 0.3s;"><i class="bi bi-whatsapp"></i></a>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7 animate-fade-in-right delay-200">
                <div class="modern-card p-5 h-100">
                    <h3 class="fw-bold mb-1">Send Us a Message</h3>
                    <p class="text-secondary mb-4">Fill out the form below to book a home sample collection or inquire about a test.</p>

                    <form class="contact-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="fw-medium small mb-1 text-secondary">First Name</label>
                                <input type="text" class="form-control rounded-3 border p-3" id="firstName" placeholder="e.g. Rajesh" required />
                            </div>
                            <div class="col-md-6">
                                <label class="fw-medium small mb-1 text-secondary">Last Name</label>
                                <input type="text" class="form-control rounded-3 border p-3" id="lastName" placeholder="e.g. Kumar" required />
                            </div>
                            <div class="col-md-6">
                                <label class="fw-medium small mb-1 text-secondary">Phone Number</label>
                                <input type="tel" class="form-control rounded-3 border p-3" id="phone" placeholder="e.g. 98765 43210" required />
                            </div>
                            <div class="col-md-6">
                                <label class="fw-medium small mb-1 text-secondary">Email Address</label>
                                <input type="email" class="form-control rounded-3 border p-3" id="email" placeholder="e.g. you@email.com" />
                            </div>
                            <div class="col-12">
                                <label class="fw-medium small mb-1 text-secondary">Service Needed</label>
                                <select class="form-select rounded-3 border p-3">
                                    <option value="" disabled selected>Select a service...</option>
                                    <option value="home">Home Sample Collection</option>
                                    <option value="lab">Lab Visit Appointment</option>
                                    <option value="report">Report Enquiry</option>
                                    <option value="package">Health Package Query</option>
                                    <option value="referral">Hospital / Referral Partnership</option>
                                    <option value="complaint">Complaint / Feedback</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="fw-medium small mb-1 text-secondary">Message / Address Details</label>
                                <textarea class="form-control rounded-3 border p-3" id="message" rows="4"
                                          placeholder="Tell us your requirement or paste your home address for collection..."></textarea>
                            </div>
                            <div class="col-12 mt-2">
                                @if (isSubmitted)
                                {
                                    <div class="alert border-0 rounded-3 d-flex align-items-center gap-3 animate-fade-in"
                                         style="background:#d1fae5;color:#065f46;">
                                        <i class="bi bi-check-circle-fill fs-4"></i>
                                        <div>
                                            <strong>Thank you!</strong> Your request has been received. Our team will contact you shortly.
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-primary-custom w-100 py-3 fs-5">
                                        Submit Request <i class="bi bi-send ms-2"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private bool isSubmitted = false;

    private async Task HandleSubmit()
    {
        await Task.Delay(600);
        isSubmitted = true;
    }
}
