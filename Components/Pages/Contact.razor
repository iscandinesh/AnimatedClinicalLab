@page "/contact"
@inject IJSRuntime JS
@inject AlphaRazor.Services.EmailService EmailService

<PageTitle>Contact Us - Alpha Diagnostics Centre</PageTitle>

<HeadContent>
    <meta name="description" content="Get in touch with Alpha Diagnostics Centre. Find our contact details, location addresses, phone numbers, or submit an online inquiry for health testing." />
    <meta name="keywords" content="contact Alpha Diagnostics, diagnostics clinic contact, blood lab phone number, Erode clinic address" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.alphadiagnosticscentre.com/contact" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Contact Us - Alpha Diagnostics Centre" />
    <meta property="og:description" content="Get in touch with Alpha Diagnostics Centre. Find our contact details, location addresses, phone numbers, or submit an online inquiry." />
    <meta property="og:url" content="https://www.alphadiagnosticscentre.com/contact" />
</HeadContent>


<!-- Top Hero Banner with Gradient & Blurred Background Image -->
<div class="contact-hero-section">
    <div class="hero-bg-image"></div>
    <div class="hero-bg-overlay"></div>
    <div class="container text-center text-white position-relative z-3">
        <h1 class="hero-title fw-800 mb-3 animate-fade-in" style="color: #ffffff !important;">Feel free to get in touch</h1>
        <p class="hero-subtitle mx-auto opacity-90 animate-fade-in" style="max-width: 650px; color: rgba(255, 255, 255, 0.85) !important;">
            With over 10 years of experience, we can deliver great results for your healthcare diagnostic needs without additional costs or commitments.
        </p>
    </div>
</div>

<!-- Main Split Section with Diagonal Division -->
<div class="contact-split-section">
    <div class="container">
        <div class="row g-5 align-items-stretch">
            
            <!-- Left Side: Form Card -->
            <div class="col-lg-6 d-flex reveal-up">
                <div class="contact-form-card w-100">
                    <h3 class="form-title mb-4">Send us a message</h3>
                    
                    @if (isSubmitted)
                    {
                        <div class="text-center py-5 animate-fade-in h-100 d-flex flex-column justify-content-center">
                            <div class="success-icon-box mx-auto mb-4">
                                <i class="bi bi-check-lg"></i>
                            </div>
                            <h4 class="fw-bold mb-3" style="color: #0f172a;">Message Sent!</h4>
                            <p class="text-secondary small mb-4">Thank you for reaching out. Our team will contact you shortly.</p>
                            <button class="btn-send-message mx-auto" @onclick="ResetForm">Send Another Message</button>
                        </div>
                    }
                    else
                    {
                        <form @onsubmit="HandleSubmit" class="d-flex flex-column gap-3">
                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger animate-fade-in small py-2 px-3 mb-2" role="alert" style="border-radius: 12px; color: #721c24; background-color: #f8d7da; border-color: #f5c6cb;">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
                                </div>
                            }

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label-custom">Full Name</label>
                                    <input type="text" class="form-input-custom" placeholder="Name" @bind="fullName" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Phone Number</label>
                                    <input type="tel" class="form-input-custom" placeholder="Phone" @bind="phoneNumber" required />
                                </div>
                            </div>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label-custom">Email Address</label>
                                    <input type="email" class="form-input-custom" placeholder="Email" @bind="emailAddress" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Subject / Test Type</label>
                                    <select class="form-select form-input-custom" style="height: auto;" @bind="subject">
                                        <option value="Home Sample Collection">Home Sample Collection</option>
                                        <option value="Health Package Inquiry">Health Package Inquiry</option>
                                        <option value="General Question">General Question</option>
                                        <option value="Feedback">Feedback</option>
                                    </select>
                                </div>
                            </div>

                            @if (subject == "Home Sample Collection")
                            {
                                <div class="row g-3 animate-slide-down">
                                    <div class="col-md-6">
                                        <label class="form-label-custom text-nowrap">Preferred date of appointment <span class="text-danger">*</span></label>
                                        <input type="date" class="form-input-custom" @bind="collectionDate" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom text-nowrap">Preferred time of appointment <span class="text-danger">*</span></label>
                                        <input type="time" class="form-input-custom" @bind="collectionTime" required />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label-custom text-nowrap">Preferred Home Collection Address <span class="text-danger">*</span></label>
                                        <input type="text" class="form-input-custom" placeholder="Collection Address" @bind="collectionAddress" required />
                                    </div>
                                </div>
                            }
                            
                            <div>
                                <label class="form-label-custom">Your Message</label>
                                <textarea class="form-input-custom" style="min-height: 100px; resize: none;" rows="2" placeholder="Message" @bind="message" required></textarea>
                            </div>
                            
                            <div class="mt-2 text-end">
                                <button type="submit" class="btn-send-message" disabled="@isSending">
                                    @if (isSending)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        <span>Sending...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-send-fill me-2"></i><span>Send</span>
                                    }
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
            
            <!-- Right Side: Info Panel -->
            <div class="col-lg-6 d-flex align-items-center reveal-up" style="transition-delay: 0.1s;">
                <div class="contact-info-content w-100">
                    <h2 class="info-title mb-3">Don't hesitate to contact us</h2>
                    <p class="info-desc mb-5">
                        Alpha Diagnostics Centre is a trusted partner for medical testing. Reach out to book a test, request home collection, or discuss your health needs.
                    </p>
                    
                    <div class="info-cards-list mb-5">
                        <!-- Card 1: Office -->
                        <div class="info-bar-card reveal-up" style="--accent: #2563eb;">
                            <div class="info-bar-icon" style="background: rgba(37,99,235,0.12);">
                                <i class="bi bi-geo-alt-fill" style="color: #2563eb;"></i>
                            </div>
                            <div class="info-bar-body">
                                <div class="info-bar-label">Office</div>
                                <div class="info-bar-value">16, Patel Street, Erode – 638 001.</div>
                            </div>
                        </div>

                        <!-- Card 2: Phone -->
                        <div class="info-bar-card reveal-up" style="--accent: #f59e0b; transition-delay: 0.08s;">
                            <div class="info-bar-icon" style="background: rgba(245,158,11,0.12);">
                                <i class="bi bi-telephone-fill" style="color: #f59e0b;"></i>
                            </div>
                            <div class="info-bar-body">
                                <div class="info-bar-label">Phone</div>
                                <div class="info-bar-value">70944 90917 &nbsp;|&nbsp; 81108 99999</div>
                            </div>
                        </div>

                        <!-- Card 3: Work Hours -->
                        <div class="info-bar-card reveal-up" style="--accent: #7c3aed; transition-delay: 0.16s;">
                            <div class="info-bar-icon" style="background: rgba(124,58,237,0.12);">
                                <i class="bi bi-clock-fill" style="color: #7c3aed;"></i>
                            </div>
                            <div class="info-bar-body">
                                <div class="info-bar-label">Work Hours</div>
                                <div class="info-bar-value d-flex align-items-center gap-2 flex-wrap">
                                    <span>Open 24 Hours</span>
                                    <span class="sunday-badge">Sunday Available</span>
                                </div>
                            </div>
                        </div>

                        <!-- Card 4: Email -->
                        <div class="info-bar-card reveal-up" style="--accent: #10b981; transition-delay: 0.24s;">
                            <div class="info-bar-icon" style="background: rgba(16,185,129,0.12);">
                                <i class="bi bi-envelope-fill" style="color: #10b981;"></i>
                            </div>
                            <div class="info-bar-body">
                                <div class="info-bar-label">Email</div>
                                <div class="info-bar-value">info@alphadiagnosticscentre.com</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="social-share-row d-flex align-items-center gap-3">
                        <span class="social-label">Social Media :</span>
                        <div class="social-list">
                            <a href="https://www.facebook.com/share/1EtQ8TbU7Z/" target="_blank" rel="noopener noreferrer" class="social-circle-btn bg-fb" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="https://www.instagram.com/alpha.diagnostics.centre?igsh=bDIzcWVpMHV6eTNl" target="_blank" rel="noopener noreferrer" class="social-circle-btn bg-ig" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="https://www.linkedin.com/company/alpha-diagnostics-centre/" target="_blank" rel="noopener noreferrer" class="social-circle-btn bg-ln" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                            <a href="https://www.youtube.com/&#64;alphadiagnosticcentre-u3q" target="_blank" rel="noopener noreferrer" class="social-circle-btn bg-yt" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                            <a href="https://wa.me/918110899999" target="_blank" rel="noopener noreferrer" class="social-circle-btn bg-wa" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

<!-- Bottom Call to Action Section -->
<div class="contact-bottom-cta">
    <div class="container position-relative z-2">
        <div class="cta-inner-card text-center text-white reveal-up">
            <div class="cta-badge d-inline-flex align-items-center gap-2 mb-4">
                <i class="bi bi-house-door-fill"></i> We Ready 24 Hours
            </div>
            <h2 class="cta-heading fw-800 mb-3">Have questions in mind? Let's Talk</h2>
            <p class="cta-paragraph mx-auto mb-4 opacity-80" style="max-width: 580px;">
                For urgent enquiries, blood collection bookings, or diagnostic support, feel free to call our direct lines anytime.
            </p>
            <a href="tel:918110899999" class="cta-phone-btn text-decoration-none">
                +91 81108 99999 <i class="bi bi-telephone-fill ms-2"></i>
            </a>
        </div>
    </div>
</div>

@code {
    private string fullName = "";
    private string phoneNumber = "";
    private string emailAddress = "";
    private string subject = "Home Sample Collection";
    private string message = "";
    
    private string collectionAddress = "";
    private DateOnly? collectionDate = null;
    private TimeOnly? collectionTime = null;

    private bool isSubmitted = false;
    private bool isSending = false;
    private string? errorMessage = null;

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isSending = true;
        try
        {
            if (subject == "Home Sample Collection")
            {
                await EmailService.SendContactFormEmailAsync(
                    fullName, 
                    phoneNumber, 
                    emailAddress, 
                    subject, 
                    message, 
                    collectionAddress, 
                    collectionDate?.ToString("yyyy-MM-dd"), 
                    collectionTime?.ToString("hh:mm tt")
                );
            }
            else
            {
                await EmailService.SendContactFormEmailAsync(fullName, phoneNumber, emailAddress, subject, message);
            }
            isSubmitted = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSending = false;
        }
    }

    private void ResetForm()
    {
        fullName = "";
        phoneNumber = "";
        emailAddress = "";
        subject = "Home Sample Collection";
        message = "";
        collectionAddress = "";
        collectionDate = null;
        collectionTime = null;
        isSubmitted = false;
        errorMessage = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initHeliumAnimations");
        }
    }
}
