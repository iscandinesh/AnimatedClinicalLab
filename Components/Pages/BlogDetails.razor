@page "/blog-details/{id:int}"
@using System.Text.Json
@using AlphaRazor.Services
@implements IDisposable
@inject BlogDbService DbService
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject ThemeService ThemeState

<PageTitle>@(_blog?.Title ?? "Blog Details") - Alpha Diagnostics Centre</PageTitle>

@if (_isLoading)
{
    <div class="loading-container text-center py-5" style="margin-top: 150px;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-secondary">Loading blog details...</p>
    </div>
}
else if (_blog == null || _details == null)
{
    <div class="container text-center py-5" style="margin-top: 150px; max-width: 600px;">
        <div class="glass-card-premium p-5">
            <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
            <h2 class="mt-4 fw-800">Article Not Found</h2>
            <p class="text-secondary mt-3">The article you are looking for does not exist or has been removed.</p>
            <a href="insights" class="btn-helium btn-helium-primary px-5 py-3 mt-4">
                <i class="bi bi-arrow-left me-2"></i> Back to Insights
            </a>
        </div>
    </div>
}
else
{
    <!-- Main Content Details Page in a Single Unified Box -->
    <section class="py-5 position-relative" style="padding-top: 150px !important; overflow: hidden; background: @SectionBackground;">
        <div class="mesh-bg" style="opacity: 0.15;"></div>
        <div class="hero-grid-bg"></div>

        <!-- Local Background Bubbles for Blog Details -->
        <div class="bubble-container animate-bubbles" style="position: fixed; inset: 0; z-index: 1; pointer-events: none; overflow: hidden;">
            <div class="bubble" style="left: 10%; width: 40px; height: 40px; animation-delay: 0s; animation-duration: 12s;"></div>
            <div class="bubble" style="left: 25%; width: 60px; height: 60px; animation-delay: 2s; animation-duration: 15s;"></div>
            <div class="bubble" style="left: 40%; width: 30px; height: 30px; animation-delay: 4s; animation-duration: 10s;"></div>
            <div class="bubble" style="left: 55%; width: 50px; height: 50px; animation-delay: 1s; animation-duration: 14s;"></div>
            <div class="bubble" style="left: 70%; width: 70px; height: 70px; animation-delay: 3s; animation-duration: 18s;"></div>
            <div class="bubble" style="left: 85%; width: 45px; height: 45px; animation-delay: 5s; animation-duration: 13s;"></div>
            <div class="bubble" style="left: 95%; width: 35px; height: 35px; animation-delay: 7s; animation-duration: 11s;"></div>
        </div>

        <div class="container position-relative z-2">
            <!-- Back Button -->
            <a href="insights" class="btn-helium btn-helium-secondary py-2 px-4 mb-4 d-inline-block text-decoration-none">
                <i class="bi bi-arrow-left me-2"></i> Back to Insights
            </a>

            <!-- Single Unified Glass Box containing the entire article and sidebar -->
            <div class="glass-card-premium p-4 p-md-5 shadow-lg overflow-hidden" style="border-radius: 24px;">
                <!-- Header Info (Full width inside the card) -->
                <div class="d-flex gap-2 mb-3 flex-wrap">
                    <span class="badge bg-primary text-uppercase px-3 py-2 fw-600" style="font-size: 0.75rem; letter-spacing: 1px;">@_blog.CategoryBadge</span>
                    @if (!string.IsNullOrEmpty(_blog.Tags))
                    {
                        @foreach (var tag in _blog.Tags.Split(','))
                        {
                            <span class="insight-tag">@tag.Trim()</span>
                        }
                    }
                </div>

                <h1 class="fw-800 text-white mb-4" style="font-size: clamp(1.8rem, 4vw, 2.8rem); line-height: 1.25; margin-bottom: 0.5rem !important;">@_blog.Title</h1>

                @if (!string.IsNullOrEmpty(_blog.SubTitle))
                {
                    <p class="blog-subtitle text-secondary mb-4">@_blog.SubTitle</p>
                }

                <!-- Removed top border/hr, only bottom border remains -->
                <div class="d-flex align-items-center gap-4 flex-wrap my-4 border-bottom border-secondary-subtle pb-4">
                    <div class="d-flex align-items-center gap-3">
                        <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #3b82f6, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; color: white; font-weight: 700;">@_blog.AuthorAvatar</div>
                        <div>
                            <div style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">@_blog.AuthorName</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">@_blog.AuthorTitle</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 text-secondary" style="font-size: 0.9rem;">
                        <div><i class="bi bi-calendar3 me-2"></i> @_blog.Date</div>
                        <div><i class="bi bi-clock me-2"></i> @_blog.ReadTime</div>
                    </div>
                </div>

                <!-- Grid Split: Row 1 contains Image on Left, Trending Posts on Right. Height is same as image. -->
                <div class="row g-4 mt-2 align-items-stretch">
                    <!-- Left Side: Main Image -->
                    <div class="col-lg-8 border-end border-secondary-subtle pe-lg-4 d-flex flex-column justify-content-center">
                        @if (!string.IsNullOrEmpty(_blog.ImagePath))
                        {
                            <div class="rounded-4 overflow-hidden border border-secondary-subtle shadow w-100" style="max-height: 480px; height: 100%;">
                                <img src="@_blog.ImagePath" alt="@_blog.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                        }
                    </div>

                    <!-- Right Side: Trending Posts (Side by side with Image only) -->
                    <div class="col-lg-4 ps-lg-4">
                        <div style="position: sticky; top: 115px;">
                            <!-- Removed XXX, added custom border-bottom matching header text width -->
                            <div class="mb-4">
                                <h3 class="fw-800 text-white mb-2 pb-2" style="font-size: 1.2rem; letter-spacing: 1px; width: max-content; border-bottom: 2px solid #3b82f6;">TRENDING POSTS</h3>
                            </div>

                            <div class="trending-list d-flex flex-column gap-4">
                                @if (_trendingBlogs != null && _trendingBlogs.Any())
                                {
                                    @foreach (var post in _trendingBlogs)
                                    {
                                        <a href="blog-details/@post.Id" class="d-flex gap-3 align-items-center text-decoration-none trending-item-hover" style="transition: all 0.3s ease;">
                                            <div style="width: 80px; height: 80px; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); flex-shrink: 0; background: linear-gradient(135deg, @(post.GradientStart ?? "#1a1a3a") 0%, @(post.GradientEnd ?? "#0f0f2a") 100%); display: flex; align-items: center; justify-content: center;">
                                                @if (!string.IsNullOrEmpty(post.ImagePath))
                                                {
                                                    <img src="@post.ImagePath" alt="@post.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <i class="@(post.IconClass ?? "bi bi-file-earmark-text")" style="font-size: 1.5rem; color: @(post.IconColor ?? "#a78bfa");"></i>
                                                }
                                            </div>
                                            <div style="flex-grow: 1;">
                                                <h4 style="font-size: 0.95rem; font-weight: 600; color: white; margin-bottom: 6px; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: color 0.2s;">
                                                    @post.Title
                                                </h4>
                                                <div style="font-size: 0.75rem; color: var(--text-muted);">
                                                    @post.Date
                                                </div>
                                            </div>
                                        </a>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted mb-0">No other articles available.</p>
                                }
                            </div>

                            <!-- Social share/connect links at the bottom of the 3 blogs list -->
                            <div class="mt-4 pt-4 border-top border-secondary-subtle">
                                <h4 style="font-size: 0.9rem; font-weight: 700; color: white; margin-bottom: 12px; letter-spacing: 0.5px; width: max-content;">SHARE & CONNECT</h4>
                                <div class="d-flex gap-3">
                                    <a href="https://wa.me/?text=@Uri.EscapeDataString(NavManager.Uri)" target="_blank" class="social-icon-btn whatsapp" title="Share on WhatsApp">
                                        <i class="bi bi-whatsapp"></i>
                                    </a>
                                    <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(NavManager.Uri)" target="_blank" class="social-icon-btn facebook" title="Share on Facebook">
                                        <i class="bi bi-facebook"></i>
                                    </a>
                                    <a href="https://www.instagram.com" target="_blank" class="social-icon-btn instagram" title="Follow us on Instagram">
                                        <i class="bi bi-instagram"></i>
                                    </a>
                                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=@Uri.EscapeDataString(NavManager.Uri)" target="_blank" class="social-icon-btn linkedin" title="Share on LinkedIn">
                                        <i class="bi bi-linkedin"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Row 2: Full width Article Body Content (spans the entire main box width) -->
                <div class="row mt-4 pt-2">
                    <div class="col-12">
                        <div class="blog-rich-content">
                            @if (!string.IsNullOrEmpty(_details.ContentHtml))
                            {
                                @((MarkupString)_details.ContentHtml)
                            }
                            else
                            {
                                <!-- Fallback display for JSON-based posts -->
                                <p class="lead mb-4" style="line-height: 1.8; color: var(--text-primary); font-size: 1.2rem; font-weight: 500;">
                                    @_details.Introduction
                                </p>
                                
                                @if (_sections != null)
                                {
                                    @foreach (var section in _sections)
                                    {
                                        <h3 class="fw-700 mt-5 mb-3" style="color: var(--primary-blue); font-size: 1.5rem;">@section.Heading</h3>
                                        <p class="text-secondary mb-4" style="line-height: 1.8; font-size: 1.05rem;">@section.Content</p>
                                    }
                                }

                                @if (!string.IsNullOrEmpty(_details.Conclusion))
                                {
                                    <h3 class="fw-700 mt-5 mb-3" style="color: var(--primary-blue); font-size: 1.5rem;">Conclusion</h3>
                                    <p class="text-secondary mb-4" style="line-height: 1.8; font-size: 1.05rem;">@_details.Conclusion</p>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<style>
    /* Subtitle styling */
    .blog-subtitle {
        font-size: clamp(1.05rem, 2vw, 1.25rem);
        line-height: 1.5;
        font-weight: 400;
        margin-top: -0.5rem;
    }

    /* Custom Sidebar styling */
    .trending-item-hover:hover h4 {
        color: #60a5fa !important;
    }
    .trending-item-hover:hover img {
        transform: scale(1.06);
    }
    .trending-item-hover img {
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Social icons styling */
    .social-icon-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        text-decoration: none;
    }
    .social-icon-btn:hover {
        color: white !important;
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }
    .social-icon-btn.whatsapp:hover { background: #25d366 !important; border-color: #25d366 !important; }
    .social-icon-btn.facebook:hover { background: #1877f2 !important; border-color: #1877f2 !important; }
    .social-icon-btn.instagram:hover { background: #e1306c !important; border-color: #e1306c !important; }
    .social-icon-btn.linkedin:hover { background: #0077b5 !important; border-color: #0077b5 !important; }

    /* Light Theme specific overrides */
    .light-theme .glass-card-premium {
        background: rgba(255, 255, 255, 0.45) !important;
        border: 1px solid rgba(255, 255, 255, 0.6) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05) !important;
    }
    .light-theme .glass-card-premium h1, 
    .light-theme .glass-card-premium h2, 
    .light-theme .glass-card-premium h3, 
    .light-theme .glass-card-premium h4,
    .light-theme .glass-card-premium .text-white {
        color: #0f172a !important;
    }
    .light-theme .blog-rich-content {
        color: #334155 !important;
    }
    .light-theme .blog-rich-content h1,
    .light-theme .blog-rich-content h2,
    .light-theme .blog-rich-content h4 {
        color: #0f172a !important;
    }
    .light-theme .blog-rich-content h3 {
        color: #2563eb !important;
    }
    .light-theme .blog-rich-content blockquote {
        background: rgba(59, 130, 246, 0.05) !important;
        color: #475569 !important;
        border-left-color: #2563eb !important;
    }
    .light-theme .blog-rich-content .cta-button {
        background: linear-gradient(135deg, #2563eb, #1d4ed8) !important;
        box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.3), 0 2px 4px -1px rgba(37, 99, 235, 0.15) !important;
    }
    .light-theme .blog-rich-content .cta-button:hover {
        background: linear-gradient(135deg, #1d4ed8, #1e40af) !important;
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.4), 0 4px 6px -2px rgba(37, 99, 235, 0.2) !important;
    }
    .light-theme .social-icon-btn {
        background: rgba(15, 23, 42, 0.05) !important;
        border: 1px solid rgba(15, 23, 42, 0.08) !important;
        color: rgba(15, 23, 42, 0.6) !important;
    }
    .light-theme .social-icon-btn:hover {
        color: white !important;
    }
    .light-theme .border-secondary-subtle {
        border-color: rgba(0, 0, 0, 0.08) !important;
    }
    .light-theme .text-secondary,
    .light-theme .text-muted {
        color: #64748b !important;
    }

    /* Premium rendering styling for dynamic editor content */
    .blog-rich-content {
        color: rgba(241, 245, 249, 0.9);
        font-size: 1.1rem;
        line-height: 1.85;
    }
    
    .blog-rich-content p {
        margin-bottom: 1.5rem;
    }
    
    .blog-rich-content p.lead {
        font-size: 1.25rem;
        color: #e2e8f0;
        font-weight: 500;
        line-height: 1.8;
    }

    .blog-rich-content h1, 
    .blog-rich-content h2, 
    .blog-rich-content h3, 
    .blog-rich-content h4 {
        color: #ffffff;
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    .blog-rich-content h1 { font-size: 2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; }
    .blog-rich-content h2 { font-size: 1.65rem; }
    .blog-rich-content h3 { font-size: 1.4rem; color: #60a5fa; }
    .blog-rich-content h4 { font-size: 1.2rem; }

    .blog-rich-content ul, 
    .blog-rich-content ol {
        margin-bottom: 1.75rem;
        padding-left: 2rem;
    }

    .blog-rich-content li {
        margin-bottom: 0.5rem;
    }

    /* Blockquotes */
    .blog-rich-content blockquote {
        border-left: 4px solid #3b82f6;
        background: rgba(59, 130, 246, 0.05);
        padding: 1.25rem 1.5rem;
        margin: 2rem 0;
        border-radius: 0 12px 12px 0;
        font-style: italic;
        color: #94a3b8;
    }

    .blog-rich-content blockquote p {
        margin-bottom: 0;
    }

    /* Tables */
    .blog-rich-content table {
        width: 100% !important;
        border-collapse: collapse !important;
        margin: 2rem 0;
        font-size: 1rem;
        background: rgba(15, 23, 42, 0.3);
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .blog-rich-content th, 
    .blog-rich-content td {
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0.75rem 1rem;
        text-align: left;
    }

    .blog-rich-content th {
        background-color: rgba(59, 130, 246, 0.1);
        font-weight: 600;
        color: #60a5fa;
    }

    .blog-rich-content tr:hover {
        background-color: rgba(255, 255, 255, 0.02);
    }

    /* Images inside editor content */
    .blog-rich-content img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        margin: 2rem 0;
        display: block;
    }

    /* Task list items */
    .blog-rich-content ul[data-type="taskList"] {
        list-style: none;
        padding-left: 0.5rem;
    }

    .blog-rich-content li[data-type="taskItem"] {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .blog-rich-content li[data-type="taskItem"] input[type="checkbox"] {
        margin-top: 0.35rem;
        accent-color: #3b82f6;
        cursor: not-allowed;
    }

    /* Custom inline code */
    .blog-rich-content code {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
        color: #f472b6;
        font-family: 'Fira Code', monospace;
    }

    /* FAQ Section */
    .blog-rich-content .faq-section {
        margin: 2.5rem 0;
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 1.75rem;
        backdrop-filter: blur(10px);
    }
    
    .blog-rich-content .faq-section h3 {
        margin-top: 0;
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        color: #60a5fa;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 0.75rem;
        margin-bottom: 1.5rem;
    }
    
    .blog-rich-content .faq-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        margin-bottom: 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    
    .blog-rich-content .faq-item[open] {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(59, 130, 246, 0.3);
    }
    
    .blog-rich-content .faq-item:last-child {
        margin-bottom: 0;
    }

    .blog-rich-content .faq-question {
        padding: 1.25rem;
        font-weight: 700;
        color: #f1f5f9;
        cursor: pointer;
        user-select: none;
        outline: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        list-style: none;
    }

    .blog-rich-content .faq-question::-webkit-details-marker {
        display: none;
    }

    .blog-rich-content .faq-question::after {
        content: '▼';
        font-size: 0.8rem;
        color: #60a5fa;
        transition: transform 0.3s ease;
    }

    .blog-rich-content .faq-item[open] .faq-question::after {
        transform: rotate(180deg);
        color: #3b82f6;
    }

    .blog-rich-content .faq-answer {
        padding: 0 1.25rem 1.25rem 1.25rem;
        color: #cbd5e1;
        font-size: 0.95rem;
        line-height: 1.6;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(0, 0, 0, 0.1);
    }

    .blog-rich-content .faq-actions {
        display: none !important;
    }

    /* Callout Boxes */
    .blog-rich-content .callout-box {
        padding: 1.25rem 1.5rem;
        border-radius: 12px;
        margin: 2rem 0;
        border-left-width: 4px;
        border-left-style: solid;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }

    .blog-rich-content .callout-box.info {
        background-color: rgba(2, 132, 199, 0.1);
        border-left-color: #0284c7;
        color: #bae6fd;
        border: 1px solid rgba(2, 132, 199, 0.15);
        border-left-width: 4px;
    }
    
    .blog-rich-content .callout-box.warning {
        background-color: rgba(217, 119, 6, 0.1);
        border-left-color: #d97706;
        color: #fef3c7;
        border: 1px solid rgba(217, 119, 6, 0.15);
        border-left-width: 4px;
    }
    
    .blog-rich-content .callout-box.success {
        background-color: rgba(22, 163, 74, 0.1);
        border-left-color: #16a34a;
        color: #bbf7d0;
        border: 1px solid rgba(22, 163, 74, 0.15);
        border-left-width: 4px;
    }
    
    .blog-rich-content .callout-box.tip {
        background-color: rgba(147, 51, 234, 0.1);
        border-left-color: #9333ea;
        color: #f3e8ff;
        border: 1px solid rgba(147, 51, 234, 0.15);
        border-left-width: 4px;
    }

    .blog-rich-content .callout-box p {
        margin: 0;
    }

    /* CTA Button Widget base styling */
    .blog-rich-content .cta-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid #334155;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin: 2.5rem 0;
        gap: 1rem;
        flex-wrap: wrap;
        width: 100%;
        box-sizing: border-box;
    }
    .blog-rich-content .cta-text {
        font-weight: 600;
        color: #93c5fd;
        font-size: 1rem;
        flex-grow: 1;
        text-align: left;
    }
    .blog-rich-content .cta-button {
        display: inline-block;
        padding: 10px 24px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #ffffff !important;
        text-decoration: none !important;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        font-family: 'Outfit', sans-serif;
        border: none;
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3), 0 2px 4px -1px rgba(59, 130, 246, 0.15);
        transition: all 0.2s ease-in-out;
        cursor: pointer;
        white-space: nowrap;
    }
    .blog-rich-content .cta-button:hover {
        background: linear-gradient(135deg, #60a5fa, #3b82f6);
        transform: translateY(-1px);
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.4), 0 4px 6px -2px rgba(59, 130, 246, 0.2);
    }
    .blog-rich-content .cta-button:active {
        transform: translateY(0);
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _isLoading = true;
    private bool _animationsInitialized = false;
    private BlogPost? _blog;
    private BlogPostDetails? _details;
    private List<BlogSection>? _sections;
    private List<BlogPost>? _trendingBlogs;

    public class BlogSection
    {
        [System.Text.Json.Serialization.JsonPropertyName("heading")]
        public string Heading { get; set; } = "";
        
        [System.Text.Json.Serialization.JsonPropertyName("content")]
        public string Content { get; set; } = "";
    }

    private string SectionBackground => ThemeState.IsDarkMode 
        ? $"radial-gradient(circle at 50% 120%, {_blog?.GradientStart ?? "#1e3a5f"} 0%, #09070f 90%)"
        : "radial-gradient(circle at 50% 120%, #e2e8f0 0%, #f8fafc 90%)";

    protected override void OnInitialized()
    {
        ThemeState.OnChange += OnThemeChange;
    }

    private void OnThemeChange()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        ThemeState.OnChange -= OnThemeChange;
    }

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _animationsInitialized = false;
        try
        {
            _blog = await DbService.GetBlogByIdAsync(Id);
            if (_blog != null)
            {
                _details = await DbService.GetBlogDetailsAsync(Id);
                if (_details != null && !string.IsNullOrEmpty(_details.DetailedSectionsJson))
                {
                    try
                    {
                        _sections = JsonSerializer.Deserialize<List<BlogSection>>(_details.DetailedSectionsJson);
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error deserializing detailed sections: {ex.Message}");
                    }
                }

                // Fetch other blogs for the sidebar
                var allBlogs = await DbService.GetBlogsAsync();
                _trendingBlogs = allBlogs.Where(b => b.Id != Id).Take(3).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading blog details: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && !_animationsInitialized)
        {
            _animationsInitialized = true;
            try
            {
                await JS.InvokeVoidAsync("initHeliumAnimations");
                await JS.InvokeVoidAsync("eval", "document.querySelectorAll('.faq-item').forEach(el => el.removeAttribute('open'))");
            }
            catch { }
        }
    }
}
