@page "/services"
@inject IJSRuntime JS

<PageTitle>Services - Alpha Diagnostics Centre</PageTitle>

<section class="page-header services-hero py-5 text-center position-relative" style="padding-top: 180px !important; padding-bottom: 120px !important; overflow: visible; min-height: 600px; display: flex; align-items: center;">
    <!-- Aesthetic Background Layers -->
    <div class="mesh-bg"></div>
    <div class="hero-grid-bg"></div>

    <!-- Ambient Glow Orbs -->
    <div class="glow-orb" style="top: 15%; left: 15%; opacity: 0.4;"></div>
    <div class="glow-orb" style="bottom: 15%; right: 15%; background: var(--primary-purple); opacity: 0.4;"></div>
    
    <div class="container position-relative z-2 reveal-up">
        <div class="glass-card-premium p-5 mx-auto" style="max-width: 900px;">
            <div class="badge-pill-premium mb-4 d-inline-block">
                <i class="bi bi-microscope me-2"></i> Comprehensive automated testing
            </div>
            <h1 class="hero-title mb-4">
                Diagnostic <span class="text-primary">Services</span>
            </h1>
            <p class="lead mb-0" style="max-width: 700px; margin: 0 auto; color: var(--text-secondary);">
                Every sample goes through automated and quality-checked processes to ensure dependable results across all major pathology departments.
            </p>
        </div>
    </div>
</section>

<!-- Health Packages Section -->
<section id="health-packages" class="py-5" style="background: rgba(255,255,255,0.01);">
    <div class="container py-5">
        @if (SelectedPackage == null)
        {
            <div class="text-center mb-5 reveal-up">
                <h2 class="section-title fw-800 mb-3" style="font-size: clamp(2.5rem, 5vw, 4rem);">Health Check Packages</h2>
                <p class="text-secondary">Choose a comprehensive package tailored to your health needs.</p>
                
                <!-- Filter Tabs -->
                <div class="d-flex justify-content-center gap-2 mt-4 flex-wrap">
                    <button class="btn-helium @(ActiveCategory == "All" ? "btn-helium-primary" : "btn-helium-secondary") px-4" @onclick='() => SetCategory("All")'>All Packages</button>
                    <button class="btn-helium @(ActiveCategory == "Health Checkups" ? "btn-helium-primary" : "btn-helium-secondary") px-4" @onclick='() => SetCategory("Health Checkups")'>Health Checkups</button>
                    <button class="btn-helium @(ActiveCategory == "Specialty Packages" ? "btn-helium-primary" : "btn-helium-secondary") px-4" @onclick='() => SetCategory("Specialty Packages")'>Specialty Packages</button>
                </div>
            </div>

            <!-- Packages Grid -->
            <div class="package-grid">
                @foreach (var pkg in FilteredPackages())
                {
                    <div class="package-card reveal-up">
                        @if (pkg.IsBestseller)
                        {
                            <div class="bestseller-badge">Most Popular</div>
                        }
                        <div class="package-image-container">
                            <img src="@pkg.ImageUrl" alt="@pkg.Name" />
                            <div class="package-image-overlay"></div>
                            <div class="package-overlay-badges">
                                <span class="badge-test-count"><i class="bi bi-activity me-1"></i>@pkg.TestCount tests</span>
                                <span class="badge-subcategory">@pkg.Subcategory</span>
                            </div>
                        </div>
                        <div class="package-content">
                            <h3 class="package-title">@pkg.Name</h3>
                            <p class="package-desc">@pkg.Description</p>
                            
                            <hr class="package-divider" />
                            
                            <div class="price-container">
                                <span class="price-actual">₹@pkg.Price.ToString("N0")</span>
                                <span class="price-original">₹@pkg.OriginalPrice.ToString("N0")</span>
                                <span class="price-discount-badge">@pkg.Discount</span>
                            </div>
                            
                            <div class="package-action-row mt-auto">
                                <button class="btn-book-now" @onclick="() => BookPackage(pkg)"><i class="bi bi-cart-fill"></i>Add to Book</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Dynamic Detail Page View -->
            <div class="reveal-up">
                <!-- Breadcrumb Back button -->
                <button class="btn-back-to-packages" @onclick="CloseDetails">
                    <i class="bi bi-arrow-left"></i> Back to all packages
                </button>
                
                <!-- Details Header split grid -->
                <div class="details-split-grid">
                    <!-- Left column: Visual image -->
                    <div class="details-image-card">
                        @if (SelectedPackage.IsBestseller)
                        {
                            <div class="bestseller-badge">Most Popular</div>
                        }
                        <img src="@SelectedPackage.ImageUrl" alt="@SelectedPackage.Name" />
                    </div>
                    
                    <!-- Right column: package details -->
                    <div class="details-info-panel">
                        <div class="details-badge-row">
                            <span class="badge bg-success text-white px-3 py-1 rounded-pill small">@SelectedPackage.Category</span>
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-1 rounded-pill small">@SelectedPackage.Subcategory</span>
                            <span class="badge bg-dark-subtle text-dark-emphasis px-3 py-1 rounded-pill small">@SelectedPackage.TestCount tests</span>
                        </div>
                        
                        <h1 class="details-title">@SelectedPackage.Name</h1>
                        <p class="details-desc">@SelectedPackage.Description</p>
                        
                        <div class="details-price-row">
                            <span class="details-price-actual">₹@SelectedPackage.Price.ToString("N0")</span>
                            <span class="details-price-original">₹@SelectedPackage.OriginalPrice.ToString("N0")</span>
                            <span class="price-discount-badge fs-6">@SelectedPackage.Discount</span>
                        </div>
                        
                        <button class="details-btn-book" @onclick="() => BookPackage(SelectedPackage)">
                            <i class="bi bi-cart-fill"></i> Add to Book Package
                        </button>
                    </div>
                </div>
                
                <!-- What's Included Section -->
                <div class="mt-5 pt-4 border-top border-subtle border-opacity-10">
                    <h3 class="included-section-header">What's Included</h3>
                    
                    <div class="notice-box">
                        <i class="bi bi-info-circle-fill notice-box-icon"></i>
                        <p class="notice-box-text">
                            <strong>@SelectedPackage.TestCount tests included</strong> in this @SelectedPackage.Subcategory.ToLower() diagnostic panel. 
                            All tests are conducted by NABL-accredited labs. Reports are delivered digitally within 24 hours of sample collection. 
                            Home sample pickup is available across all our branch locations.
                        </p>
                    </div>
                    
                    <!-- Checklist Grid -->
                    <div class="tests-checklist-grid">
                        @foreach (var test in SelectedPackage.Tests)
                        {
                            <div class="test-check-item">
                                <div class="test-check-icon-wrap">
                                    <i class="bi bi-check"></i>
                                </div>
                                <span class="test-check-name">@test</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<!-- Departments Section -->
<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <h2 class="section-title fw-800 mb-3" style="font-size: clamp(2.5rem, 5vw, 4rem);">Our Departments</h2>
            <p class="text-secondary">Specialized testing across the full spectrum of pathology.</p>
        </div>
        <div class="row g-4">
            <!-- Biochemistry -->
            <div class="col-lg-4 col-md-6 reveal-up">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-blue">
                        <i class="bi bi-droplet-half fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Biochemistry</h3>
                    <p class="text-secondary small mb-4">Tests for blood sugar, cholesterol, liver and kidney functions, electrolytes, enzymes, and more.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Blood Sugar (FBS/PPBS/RBS)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Liver Function Test (LFT)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Renal Function Test (RFT)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Lipid Profile</li>
                    </ul>
                </div>
            </div>

            <!-- Hematology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.1s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-cyan">
                        <i class="bi bi-water fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Hematology</h3>
                    <p class="text-secondary small mb-4">Complete blood counts, differential counts, clotting studies, and fluid analysis with 6-part analyzers.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Complete Blood Count (CBC)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> 6-Part Differential Count</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Coagulation Studies</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Body Fluid Analysis</li>
                    </ul>
                </div>
            </div>

            <!-- Immunology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.2s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-red">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Immunology</h3>
                    <p class="text-secondary small mb-4">Hormone panels, thyroid tests, infection markers, and other immune-related assays using chemiluminescence.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Thyroid Panel (FT3, FT4, TSH)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Hormone Tests (LH, FSH)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Cardiac Markers (Troponin)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Vitamin D & B12</li>
                    </ul>
                </div>
            </div>

            <!-- Microbiology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.3s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-purple">
                        <i class="bi bi-virus fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Microbiology</h3>
                    <p class="text-secondary small mb-4">Culture and sensitivity for blood and body fluids with automated BACTEC and VITEK systems.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Blood Culture (BD BACTEC)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Antibiotic Sensitivity (VITEK 2)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Gram Stain & Microscopy</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Positive Culture in ~4 Hours</li>
                    </ul>
                </div>
            </div>

            <!-- PCR / Molecular -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.4s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-blue">
                        <i class="bi bi-fingerprint fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">PCR / Molecular</h3>
                    <p class="text-secondary small mb-4">PCR-based tests using advanced Bio-Rad CFX96 platform for precise molecular detection.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> COVID-19 PCR Testing</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> TB Molecular Detection</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Viral Load Testing</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Genetic Screening</li>
                    </ul>
                </div>
            </div>

            <!-- Histopathology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.5s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-cyan">
                        <i class="bi bi-layers-half fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Histopathology</h3>
                    <p class="text-secondary small mb-4">Tissue and biopsy examination by experienced pathologists to support diagnosis.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Tissue Biopsy Examination</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Cytology & Papsmear</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> FNAC Reports</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Expert Pathologist Review</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Hospital & Referral Services -->
