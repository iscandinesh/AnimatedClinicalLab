@page "/services"
@inject IJSRuntime JS

<PageTitle>Services - Alpha Diagnostics Centre</PageTitle>

<section class="page-header py-5 text-center position-relative" style="padding-top: 180px !important; padding-bottom: 120px !important; overflow: hidden; min-height: 600px; display: flex; align-items: center;">
    <!-- Aesthetic Background Layers -->
    <div class="mesh-bg"></div>
    <div class="hero-grid-bg"></div>

    <!-- Ambient Glow Orbs -->
    <div class="glow-orb" style="top: 15%; left: 15%; opacity: 0.4;"></div>
    <div class="glow-orb" style="bottom: 15%; right: 15%; background: var(--primary-purple); opacity: 0.4;"></div>
    
    <div class="container position-relative z-2 reveal-up">
        <div class="glass-card-premium p-5 mx-auto" style="max-width: 900px;">
            <div class="badge-pill-premium mb-4 d-inline-block">
                <i class="bi bi-microscope me-2"></i> Comprehensive automated testing
            </div>
            <h1 class="hero-title mb-4">
                Diagnostic <span class="text-primary">Services</span>
            </h1>
            <p class="lead mb-0" style="max-width: 700px; margin: 0 auto; color: var(--text-secondary);">
                Every sample goes through automated and quality-checked processes to ensure dependable results across all major pathology departments.
            </p>
        </div>
    </div>
</section>

<!-- Departments Section -->
<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <h2 class="section-title">Our Departments</h2>
            <p class="text-secondary">Specialized testing across the full spectrum of pathology.</p>
        </div>
        <div class="row g-4">
            <!-- Biochemistry -->
            <div class="col-lg-4 col-md-6 reveal-up">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-blue">
                        <i class="bi bi-droplet-half fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Biochemistry</h3>
                    <p class="text-secondary small mb-4">Tests for blood sugar, cholesterol, liver and kidney functions, electrolytes, enzymes, and more.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Blood Sugar (FBS/PPBS/RBS)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Liver Function Test (LFT)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Renal Function Test (RFT)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Lipid Profile</li>
                    </ul>
                </div>
            </div>

            <!-- Hematology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.1s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-cyan">
                        <i class="bi bi-water fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Hematology</h3>
                    <p class="text-secondary small mb-4">Complete blood counts, differential counts, clotting studies, and fluid analysis with 6-part analyzers.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Complete Blood Count (CBC)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> 6-Part Differential Count</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Coagulation Studies</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Body Fluid Analysis</li>
                    </ul>
                </div>
            </div>

            <!-- Immunology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.2s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-red">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Immunology</h3>
                    <p class="text-secondary small mb-4">Hormone panels, thyroid tests, infection markers, and other immune-related assays using chemiluminescence.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Thyroid Panel (FT3, FT4, TSH)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Hormone Tests (LH, FSH)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Cardiac Markers (Troponin)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Vitamin D & B12</li>
                    </ul>
                </div>
            </div>

            <!-- Microbiology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.3s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-purple">
                        <i class="bi bi-virus fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Microbiology</h3>
                    <p class="text-secondary small mb-4">Culture and sensitivity for blood and body fluids with automated BACTEC and VITEK systems.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Blood Culture (BD BACTEC)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Antibiotic Sensitivity (VITEK 2)</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Gram Stain & Microscopy</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Positive Culture in ~4 Hours</li>
                    </ul>
                </div>
            </div>

            <!-- PCR / Molecular -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.4s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-blue">
                        <i class="bi bi-fingerprint fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">PCR / Molecular</h3>
                    <p class="text-secondary small mb-4">PCR-based tests using advanced Bio-Rad CFX96 platform for precise molecular detection.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> COVID-19 PCR Testing</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> TB Molecular Detection</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Viral Load Testing</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Genetic Screening</li>
                    </ul>
                </div>
            </div>

            <!-- Histopathology -->
            <div class="col-lg-4 col-md-6 reveal-up" style="transition-delay: 0.5s;">
                <div class="glass-card h-100 p-5">
                    <div class="service-icon-box orb-cyan">
                        <i class="bi bi-layers-half fs-3"></i>
                    </div>
                    <h3 class="h4 fw-bold mb-3">Histopathology</h3>
                    <p class="text-secondary small mb-4">Tissue and biopsy examination by experienced pathologists to support diagnosis.</p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Tissue Biopsy Examination</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Cytology & Papsmear</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> FNAC Reports</li>
                        <li class="text-secondary small d-flex align-items-center gap-2"><i class="bi bi-check2 text-primary"></i> Expert Pathologist Review</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Health Packages Section -->
<section class="py-5" style="background: rgba(255,255,255,0.01);">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <h2 class="section-title">Health Check Packages</h2>
            <p class="text-secondary">Choose a comprehensive package tailored to your health needs.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <!-- Basic -->
            <div class="col-lg-4 reveal-up">
                <div class="glass-card h-100 p-5">
                    <h3 class="h4 fw-bold mb-3">Basic Health Checkup</h3>
                    <hr class="border-subtle border-opacity-10 mb-4">
                    <ul class="list-unstyled d-flex flex-column gap-3 mb-5">
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> CBC & ESR</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Fasting & PP Blood Sugar</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Lipid Profile (Cholesterol)</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Renal Function (Urea, Creatinine)</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Urine Routine & ECG</li>
                    </ul>
                    <a href="contact" class="btn-helium btn-helium-secondary w-100 text-center">Book Now</a>
                </div>
            </div>

            <!-- Master -->
            <div class="col-lg-4 reveal-up" style="transition-delay: 0.1s;">
                <div class="glass-card h-100 p-5 border-primary border-opacity-30">
                    <div class="position-absolute top-0 end-0 bg-primary text-white px-3 py-1 fw-bold small rounded-start" style="margin-top: 20px;">MOST POPULAR</div>
                    <h3 class="h4 fw-bold mb-3">Master Health Checkup</h3>
                    <hr class="border-subtle border-opacity-10 mb-4">
                    <ul class="list-unstyled d-flex flex-column gap-3 mb-5">
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> All BHC Tests Included</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Liver Function Test (LFT)</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> HbA1C & FT4 / TSH</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Chest X-Ray & PFT</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Doctor Consultation</li>
                    </ul>
                    <a href="contact" class="btn-helium btn-helium-primary w-100 text-center">Book Now</a>
                </div>
            </div>

            <!-- Executive -->
            <div class="col-lg-4 reveal-up" style="transition-delay: 0.2s;">
                <div class="glass-card h-100 p-5">
                    <h3 class="h4 fw-bold mb-3">Executive Health Checkup</h3>
                    <hr class="border-subtle border-opacity-10 mb-4">
                    <ul class="list-unstyled d-flex flex-column gap-3 mb-5">
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> All MHC Tests Included</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Vitamin D & Vitamin B12</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Ultrasonography (Abdomen)</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> TMT & Cardiac Profile</li>
                        <li class="text-secondary small d-flex align-items-start gap-2"><i class="bi bi-check2 text-primary mt-1"></i> Premium Consultation</li>
                    </ul>
                    <a href="contact" class="btn-helium btn-helium-secondary w-100 text-center">Book Now</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Hospital & Referral Services -->
<section class="py-5">
    <div class="container py-5">
        <div class="row g-4">
            <!-- Large Info Card -->
            <div class="col-lg-5 reveal-up">
                <div class="glass-card h-100 p-5 border-primary border-opacity-50">
                    <div class="service-icon-box orb-blue mb-4">
                        <i class="bi bi-hospital fs-3"></i>
                    </div>
                    <h2 class="h3 fw-bold mb-4">Hospital & Referral Services</h2>
                    <p class="text-secondary mb-4">We act as a referral lab for hospitals, nursing homes, clinics, and diagnostic centres across Erode and nearby regions.</p>
                    <p class="text-secondary mb-0">Our barcoded and interfaced systems make it easy for partner centres to send samples and receive reports quickly and securely.</p>
                </div>
            </div>

            <!-- Small Grid Cards -->
            <div class="col-lg-7">
                <div class="row g-4">
                    <div class="col-md-6 reveal-up" style="transition-delay: 0.1s;">
                        <div class="glass-card p-4 text-center h-100">
                            <div class="orb-blue mx-auto mb-3" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 14px;">
                                <i class="bi bi-building-check fs-4"></i>
                            </div>
                            <h4 class="h6 fw-bold mb-2">Partner Hospitals</h4>
                            <p class="text-secondary x-small mb-0">Trusted by 50+ healthcare facilities across the district.</p>
                        </div>
                    </div>
                    <div class="col-md-6 reveal-up" style="transition-delay: 0.2s;">
                        <div class="glass-card p-4 text-center h-100">
                            <div class="orb-cyan mx-auto mb-3" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 14px;">
                                <i class="bi bi-node-plus fs-4"></i>
                            </div>
                            <h4 class="h6 fw-bold mb-2">Interfaced Systems</h4>
                            <p class="text-secondary x-small mb-0">Direct HL7/API integration for seamless data transfer.</p>
                        </div>
                    </div>
                    <div class="col-md-6 reveal-up" style="transition-delay: 0.3s;">
                        <div class="glass-card p-4 text-center h-100">
                            <div class="orb-purple mx-auto mb-3" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 14px;">
                                <i class="bi bi-geo-alt fs-4"></i>
                            </div>
                            <h4 class="h6 fw-bold mb-2">15+ Locations</h4>
                            <p class="text-secondary x-small mb-0">Extensive network covering Erode, Perundurai, and beyond.</p>
                        </div>
                    </div>
                    <div class="col-md-6 reveal-up" style="transition-delay: 0.4s;">
                        <div class="glass-card p-4 text-center h-100">
                            <div class="orb-red mx-auto mb-3" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 14px;">
                                <i class="bi bi-award fs-4"></i>
                            </div>
                            <h4 class="h6 fw-bold mb-2">NABL & ICMR</h4>
                            <p class="text-secondary x-small mb-0">Accredited reporting you can rely on for critical cases.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Turnaround Section -->
<section class="py-5 bg-midnight-soft">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
            <!-- Left Info -->
            <div class="col-lg-5 reveal-up">
                <h2 class="h1 fw-bold mb-4">Turnaround Time & Reporting</h2>
                <p class="text-secondary fs-5 mb-4">Many routine tests are reported within 4 hours in Erode district, while specialized tests follow clear timelines shared at the time of booking.</p>
                <p class="text-secondary fs-5">Reports are available through online portals, email, and WhatsApp, as well as printed copies at our centres.</p>
            </div>

            <!-- Right Cards -->
            <div class="col-lg-7">
                <div class="row g-4 mb-4">
                    <div class="col-sm-6 reveal-up" style="transition-delay: 0.1s;">
                        <div class="glass-card p-4 text-center">
                            <div class="display-4 fw-bold text-primary mb-1">4 Hrs</div>
                            <div class="text-secondary small">Routine Tests in Erode</div>
                        </div>
                    </div>
                    <div class="col-sm-6 reveal-up" style="transition-delay: 0.2s;">
                        <div class="glass-card p-4 text-center">
                            <div class="display-4 fw-bold text-info mb-1">24-72</div>
                            <div class="text-secondary small">Hours for Specialized Tests</div>
                        </div>
                    </div>
                </div>
                <div class="reveal-up" style="transition-delay: 0.3s;">
                    <div class="glass-card p-4 d-flex align-items-center gap-4">
                        <div class="orb-red" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; border-radius: 16px; flex-shrink: 0;">
                            <i class="bi bi-whatsapp fs-2"></i>
                        </div>
                        <div>
                            <h4 class="h5 fw-bold mb-1">Digital Report Delivery</h4>
                            <p class="text-secondary small mb-0">WhatsApp • Email • Online Portal • Printed at Centre</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initHeliumAnimations");
        }
    }
}
