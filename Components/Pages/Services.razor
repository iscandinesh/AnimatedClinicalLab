@page "/services"

<PageTitle>Services - Alpha Diagnostics Centre</PageTitle>

<section class="page-header py-5 text-center text-white position-relative"
         style="background: var(--gradient-primary); padding-top: 120px !important; padding-bottom: 80px !important;">
    <div class="container position-relative z-2 animate-fade-in-up">
        <div class="badge-pill mb-3 glass-panel-dark d-inline-block px-4 py-2 text-white border-white border-opacity-25"
             style="border-radius: 30px;">
            <i class="bi bi-clipboard2-pulse me-2"></i> What We Offer
        </div>
        <h1 class="display-4 fw-bold mb-3 mt-2">Diagnostic Services</h1>
        <p class="lead mb-0 text-white opacity-75">Comprehensive automated testing across all major pathology departments.</p>
    </div>
</section>

<!-- Departments Section -->
<section class="py-5 bg-white">
    <div class="container py-5">
        <div class="text-center mb-5 animate-fade-in-up">
            <h2 class="section-title">Our Departments</h2>
            <p class="section-subtitle">Every sample goes through automated and quality-checked processes to ensure dependable results.</p>
        </div>

        <div class="row g-4">
            <!-- Biochemistry -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-100">
                <div class="modern-card h-100">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="card-icon flex-shrink-0"><i class="bi bi-droplet-half"></i></div>
                        <h4 class="fw-bold mb-0">Biochemistry</h4>
                    </div>
                    <p class="text-secondary mb-4">Tests for blood sugar, cholesterol, liver and kidney functions, electrolytes, enzymes, and more.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-primary"></i> Blood Sugar (FBS / PPBS / RBS)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-primary"></i> Liver Function Test (LFT)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-primary"></i> Renal Function Test (RFT)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-primary"></i> Lipid Profile</li>
                        <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-primary"></i> Electrolytes & Enzymes</li>
                    </ul>
                </div>
            </div>

            <!-- Hematology -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-200">
                <div class="modern-card h-100">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="card-icon flex-shrink-0" style="background: #fee2e2; color: #dc2626;"><i class="bi bi-droplet"></i></div>
                        <h4 class="fw-bold mb-0">Hematology</h4>
                    </div>
                    <p class="text-secondary mb-4">Complete blood counts, differential counts, clotting studies, and fluid analysis with 5-part and 6-part analyzers.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-danger"></i> Complete Blood Count (CBC)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-danger"></i> 6-Part Differential Count</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-danger"></i> ESR & Peripheral Smear</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-danger"></i> Coagulation Studies</li>
                        <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-danger"></i> Body Fluid Analysis (Sysmex XN-350)</li>
                    </ul>
                </div>
            </div>

            <!-- Immunology -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-300">
                <div class="modern-card h-100">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="card-icon flex-shrink-0" style="background: #ede9fe; color: #7c3aed;"><i class="bi bi-shield-plus"></i></div>
                        <h4 class="fw-bold mb-0">Immunology</h4>
                    </div>
                    <p class="text-secondary mb-4">Hormone panels, thyroid tests, infection markers, and other immune-related assays using chemiluminescence platforms.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-purple"></i> Thyroid Panel (FT3, FT4, TSH)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-purple"></i> Hormone Tests (LH, FSH, Prolactin)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-purple"></i> Cardiac Markers (Troponin, CK-MB)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-purple"></i> Vitamin D & B12</li>
                        <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-purple"></i> VITROS ECIQ Platform</li>
                    </ul>
                </div>
            </div>

            <!-- Microbiology -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-400">
                <div class="modern-card h-100">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="card-icon flex-shrink-0" style="background: #d1fae5; color: #059669;"><i class="bi bi-bug"></i></div>
                        <h4 class="fw-bold mb-0">Microbiology</h4>
                    </div>
                    <p class="text-secondary mb-4">Culture and sensitivity for blood and body fluids with BD BACTEC and VITEK for early and accurate results.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-success"></i> Blood Culture (BD BACTEC Fx40)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-success"></i> Urine & Body Fluid Culture</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-success"></i> Antibiotic Sensitivity (VITEK 2)</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-success"></i> Gram Stain & Microscopy</li>
                        <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-success"></i> Positive Culture in ~4 Hours</li>
                    </ul>
                </div>
            </div>

            <!-- Histopathology -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-500">
                <div class="modern-card h-100">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="card-icon flex-shrink-0" style="background: #fef3c7; color: #d97706;"><i class="bi bi-file-medical"></i></div>
                        <h4 class="fw-bold mb-0">Histopathology</h4>
                    </div>
                    <p class="text-secondary mb-4">Tissue and biopsy examination by experienced pathologists to support accurate diagnosis and treatment planning.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-warning"></i> Tissue Biopsy Examination</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-warning"></i> Cytology & Papsmear</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-warning"></i> FNAC Reports</li>
                        <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-warning"></i> Stool Occult Blood</li>
                        <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2-circle text-warning"></i> Expert Pathologist Review</li>
                    </ul>
                </div>
            </div>

            <!-- PCR / Molecular -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-600">
                <div class="modern-card h-100" style="background: var(--gradient-primary); color: white; border: none;">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="card-icon flex-shrink-0" style="background: rgba(255,255,255,0.2); color: white;"><i class="bi bi-dna"></i></div>
                        <h4 class="fw-bold mb-0 text-white">PCR / Molecular</h4>
                    </div>
                    <p class="mb-4 opacity-75">PCR-based tests using advanced Bio-Rad CFX96 platform for precise molecular detection.</p>
                    <ul class="list-unstyled mb-0">
                        <li class="py-2 border-bottom border-white border-opacity-25 d-flex align-items-center gap-2 small opacity-90"><i class="bi bi-check2-circle"></i> COVID-19 PCR Testing</li>
                        <li class="py-2 border-bottom border-white border-opacity-25 d-flex align-items-center gap-2 small opacity-90"><i class="bi bi-check2-circle"></i> TB Molecular Detection</li>
                        <li class="py-2 border-bottom border-white border-opacity-25 d-flex align-items-center gap-2 small opacity-90"><i class="bi bi-check2-circle"></i> Viral Load Testing</li>
                        <li class="py-2 border-bottom border-white border-opacity-25 d-flex align-items-center gap-2 small opacity-90"><i class="bi bi-check2-circle"></i> Genetic Screening</li>
                        <li class="py-2 d-flex align-items-center gap-2 small opacity-90"><i class="bi bi-check2-circle"></i> Bio-Rad CFX96 Platform</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Health Packages -->
<section class="py-5 bg-main">
    <div class="container py-5">
        <div class="text-center mb-5 animate-fade-in-up">
            <h2 class="section-title">Health Check Packages</h2>
            <p class="section-subtitle">Choose a comprehensive package tailored to your health needs at competitive pricing.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- BHC -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-100">
                <div class="modern-card h-100 p-0 overflow-hidden">
                    <div class="p-4 text-white text-center" style="background: linear-gradient(135deg,#1565c0,#42a5f5);">
                        <i class="bi bi-clipboard-heart fs-1 mb-3 d-block opacity-75"></i>
                        <h4 class="fw-bold mb-1">Basic Health Checkup</h4>
                        <small class="opacity-75">BHC</small>
                    </div>
                    <div class="p-4">
                        <ul class="list-unstyled mb-4">
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Complete Blood Count</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Fasting & Postprandial Blood Sugar</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Lipid Profile</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Renal Function Test</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Uric Acid / SGOT / Bilirubin / TSH</li>
                            <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Urine Routine / ECG</li>
                        </ul>
                        <a href="contact" class="btn btn-primary-custom w-100">Book Now <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>

            <!-- MHC -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-200">
                <div class="modern-card h-100 p-0 overflow-hidden" style="transform: scale(1.03); box-shadow: 0 25px 50px rgba(0,176,255,0.2);">
                    <div class="position-absolute top-0 end-0 bg-warning text-dark px-3 py-1 fw-bold small" style="border-radius: 0 20px 0 20px; z-index:5;">Popular</div>
                    <div class="p-4 text-white text-center" style="background: linear-gradient(135deg,#0d47a1,#00b0ff);">
                        <i class="bi bi-heart-pulse fs-1 mb-3 d-block opacity-75"></i>
                        <h4 class="fw-bold mb-1">Master Health Checkup</h4>
                        <small class="opacity-75">MHC</small>
                    </div>
                    <div class="p-4">
                        <ul class="list-unstyled mb-4">
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> All BHC tests included</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Liver Function Test (LFT)</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> HbA1C / Calcium / FT4 / TSH / ESR</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Total PSA / Papsmear</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> ECG / Pulmonary Function Test</li>
                            <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Chest X-Ray + Doctor Consultation</li>
                        </ul>
                        <a href="contact" class="btn btn-primary-custom w-100">Book Now <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>

            <!-- EHC -->
            <div class="col-lg-4 col-md-6 animate-fade-in-up delay-300">
                <div class="modern-card h-100 p-0 overflow-hidden">
                    <div class="p-4 text-white text-center" style="background: linear-gradient(135deg,#002171,#0d47a1);">
                        <i class="bi bi-award fs-1 mb-3 d-block opacity-75"></i>
                        <h4 class="fw-bold mb-1">Executive Health Checkup</h4>
                        <small class="opacity-75">EHC</small>
                    </div>
                    <div class="p-4">
                        <ul class="list-unstyled mb-4">
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> All MHC tests included</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Vitamin D / Vitamin B12</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Sodium / Potassium / Calcium</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> FT3 / FT4 / TSH + Peripheral Smear</li>
                            <li class="py-2 border-bottom d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> Ultrasonography (Abdomen) / TMT</li>
                            <li class="py-2 d-flex align-items-center gap-2 text-secondary small"><i class="bi bi-check2 text-primary"></i> PFT + Doctor Consultation</li>
                        </ul>
                        <a href="contact" class="btn btn-primary-custom w-100">Book Now <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Turnaround Time Strip -->
<section class="py-5" style="background: var(--gradient-dark); color: white;">
    <div class="container py-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h2 class="fw-bold mb-3">Turnaround Time & Reporting</h2>
                <p class="opacity-75 mb-4">Many routine tests are reported within 4 hours in Erode district, while specialized tests follow clear timelines shared at the time of booking.</p>
                <p class="opacity-75 mb-0">Reports are available through online portals, email, and WhatsApp, as well as printed copies at our centres.</p>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="glass-panel-dark p-4 text-center rounded-4 border border-white border-opacity-10">
                            <h2 class="display-5 fw-bold text-gradient mb-0">4 Hrs</h2>
                            <small class="opacity-75 d-block mt-2">Routine Tests in Erode</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="glass-panel-dark p-4 text-center rounded-4 border border-white border-opacity-10">
                            <h2 class="display-5 fw-bold text-gradient mb-0">24-72</h2>
                            <small class="opacity-75 d-block mt-2">Hours for Specialized Tests</small>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="glass-panel-dark p-4 rounded-4 border border-white border-opacity-10 d-flex align-items-center gap-3">
                            <i class="bi bi-whatsapp text-success fs-2"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Digital Report Delivery</h6>
                                <p class="mb-0 opacity-75 small">WhatsApp · Email · Online Portal · Printed at Centre</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Referral Services -->
<section class="py-5 bg-white">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 animate-fade-in-left">
                <div class="glass-panel p-5 border-start border-5 border-primary rounded-end-4 h-100 d-flex flex-column justify-content-center">
                    <i class="bi bi-building-add text-primary fs-1 mb-4 opacity-25"></i>
                    <h3 class="fw-bold mb-3">Hospital & Referral Services</h3>
                    <p class="text-secondary mb-4">We act as a referral lab for hospitals, nursing homes, clinics, and diagnostic centres across Erode and nearby regions.</p>
                    <p class="text-secondary mb-0">Our barcoded and interfaced systems make it easy for partner centres to send samples and receive reports quickly and securely.</p>
                </div>
            </div>
            <div class="col-lg-7 animate-fade-in-right delay-200">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="modern-card p-4 text-center">
                            <i class="bi bi-hospital text-primary fs-2 mb-3 d-block"></i>
                            <h6 class="fw-bold">Partner Hospitals</h6>
                            <p class="text-secondary small mb-0">Aadhitya Multicare, Manian Medical, Padmanabhan's Heart Clinic, Sholai Medical and more</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="modern-card p-4 text-center">
                            <i class="bi bi-diagram-3 text-info fs-2 mb-3 d-block"></i>
                            <h6 class="fw-bold">Interfaced Systems</h6>
                            <p class="text-secondary small mb-0">Barcoded workflows for fast, error-free report transfer to partner centres</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="modern-card p-4 text-center">
                            <i class="bi bi-geo-alt text-success fs-2 mb-3 d-block"></i>
                            <h6 class="fw-bold">15+ Locations</h6>
                            <p class="text-secondary small mb-0">Branches across Erode, Perundurai, Gobi, Bhavani, Coimbatore, Anthiyur & Tiruppur</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="modern-card p-4 text-center">
                            <i class="bi bi-award text-warning fs-2 mb-3 d-block"></i>
                            <h6 class="fw-bold">NABL & ICMR</h6>
                            <p class="text-secondary small mb-0">Accredited and approved quality standards for reliable referral reporting</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
