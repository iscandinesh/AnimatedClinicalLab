    private async Task CloseDetails()
    {
        SelectedPackage = null;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 300);
    }

    private async Task BookPackage(MedicalPackage pkg)
    {
        await JS.InvokeVoidAsync("alert", $"Booking Request Received:\n\n{pkg.Name} (₹{pkg.Price:N0}) has been selected. Our collection team will contact you shortly to schedule your home sample collection!");
